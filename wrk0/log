8735 |     +                                            R_FEDERAL_TAX_RATE(MO)|
8736 |            ELSE|
8737 |               R_FEDERAL_BTL_TAXABLE_INCOME(MO) = 0.|
8738 |               R_FEDERAL_BTL_INCOME_TAX(MO) = 0.|
8739 |            ENDIF|
8740 |C|
8741 |C CALCULATE DEFERRED TAXES DR CAUSED BY NOLs|
8742 |C|
8743 |            R_FED_DEF_TAX_DR_NOLS_AMT(MO) = R_FEDERAL_TAX_RATE(MO) *|
8744 |     +                                  (R_FEDERAL_NOLS_USED(MO)|
8745 |     +                                   - R_FEDERAL_NOLS_GENERATED(MO))|
