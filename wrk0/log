6979 |C|
6980 |C DECOMMISION FUND EARNINGS|
6981 |C|
6982 |            CALL RETURN_MONTHLY_NUC_DECOM_CASH_ADDENDUMS(CLASS_ID,R_YR,|
6983 |     +                                   MONTHLY_NUC_DECOM_CASH_VALUES,|
6984 |     +                                   MONTHLY_NUC_DECOM_EARNINGS_ADJ)|
