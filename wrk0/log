8570 |C|
8571 |C CHECK FOR ACTUAL STATE INCOME TAXES|
8572 |C|
8573 |         CALL ACTUAL_MONTHLY_INCOME_TAX_ITEMS(R_YR,R_CLASS,|
8574 |     +                                        R_STATE_INCOME_TAX,|
8575 |     +                                        STATE_TAX_CODE)|
8576 |C|
8577 |C FEDERAL INCOME TAXES|
8578 |C|
8579 |         DO MO = 1, 12|
8580 |            R_FEDERAL_SEC29_CREDITS(MO) = 0.|
8581 |            R_FEDERAL_GENERAL_CREDITS(MO) = 0.|
8582 |            R_FEDERAL_AMT_CREDITS_USED(MO) = 0.|
8583 |            R_FED_AMT_CREDITS_GENERATED(MO) = 0.|
8584 |C|
8585 |            R_FED_TAXABLE_INCOME_B4_NOLS(MO) =|
8586 |     +                                   R_TAXABLE_INCOME_B4_DEDUCTS(MO)|
8587 |     +                                   + R_FEDERAL_M1_ADDITIONS(MO)|
8588 |     +                                   - R_FEDERAL_M1_DEDUCTIONS(MO)|
8589 |     +                                   - R_STATE_INCOME_TAX(MO)|
8590 |            R_FED_TAXABLE_INCOME_B4_NOLS(0) =|
8591 |     +                                R_FED_TAXABLE_INCOME_B4_NOLS(0)|
8592 |     +                                + R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8593 |            IF(GET_FED_TAX_BENEFITS_NOW) THEN|
8594 |               R_FEDERAL_NOLS_GENERATED(MO) = 0.|
8595 |               R_FEDERAL_TAXABLE_INCOME(MO) =|
8596 |     +                                  R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8597 |     +                                  - AVAILABLE_FEDERAL_NOLS|
8598 |               R_FEDERAL_NOLS_USED(MO) = AVAILABLE_FEDERAL_NOLS|
8599 |               AVAILABLE_FEDERAL_NOLS = 0.|
8600 |            ELSEIF(R_FED_TAXABLE_INCOME_B4_NOLS(MO) <= 0.) THEN|
8601 |               IF(R_CLASS_TYPE == SBU .OR.|
8602 |     +                             R_CLASS_TYPE == REGULATED_GROUP) THEN|
8603 |                  R_FEDERAL_TAXABLE_INCOME(MO) =|
8604 |     +                                  R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8605 |                  R_FEDERAL_NOLS_GENERATED(MO) = 0.|
8606 |               ELSE|
8607 |                  R_FEDERAL_TAXABLE_INCOME(MO) = 0.|
8608 |C    +                                  R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8609 |                  R_FEDERAL_NOLS_GENERATED(MO) =|
8610 |     +                             ABS(R_FED_TAXABLE_INCOME_B4_NOLS(MO))|
8611 |               ENDIF|
8612 |               R_FEDERAL_NOLS_USED(MO) = 0.|
8613 ||
8614 |               AVAILABLE_FEDERAL_NOLS = AVAILABLE_FEDERAL_NOLS|
8615 |     +                                  + R_FEDERAL_NOLS_GENERATED(MO)|
8616 |            ELSE|
8617 |               R_FEDERAL_NOLS_GENERATED(MO) = 0.|
8618 |               IF(R_FED_TAXABLE_INCOME_B4_NOLS(MO) >=|
8619 |     +                                      AVAILABLE_FEDERAL_NOLS) THEN|
8620 |                  R_FEDERAL_TAXABLE_INCOME(MO) =|
8621 |     +                                  R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8622 |     +                                  - AVAILABLE_FEDERAL_NOLS|
8623 |                  R_FEDERAL_NOLS_USED(MO) = AVAILABLE_FEDERAL_NOLS|
8624 |                  AVAILABLE_FEDERAL_NOLS = 0.|
8625 |               ELSE|
8626 |                  R_FEDERAL_TAXABLE_INCOME(MO) = 0.|
8627 |                  AVAILABLE_FEDERAL_NOLS = AVAILABLE_FEDERAL_NOLS|
8628 |     +                                - R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8629 |                  R_FEDERAL_NOLS_USED(MO) =|
8630 |     +                                  R_FED_TAXABLE_INCOME_B4_NOLS(MO)|
8631 |               ENDIF|
8632 |            ENDIF|
8633 |C|
8634 |C BALANCE NOLS GENERTED DURING THE YEAR WHICH WOULD OFFSET TAXABLE INCOME|
8635 |C THAT OCCURRED BEFORE THE NOL WAS GENERATED.|
8636 |C|
8637 |            IF(MO == 12 .AND. (R_FEDERAL_TAXABLE_INCOME(0)|
8638 |     +                         + R_FEDERAL_TAXABLE_INCOME(MO)) >|
8639 |     +                                 FED_INCOME_AFTER_NOLS_CHECK) THEN|
