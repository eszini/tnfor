9600 |     +                                      THIS_IS_A_PAY_MONTH = .TRUE.    |
9601 |            IF(CURRENT_MO == ISSUE_MO-3 .OR. |
9602 |     +            CURRENT_MO == ISSUE_MO-6 .OR. |
9603 |     +               CURRENT_MO == ISSUE_MO-9)|
9604 |     +                                      THIS_IS_A_PAY_MONTH = .TRUE.    |
9605 |         ELSEIF(PAID_WHEN == 'S') THEN      |
