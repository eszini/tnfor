8555 |                  R_STATE_BTL_INCOME_TAX(MO) = 0.|
8556 |                  R_STATE_BTL_MISC_DEDUCTIONS(MO) = 0.|
8557 |                  R_BTL_MISC_DEDUCTIONS(MO) = 0.|
8558 |               ENDIF|
8559 |               R_STATE_DEF_TAX_DR_NOLS(MO) = R_STATE_TAX_RATE(MO) * |
8560 |     +                                    (R_STATE_NOLS_USED(MO)|
8561 |     +                                     - R_STATE_NOLS_GENERATED(MO))|
8562 |               R_STATE_DEF_TAX_DR_NOLS(0) = R_STATE_DEF_TAX_DR_NOLS(0)|
8563 |     +                                   + R_STATE_DEF_TAX_DR_NOLS(MO)|
8564 |               R_STATE_NOLS_USED(0) = R_STATE_NOLS_USED(0)|
8565 |     +                             + R_STATE_NOLS_USED(MO)|
