8641 |     +                                  + R_FEDERAL_TAXABLE_INCOME(MO)|
8642 |     +                                  - FED_INCOME_AFTER_NOLS_CHECK|
8643 |               R_FEDERAL_NOLS_USED(MO) = R_FEDERAL_NOLS_USED(MO)|
8644 |     +                                 + ADDITIONAL_NOLS_NEEDED|
8645 |               R_FEDERAL_TAXABLE_INCOME(MO) =|
8646 |     +                                      R_FEDERAL_TAXABLE_INCOME(MO)|
8647 |     +                                      - ADDITIONAL_NOLS_NEEDED|
8648 |            ENDIF|
8649 |            R_FED_INCOME_TAXES_B4_CREDITS(MO)=R_FEDERAL_TAX_RATE(MO)*|
8650 |     +                                      R_FEDERAL_TAXABLE_INCOME(MO)     |
8651 ||
8652 |            R_FEDERAL_INCOME_TAXES(MO) =|
8653 |     +                                 R_FED_INCOME_TAXES_B4_CREDITS(MO)|
8654 ||
8655 |            IF(R_CLASS_TYPE == CONSOLIDATED .AND.|
8656 |     +                AVAILABLE_SEC29_CREDITS > 0. .AND.|
8657 |     +                             R_FEDERAL_INCOME_TAXES(MO) > 0.) THEN|
8658 |               IF(AVAILABLE_SEC29_CREDITS >|
8659 |     +                                  R_FEDERAL_INCOME_TAXES(MO)) THEN|
8660 |                  R_FEDERAL_SEC29_CREDITS(MO) =|
8661 |     +                                        R_FEDERAL_INCOME_TAXES(MO)|
8662 |                  AVAILABLE_SEC29_CREDITS = AVAILABLE_SEC29_CREDITS|
8663 |     +                                      - R_FEDERAL_INCOME_TAXES(MO)|
8664 |                  R_FEDERAL_INCOME_TAXES(MO) = 0.|
8665 |               ELSE|
8666 |                  R_FEDERAL_SEC29_CREDITS(MO) = AVAILABLE_SEC29_CREDITS|
8667 |                  R_FEDERAL_INCOME_TAXES(MO) =|
8668 |     +                                 MAX(0.,R_FEDERAL_INCOME_TAXES(MO)|
8669 |     +                                        - AVAILABLE_SEC29_CREDITS)|
8670 |                  AVAILABLE_SEC29_CREDITS = 0.|
8671 |               ENDIF|
8672 |            ELSEIF(AVAILABLE_SEC29_CREDITS > 0.) THEN ! always use 29 credits|
8673 |               R_FEDERAL_SEC29_CREDITS(MO) = AVAILABLE_SEC29_CREDITS|
8674 |               R_FEDERAL_INCOME_TAXES(MO) = R_FEDERAL_INCOME_TAXES(MO)|
8675 |     +                                      - AVAILABLE_SEC29_CREDITS|
8676 |               AVAILABLE_SEC29_CREDITS = 0.|
8677 |            ENDIF|
8678 |            IF(AVAILABLE_FED_GENERAL_CREDITS > 0.) THEN|
8679 |               IF(GET_FED_TAX_BENEFITS_NOW) THEN|
8680 |                  R_FEDERAL_GENERAL_CREDITS(MO) =|
8681 |     +                                     AVAILABLE_FED_GENERAL_CREDITS|
8682 |                  R_FEDERAL_INCOME_TAXES(MO) =|
8683 |     +                                   R_FEDERAL_INCOME_TAXES(MO)|
8684 |     +                                   - AVAILABLE_FED_GENERAL_CREDITS|
8685 |                  AVAILABLE_FED_GENERAL_CREDITS = 0.|
8686 |               ELSEIF(R_FEDERAL_INCOME_TAXES(MO) > 0.) THEN|
8687 |                  IF(AVAILABLE_FED_GENERAL_CREDITS >|
8688 |     +                                  R_FEDERAL_INCOME_TAXES(MO)) THEN|
8689 |                     R_FEDERAL_GENERAL_CREDITS(MO) =|
8690 |     +                                        R_FEDERAL_INCOME_TAXES(MO)|
8691 |                     AVAILABLE_FED_GENERAL_CREDITS =|
8692 |     +                                     AVAILABLE_FED_GENERAL_CREDITS|
8693 |     +                                     - R_FEDERAL_INCOME_TAXES(MO)|
8694 |                     R_FEDERAL_INCOME_TAXES(MO) = 0.|
8695 |                  ELSE|
8696 |                     R_FEDERAL_GENERAL_CREDITS(MO) =|
8697 |     +                                     AVAILABLE_FED_GENERAL_CREDITS|
8698 |                     R_FEDERAL_INCOME_TAXES(MO) =|
8699 |     +                           MAX(0.,R_FEDERAL_INCOME_TAXES(MO)|
8700 |     +                                  - AVAILABLE_FED_GENERAL_CREDITS)|
8701 |                     AVAILABLE_FED_GENERAL_CREDITS = 0.|
8702 |                  ENDIF|
8703 |               ENDIF|
8704 |            ENDIF|
8705 |C|
8706 |            R_FEDERAL_INCOME_TAXES(MO) = R_FEDERAL_INCOME_TAXES(MO)|
8707 |     +                             + R_FEDERAL_INCOME_TAX_ADJUSTMENT(MO)|
8708 |            R_FEDERAL_TAXABLE_INCOME(0) = R_FEDERAL_TAXABLE_INCOME(0)|
8709 |     +                                    + R_FEDERAL_TAXABLE_INCOME(MO)|
8710 |            R_FED_INCOME_TAXES_B4_CREDITS(0) =|
8711 |     +                               R_FED_INCOME_TAXES_B4_CREDITS(0)|
8712 |     +                               + R_FED_INCOME_TAXES_B4_CREDITS(MO)|
8713 |C|
8714 |C CALCULATE BTL NET TAXABLE INCOME|
8715 |C|
8716 |            |
