9594 |            THIS_IS_A_PAY_MONTH = .TRUE. |
9595 |         ELSEIF(PAID_WHEN == 'Q' .OR. PAID_WHEN == 'C') THEN|
9596 |            IF(CURRENT_MO == ISSUE_MO .OR.      |
9597 |     +             CURRENT_MO == ISSUE_MO+3 .OR. |
