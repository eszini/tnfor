7026 |     +                      .OR. RETAIN_POST_RETIREMENT_EARNINGS()) THEN   ! ADD A RETAIN EARNINGS SWITCH HERE|
7027 |                  POST_RETIREMENT_MEDICAL_FUND_BAL =|
7028 |     +                       POST_RETIREMENT_MEDICAL_FUND_BAL|
7029 |     +                       + RETIREMENT_MEDICAL_FUND_RETURN(MO)|
7030 |               ENDIF|
7031 |C|
7032 |C NUC DECOMISSIONING FUND RETURN|
7033 |C|
7034 |               MONTHLY_NUC_DECOM_FUND_RETURN(MO) = |
7035 |     +                  MONTHLY_NUC_DECOM_RATE(MO) *|
7036 |     +                        (MONTHLY_NUC_DECOM_BALANCE(MO-1)|
7037 |     +                          + MONTHLY_NUC_DECOM_CASH_VALUES(MO)/2.)|
7038 |               MONTHLY_OCI_NUC_DECOM_FUND_RETURN(MO) =|
7039 |     +                  OCI_MONTHLY_NUC_DECOM_RATE(MO) *|
7040 |     +                        (MONTHLY_NUC_DECOM_BALANCE(MO-1)|
7041 |     +                          + MONTHLY_NUC_DECOM_CASH_VALUES(MO)/2.)|
7042 |C|
7043 |C THE TIMING OF THE TAX PAYMENT HAS TO BE RECONIZED IN THE EARNINGS|
7044 |C CALCULATION.  THE ASSUMPTION HERE IS THAT IT IS PAID MONTHLY|
7045 |C|
7046 |               MONTHLY_NUC_DECOM_FUND_NET_OF_TAX_RETURN(MO) =|
7047 |     +               (MONTHLY_NUC_DECOM_FUND_RETURN(MO)|
7048 |     +                + MONTHLY_OCI_NUC_DECOM_FUND_RETURN(MO)) *|
7049 |     +                     (1.-FEDERAL_EPA_92_TAX_RATE) *|
7050 |     +                                  (1.- MONTHLY_STATE_TAX_RATE(MO))|
7051 |     +               + MONTHLY_NUC_DECOM_EARNINGS_ADJ(MO)|
7052 |               MONTHLY_NUC_DECOM_BALANCE(MO) = |
7053 |     +                    MONTHLY_NUC_DECOM_BALANCE(MO-1)|
7054 |     +                    + MONTHLY_NUC_DECOM_CASH_VALUES(MO)|
7055 |     +                    + MONTHLY_NUC_DECOM_FUND_NET_OF_TAX_RETURN(MO)|
7056 |            ENDDO|
7057 |            MONTHLY_NUC_DECOM_FUND_RETURN(0) = |
7058 |     +                            SUM(MONTHLY_NUC_DECOM_FUND_RETURN(1:))|
7059 |            MONTHLY_OCI_NUC_DECOM_FUND_RETURN(0) =|
7060 |     +                        SUM(MONTHLY_OCI_NUC_DECOM_FUND_RETURN(1:))|
7061 |            MONTHLY_NUC_DECOM_FUND_NET_OF_TAX_RETURN(0) = |
7062 |     +                 SUM(MONTHLY_NUC_DECOM_FUND_NET_OF_TAX_RETURN(1:))|
7063 |            RETIREMENT_MEDICAL_FUND_RETURN(0) =|
7064 |     +                           SUM(RETIREMENT_MEDICAL_FUND_RETURN(1:))|
7065 |            OCI_RETIREMENT_MEDICAL_FUND_RETURN(0) =|
7066 |     +                       SUM(OCI_RETIREMENT_MEDICAL_FUND_RETURN(1:))|
7067 |C|
7068 |            R_MONTHLY_NUC_DECOM_FUND_RETURN =|
7069 |     +                                  MONTHLY_NUC_DECOM_FUND_RETURN(0)|
7070 |            R_OCI_NUCL_FUND_RETURN =|
7071 |     +                              MONTHLY_OCI_NUC_DECOM_FUND_RETURN(0)|
7072 |            R_MONTHLY_NUC_DECOM_FUND_NET_OF_TAX_RETURN = |
7073 |     +                       MONTHLY_NUC_DECOM_FUND_NET_OF_TAX_RETURN(0) |
7074 |            R_RETIREMENT_MEDICAL_FUND_RETURN =|
7075 |     +                                 RETIREMENT_MEDICAL_FUND_RETURN(0)|
7076 |            R_OCI_RETIREMENT_MEDICAL_FUND_RETURN =|
7077 |     +                             OCI_RETIREMENT_MEDICAL_FUND_RETURN(0)|
7078 |      RETURN|
