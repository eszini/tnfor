6986 |            FEDERAL_EPA_92_TAX_RATE = .20|
6987 |            IF(SALT_RIVER_PROJECT()) FEDERAL_EPA_92_TAX_RATE = 0.|
6988 |c            MONTHLY_NUC_DECOM_RATE = MONTHLY_NUC_DECOM_RATE/100.|
6989 |C|
6990 |C RETIREMENT FUND RETURN|
6991 |C|
6992 |            CALL RETURN_MONTHLY_RETIREMENT_CASH_ADDENDUMS(CLASS_ID,R_YR,|
6993 |     +                            MONTHLY_POST_RETIREMENT_CASH_PAYMENTS,|
6994 |     +                            MONTHLY_RETIREE_MEDICAL_CASH_PAYMENTS,|
6995 |     +                            MONTHLY_CASH_TO_POST_RETIREMENT,|
6996 |     +                            MONTHLY_RETIREMENT_FUND_EARNINGS_ADJ)|
6997 |            POST_RETIREMENT_MEDICAL_FUND_BAL =|
6998 |     +                                      BOY_POST_RETIRE_MEDICAL_FUND|
6999 |C|
7000 |            DO MO = 1, 12 |
7001 |               MONTHLY_STATE_TAX_RATE(MO) =  STATE_TAX_RATE|
7002 |C|
7003 |C MONTHLY RETIREMENT FUND RETURN|
7004 |C|
7005 |               RETIREMENT_MEDICAL_FUND_RETURN(MO) =|
7006 |     +            MONTHLY_RETIREMENT_FUND_RATE(MO) *|
7007 |     +              (POST_RETIREMENT_MEDICAL_FUND_BAL|
7008 |     +               + (MONTHLY_POST_RETIREMENT_CASH_PAYMENTS(MO)|
7009 |     +                  + MONTHLY_CASH_TO_POST_RETIREMENT(MO)|
7010 |     +                  - MONTHLY_RETIREE_MEDICAL_CASH_PAYMENTS(MO))/2.)|
7011 |     +            + MONTHLY_RETIREMENT_FUND_EARNINGS_ADJ(MO)|
7012 |               OCI_RETIREMENT_MEDICAL_FUND_RETURN(MO) =|
7013 |     +            OCI_MONTHLY_RETIREMENT_FUND_RATE(MO) *|
7014 |     +              (POST_RETIREMENT_MEDICAL_FUND_BAL|
7015 |     +               + (MONTHLY_POST_RETIREMENT_CASH_PAYMENTS(MO)|
7016 |     +                  + MONTHLY_CASH_TO_POST_RETIREMENT(MO)|
7017 |     +                  - MONTHLY_RETIREE_MEDICAL_CASH_PAYMENTS(MO))/2.)|
7018 |C     +            + MONTHLY_RETIREMENT_FUND_EARNINGS_ADJ(MO)|
7019 |               POST_RETIREMENT_MEDICAL_FUND_BAL =|
7020 |     +                       POST_RETIREMENT_MEDICAL_FUND_BAL|
7021 |     +                       + MONTHLY_POST_RETIREMENT_CASH_PAYMENTS(MO)|
7022 |     +                       + MONTHLY_CASH_TO_POST_RETIREMENT(MO)|
7023 |     +                       - MONTHLY_RETIREE_MEDICAL_CASH_PAYMENTS(MO)|
7024 |     +                       + OCI_RETIREMENT_MEDICAL_FUND_RETURN(MO)|
