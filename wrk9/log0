1795 |!***********************************************************************|
1796 |      subroutine SquareUpPattern(x,xMin,xMax,y,yMin,yMax,ySum,nCases)|
1797 |!***********************************************************************|
1798 |!     for feasibility, we require yMin<(ySum/nCases)<yMax|
1799 |      logical*1 L1_FALSE/.false./|
1800 |      integer*2 nCases,iCase,jCase,pCase,nxUnique,nyAtMax,|
1801 |     +  jIntermediate,iIntermediate,OrgOrder(:)|
1802 |      real*8 x(*),y(*),yMin,yMax,ySum,xMin,xMax,ThisySum|
1803 |      allocatable OrgOrder|
1804 |!|
1805 |! END DECLARATIONS|
1806 |!|
1807 |!     Move the nearest intermediate values to either extreme to make|
1808 |!       sum(yi,over i on [1,nCases])=ySum, or equivalently|
1809 |!       sum(yi-yMin,over i on [1,nCases])=ySum-nCases*yMin|
1810 |!     subject (by construction) to|
1811 |!       xMin=>yMin and|
1812 |!       xMax=>yMax|
1813 |!     and where the sequence in array x may be non-monotonic (even cyclic)|
1814 |      if((xMax<=xMin).or.(yMax<=yMin)) return ! no transformation is possible|
1815 |      if(allocated(OrgOrder)) deallocate(OrgOrder)|
1816 |      allocate(OrgOrder(nCases))|
1817 |      do iCase=1,nCases|
1818 |        OrgOrder(iCase)=iCase ! before sorting|
1819 |      end do|
1820 |      call Indexed_SortR8_Ascending(x,OrgOrder,nCases,L1_FALSE)|
1821 |      nyAtMax=(ySum-yMin*dble(nCases))/(yMax-yMin) ! truncated to an integer|
1822 |      jIntermediate=nyAtMax+1 ! only y at this rank will not be at yMin or yMax|
1823 |      iIntermediate=OrgOrder(jIntermediate)|
1824 |      nxUnique=1|
1825 |      pCase=OrgOrder(1)|
1826 |      y(pCase)=yMax|
1827 |      do jCase=2,nCases ! count distinct values|
1828 |        iCase=OrgOrder(jCase)|
1829 |        if(x(iCase).ne.x(pCase)) nxUnique=nxUnique+1|
1830 |        if(jCase<=nyAtMax) then|
1831 |          y(iCase)=yMax|
1832 |        else|
1833 |          y(iCase)=yMin|
1834 |        end if|
1835 |!       write(4,'(3i4,2f12.3)') jCase,iCase,nxUnique,x(iCase),y(iCase)|
1836 |        pCase=iCase|
1837 |      end do|
1838 |      deallocate(OrgOrder)|
1839 |      if(nxUnique<=2) then|
1840 |!     ! use exponential transformation of interpolates|
1841 |        call MonthNonlinearlyMap(x,xMin,xMax,y,yMin,yMax,ySum,nCases)|
1842 |        return|
1843 |      end if|
1844 |      ThisySum=yMin*dble(nCases)+(yMax-yMin)*dble(nyAtMax)|
1845 |      y(iIntermediate)=y(iIntermediate)-(ThisySum-ySum)|
1846 |!     write(4,'(2i4,3f10.3,a)') jIntermediate,iIntermediate,|
1847 |!    +  y(iIntermediate),ySum,ThisySum,' penultimate ySum'|
1848 |      end ! subroutine SquareUpPattern|
