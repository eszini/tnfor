1652 |     +                         LAMDA,|
1653 |     +                         BLKNO,|
1654 |     +                         INHEAT,|
1655 |     +                         MWBLOK,|
1656 |     +                         UNIT,|
1657 |     +                         SAVE_HEATRATE,|
1658 |     +                         SHADOW_DISPATCH_ADDER)|
1659 |!***********************************************************************|
1660 |!|
1661 |      USE IREC_ENDPOINT_CONTROL|
1662 |      use grx_planning_routines|
1663 ||
1664 |      INTEGER (KIND=2) :: NBLOK,L,M,I,N,ITEMP|
1665 |      INTEGER (KIND=2) :: LAMDA(NBLOK),BLKNO(NBLOK),UNIT(NBLOK)|
1666 |      REAL (KIND=4) :: SAVE_HEATRATE(NBLOK),|
1667 |     +                 SHADOW_DISPATCH_ADDER(NBLOK),|
1668 |     +                 MWBLOK(NBLOK),INHEAT(NBLOK),RTEMP|
1669 |      LOGICAL (KIND=4) :: REASON1,REASON2,REASON3,REASON4,REASON5|
1670 |!|
1671 |!=======================================================================|
1672 |!     THIS SECTION OF THE PROGRAM CALCULATES THE LOADING ORDER OF|
1673 |!       THE DISPATCHING BLOCKS.  THIS SECTION IS PATTERNED AFTER THE|
1674 |!     SORT IN THE CREORD SUBROUTINE IN PCS|
1675 |!=======================================================================|
1676 |!|
1677 |!|
1678 |! TO CHANGE THE PROMOD PROBLEM CAUSED BY INCREMENTAL HEAT RATES GOING|
1679 |! LOWER (THE FIT TO I/O DATA PRODUCES NEGATIVE COEFFICIENTS WHICH LEAD TO|
1680 |! DECLINING INCREMENTAIL HEAT RATES), THE UNITS SHOULD BE SHORTED FIRST BY|
1681 |! BLOCK NUMBER THEN BY INCREMENT COST.|
1682 |! I DON'T THINK THIS SHOULD BE DONE.  10/4/88|
1683 |! AFTER SEEING COMMONWEALTH EDISON'S DISPATCHING ORDER I CHANGED MY MIND|
1684 |! AND IMPLEMENTE A PRE SORT ON BLOCK NUMBER|
1685 |!|
1686 |         L = NBLOK - 1|
1687 |         IF(L >= 1) THEN|
1688 |            DO I=1,L|
1689 |               M=I|
1690 |               N=I+1|
1691 |   20          REASON4 = .FALSE.|
1692 ||
1693 |               IF(M > 0) THEN|
1694 |!|
1695 |! UNIT TO BE FLIPPED IS A MUST RUN|
1696 |!|
1697 |                  REASON1 = BLKNO(M) /= 0 .AND. BLKNO(N) == 0 .AND.|
1698 |     +                     LAMDA(M) /= 32000 .AND. LAMDA(N) /= 32000|
1699 |!|
1700 |! BOTH UNITS ARE MUST RUNS AND THE LAMDA IS LOWER|
1701 |!|
1702 |                  REASON2 = BLKNO(M) == 0 .AND. BLKNO(N) == 0 .AND.|
1703 |     +                                               LAMDA(M) > LAMDA(N)|
1704 |!|
1705 |! DON'T FLIP BLOCK 1 AND BLOCK 2 OF THE SAME UNIT|
1706 |!|
1707 |                  REASON3 = BLKNO(M) /= 0 .AND. BLKNO(N) /= 0 .AND.|
1708 |     +                      LAMDA(M) > LAMDA(N) .AND. UNIT(M) /= UNIT(N)|
1709 |!|
1710 |! THE PROMOD REASON FOR FLIPPING A DECREASING INCREMENTAL HEAT RATE|
1711 |! CHECK TO SEE IF BLOCK 2  HAS STOPPED BECAUSE IT HIT ITS BLOCK 1|
1712 |!|
1713 |                  IF(M > 1) REASON4 = LAMDA(N) < LAMDA(M-1) .AND.|
1714 |     +                                              UNIT(M) == UNIT(M-1)|
1715 |!|
1716 |! REASON 5 IS MOVE ALL UNITS WITH LAMDAS GE 32000 TO THE BOTTOM OF THE|
1717 |! STACK|
1718 |!|
1719 |                  REASON5 = LAMDA(M) > LAMDA(N) .AND. LAMDA(M) > 31999|
1720 |!|
1721 |                  IF(REASON1 .OR. REASON2 .OR. REASON3 .OR.|
1722 |     +                                        REASON4 .OR. REASON5) THEN|
1723 |!        THEN INTERCHANGES THE ARRAY POSITIONS|
1724 |                     ITEMP=LAMDA(M)|
1725 |                     LAMDA(M)=LAMDA(N)|
1726 |                     LAMDA(N)=ITEMP|
1727 |                     RTEMP=MWBLOK(M)|
1728 |                     MWBLOK(M)=MWBLOK(N)|
1729 |                     MWBLOK(N)=RTEMP|
1730 |                     ITEMP=UNIT(M)|
1731 |                     UNIT(M)=UNIT(N)|
1732 |                     UNIT(N)=ITEMP|
1733 |!|
1734 |                     RTEMP=INHEAT(M)|
1735 |                     INHEAT(M)=INHEAT(N)|
1736 |                     INHEAT(N)=RTEMP|
1737 |!|
1738 |                     RTEMP=SAVE_HEATRATE(M)|
1739 |                     SAVE_HEATRATE(M)=SAVE_HEATRATE(N)|
1740 |                     SAVE_HEATRATE(N)=RTEMP|
1741 |!|
1742 |                     ITEMP = BLKNO(M)|
1743 |                     BLKNO(M) = BLKNO(N)|
1744 |                     BLKNO(N) = ITEMP|
1745 |                     RTEMP = SHADOW_DISPATCH_ADDER(M)|
1746 |                     SHADOW_DISPATCH_ADDER(M) = SHADOW_DISPATCH_ADDER(N)|
1747 |                     SHADOW_DISPATCH_ADDER(N) = RTEMP|
1748 |                     N = M|
1749 |                     M = M - 1|
1750 |                     GOTO 20|
1751 |                  ENDIF|
1752 |               ENDIF|
1753 |            ENDDO|
