6352 |     +                     WEEKLY_REFERENCE_BASE) <|
6353 |     +                     max(Tolerance,|
6354 |     +                            WEEKLY_REFERENCE_BASE*Tolerance)) then|
6355 |                     nHrAtMin = nHrAtMin+1|
6356 |                  endif|
6357 |               ENDIF|
6358 |               IF(WEEKLY_REFERENCE_LOAD(J) < WEEKLY_NONZERO_BASE .AND.|
