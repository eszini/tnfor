1851 |      subroutine Indexed_SortR8_Ascending(a,Ofs,nItems,Ascending)|
1852 |!***********************************************************************|
1853 |!     sorts nItems items into Ascending order(Ofs array); from EvaluInc.fpp|
1854 |      integer*2 nItems,i,j,k,Gap,Ofs(*),Hold|
1855 |      logical*1 Ascending ! .false. => Descending order|
1856 |      real*8 a(*) ! the only difference from Indexed_Sort_Ascending|
1857 |!|
1858 |      Gap=nItems/2|
1859 |      do while(Gap>0)|
1860 |        do i=Gap+1,nItems|
1861 |          j=i-Gap|
1862 |          do while(j>0)|
1863 |            k=j+Gap|
1864 |            if((      Ascending .and.(a(Ofs(j))<=a(Ofs(k)))).or.|
1865 |     +         ((.not.Ascending).and.(a(Ofs(j))>=a(Ofs(k))))) then|
1866 |              j=0 ! break the while loop (assign j=-1 for 0-based arrays)|
1867 |            else ! interchange the index values|
1868 |!             write(*,'(a,2i3,2f7.2)') ' interchanging',|
1869 |!    +          Ofs(j),Ofs(k),a(Ofs(j)),a(Ofs(k))|
1870 |              Hold=Ofs(j)|
1871 |              Ofs(j)=Ofs(k)|
1872 |              Ofs(k)=Hold|
1873 |            end if|
1874 |            j=j-Gap|
1875 |          end do|
1876 |        end do|
1877 |        Gap=Gap/2|
1878 |      end do|
1879 |      end ! subroutine Indexed_SortR8_Ascending|
