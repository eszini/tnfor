7561 |      real*4|
7562 |     +   Nearly1/0.999999/, ! relative threshold for completion|
7563 |     +   R_PUMPING_CAP_MW,|
7564 |     +   R_MIN_GEN_CAP_MW,|
7565 |     +   R_MAX_GEN_CAP_MW,|
7566 |     +   R_AVG_GEN_CAP_MW,|
7567 |     +   R_PUMPING_STORAGE_EFFICIENCY,|
7568 |     +   R_WEEKLY_LOAD_ORG(*), ! 24x7 hourly detail|
