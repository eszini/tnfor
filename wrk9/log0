7552 |!***********************************************************************|
7553 |!|
7554 |      logical*1 GPSameHour,GPShoulder,TgtAttained,L1_FALSE/.false./|
7555 |      integer*2|
7556 |     +   iHr,iGP,PrtDetail/0/, ! 2 to get LDC before and after PS mods|
7557 |     +   nFullCapHr,|
7558 |     +   DescOrder(168),|
7559 |     +   GPHour(0:1),|
