7929 |     +               DEPTH_LAMBDA,|
7930 |     +               DEPTH_MONTH_PRICE,|
7931 |     +               DEPTH_MONTH_LAMBDA,|
7932 |     +               PRODUCT_HOURS|
7933 |!|
7934 |! R_UNIT_PRICE = MARGINAL COST OF THE CURRENT UNIT BLOCK|
7935 |! R_UNIT_CAPACITY = CAPACITY OF THE CURRENT UNIT BLOCK|
7936 |! R_QUANTITY = GENERATION USED - NATIVE DEMAND|
7937 |!|
7938 |! STRATEGY: THE INCOMING R_UNIT IS MOVING UP THE DISPATCH ORDER.|
7939 |!           INSIDE THIS ROUTINE WE KNOW THE MARGINAL COST BETWEEN|
7940 |!           THE LOWER AND UPPER DEPTH OF MARKET BOUNDS.|
7941 |!           FOR EACH UNIT, WE TEST ITS POSITION WITHIN THE SYSTEM|
7942 |!           BUY/SELL.  WE THEN SEE IF ITS POSITION ACROSS THE|
7943 |!           DEPTH OF MARKET CURVE. IF SO, WE HAVE A DEPTH OF MARKET|
7944 |!           SOLUTION.  IF NOT, WE KEEP ON LOOKING UNTIL WE ARE AT|
7945 |!           THE TOP END OF THE DEPTH OF MARKET RANGE.|
7946 |!|
7947 |!|
7948 |! END OF DATA DECLARATIONS|
7949 |!|
7950 |         GET_DEPTH_OF_MARKET_QUANTITY = .FALSE.|
7951 |! RESET SOLUTION.|
7952 |!         LOCAL_DEPTH_QUANTITY = 0.|
7953 |!         LOCAL_DEPTH_PRICE = 0.|
7954 |!|
7955 |!|
7956 |!         DEMO_QUANTITY(1) = R_QUANTITY - 500.|
7957 |!         DEMO_QUANTITY(2) = R_QUANTITY - 250.|
7958 |!         DEMO_QUANTITY(3) = R_QUANTITY + 5|
7959 |!         DEMO_QUANTITY(4) = R_QUANTITY + 250.|
7960 |!         DEMO_QUANTITY(5) = R_QUANTITY + 500.|
7961 |         DEMO_QUANTITY(1) = - 500.|
7962 |         DEMO_QUANTITY(2) = - 250.|
7963 |         DEMO_QUANTITY(3) =     5.|
7964 |         DEMO_QUANTITY(4) =   250.|
7965 |         DEMO_QUANTITY(5) =   500.|
7966 |!|
7967 |         MAX_INTERVALS = DEPTH_MARKET_INTERVALS|
7968 |!|
7969 |         IF( .NOT. ALLOCATED(DEPTH_PRICE)) RETURN|
7970 |!|
7971 |!|
7972 |! TEST FOR OUTSIDE THE INTERVAL. WOULD I USE THESE IF NEVER FOUND? PROBABLY.|
7973 |!|
7974 |! TO CAPTURE RAMP-UP AND RAMP-DOWN ISSUES|
7975 |         DO INTERVAL = MAX_INTERVALS, 1, -1|
7976 |            IF(DEPTH_QUANTITY(INTERVAL) > R_MAX_DEPTH_MARKET) CYCLE|
7977 |            TOP_INTERVAL = MAX(2,MIN(INTERVAL,MAX_INTERVALS))|
7978 |            EXIT|
7979 |         ENDDO|
7980 |         DO INTERVAL = 1, MAX_INTERVALS|
7981 |            IF(DEPTH_QUANTITY(INTERVAL) < R_MIN_DEPTH_MARKET) CYCLE|
7982 |            BOTTOM_INTERVAL = MIN(INTERVAL,TOP_INTERVAL-1) ! MAX(1,MIN(INTERVAL,MAX_INTERVALS))|
7983 |            EXIT|
7984 |         ENDDO|
7985 |!|
7986 |! DEPTH_QUANTITY(MAX_INTERVALS) : BUY MAX FROM THE MARKET|
7987 |! DEPTH_PRICE(MAX_INTERVALS) :    MAX MARKET PRICE|
7988 |! DEPTH_QUANTITY(1) : SELL MAX TO THE MARKET|
7989 |! DEPTH_PRICE(1):    MIN MARKET PRICE|
7990 |!|
7991 |!BUY CONIDITION|
7992 |!|
7993 |!|
7994 |         TOP_INTERVAL = MAX_INTERVALS|
7995 |         BOTTOM_INTERVAL = 1|
7996 |!|
7997 |         INTERVAL = ZERO_PRICE_INTERVAL|
7998 |!|
7999 |         IF(R_LOCAL_BALANCE + DEPTH_QUANTITY(TOP_INTERVAL) < 0.) THEN|
8000 |!|
8001 |!              INSUFFICIENT NATIVE RESOURCES AVAILABLE TO MEET DEMAND|
8002 |!|
8003 |            LOCAL_DEPTH_QUANTITY = DEPTH_QUANTITY(TOP_INTERVAL)|
8004 |            LOCAL_DEPTH_PRICE =|
8005 |     +                            DEPTH_PRICE(TOP_INTERVAL,R_HOUR,R_DAY)|
8006 |!|
8007 |!|
8008 |!              STOP SEARCH AND BUY THE MAX AT THE MAX PRICE|
8009 |!|
8010 |            GET_DEPTH_OF_MARKET_QUANTITY = .TRUE.|
8011 |         ENDIF|
8012 ||
8013 |!|
8014 |         LOCAL_NET_LOAD = - R_SYSTEM_LOAD - DEPTH_TRANS(R_HOUR,R_DAY)|
8015 |!|
8016 |         DO I = 2 , R_MAX_OUTAGE_BLOCKS|
8017 |!|
8018 |            IF(GET_DEPTH_OF_MARKET_QUANTITY) EXIT|
8019 |!|
8020 |            LOCAL_QUANTITY(1) = R_DISPATCH_MW(I-1) + LOCAL_NET_LOAD|
8021 |            LOCAL_QUANTITY(2) = R_DISPATCH_MW(I) + LOCAL_NET_LOAD|
8022 |!|
8023 |            IF(LOCAL_QUANTITY(1) < 0. .AND. LOCAL_QUANTITY(2) > 0.) THEN|
8024 |               R_MAX_OUTAGE_BLOCKS = R_MAX_OUTAGE_BLOCKS|
8025 |            ENDIF|
8026 |!|
8027 |!|
8028 |            IF(LOCAL_QUANTITY(2) +|
8029 |     +                          DEPTH_QUANTITY(TOP_INTERVAL) < 0.) THEN|
8030 |!|
8031 |! BUY CONDITION|
8032 |!|
8033 |!|
8034 |!              CURRENT DISPATCH LESS NATIVE LOAD (NEED) IS ABOVE|
8035 |!              THE TOP END OF THE BUY RANGE|
8036 |!|
8037 |               LOCAL_DEPTH_QUANTITY = DEPTH_QUANTITY(TOP_INTERVAL)|
8038 |               LOCAL_DEPTH_PRICE =|
8039 |     +                            DEPTH_PRICE(TOP_INTERVAL,R_HOUR,R_DAY)|
8040 |!|
8041 |            ELSEIF(LOCAL_QUANTITY(1) +|
8042 |     +                      DEPTH_QUANTITY(BOTTOM_INTERVAL) > 0. .AND.|
8043 |     +               R_DISPATCH_COST(I) <|
8044 |     +                   DEPTH_PRICE(BOTTOM_INTERVAL,R_HOUR,R_DAY)) THEN|
8045 |!|
8046 |! SELL AND TERMINATE CONDITION|
8047 |! MODIFIED 01/30/03 TO INCLUDE UNIT VS DEPTH PRICE CHECK.|
8048 |!|
8049 |!           CURRENT DISPATCH ABOVE UPPER END OF DEPTH OF MARKET CURVE|
8050 |!|
8051 |               LOCAL_DEPTH_QUANTITY = DEPTH_QUANTITY(BOTTOM_INTERVAL)|
8052 |               LOCAL_DEPTH_PRICE =|
8053 |     +                         DEPTH_PRICE(BOTTOM_INTERVAL,R_HOUR,R_DAY)|
8054 |!|
8055 |!           STOP SEARCH AND SELL THE MAX AT THE MIN PRICE|
8056 |!|
8057 |               GET_DEPTH_OF_MARKET_QUANTITY = .TRUE.|
8058 |!|
8059 |!            ELSEIF(R_DISPATCH_COST(I) <|
8060 |!     +                   DEPTH_PRICE(BOTTOM_INTERVAL,R_HOUR,R_DAY)) THEN|
8061 |!|
8062 |! SELL CONDITION|
8063 |!|
8064 |!               LOCAL_DEPTH_QUANTITY = DEPTH_QUANTITY(BOTTOM_INTERVAL)|
8065 |!               LOCAL_DEPTH_PRICE =|
8066 |!     +                         DEPTH_PRICE(BOTTOM_INTERVAL,R_HOUR,R_DAY)|
8067 |!            ELSEIF(R_DISPATCH_COST(I) >|
8068 |!     +                     DEPTH_PRICE(TOP_INTERVAL,R_HOUR,R_DAY)) THEN|
8069 |!|
8070 |! BUY CONDITION|
8071 |!|
8072 |!               LOCAL_DEPTH_QUANTITY = DEPTH_QUANTITY(TOP_INTERVAL)|
8073 |!               LOCAL_DEPTH_PRICE =|
8074 |!     +                            DEPTH_PRICE(TOP_INTERVAL,R_HOUR,R_DAY)|
8075 |!|
8076 |            ELSE|
8077 |!|
8078 |! MAYBE SELL OR BUY CONDITION|
8079 |!|
8080 |!|
8081 |! FIND UPPER INTERVAL|
8082 |!|
8083 |!|
8084 |!            IF(R_DAY == 1 .AND. R_HOUR == 17)THEN|
8085 |!               R_DAY = R_DAY|
8086 |!            ENDIF|
8087 |!|
8088 |!               LOCAL_DEPTH_QUANTITY =|
