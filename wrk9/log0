8589 |               ENDDO|
8590 |               CLOSE(TRANS_MWH_UNIT)|
8591 |            ENDIF|
8592 |            MONTHLY_DEPTH_OF_MARKET_DB = .TRUE.|
8593 |            CLOSE(DEPTH_MARKET_UNIT)|
8594 |         ENDIF|
