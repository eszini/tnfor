11167 |                  ELSE|
11168 |                     MONTHLY_BURN_COST(TRANS,R_MONTH) =|
11169 |     +                    MONTHLY_BURN_COST(TRANS,R_MONTH) +|
11170 |     +                             HOURLY_PRICE(TRANS) * DERIV_FUEL_USED|
11171 |                  ENDIF|
11172 |!|
11173 |!     +               MONTHLY_AC_REVENUE,|
11174 |!     +               MONTHLY_AC_REVENUE_ENERGY,|
11175 |!     +               MONTHLY_AC_EXPENSE,|
11176 |!     +               MONTHLY_AC_EXPENSE_ENERGY,|
11177 |!     +               MONTHLY_STRIKES,|
11178 |                  REDUCE_HOURLY_FUEL_DERIVATIVES = .TRUE.|
11179 |               ENDIF|
11180 |            ENDIF|
11181 |            I = I + 1|
