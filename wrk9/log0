11138 |                  ELSE ! NOT THE MARGINAL FUEL|
11139 |                     MONTH_TOTAL_FUEL_BURNED(TRANS) =|
11140 |     +                  MONTH_TOTAL_FUEL_BURNED(TRANS) + DERIV_FUEL_USED|
11141 |                  ENDIF|
11142 |!|
11143 |!|
11144 |!|
11145 |                  LOCAL_HEAT = LOCAL_HEAT - DERIV_FUEL_USED*1000.|
11146 |!|
11147 |!|
11148 |                  HOURLY_QUANTITY(TRANS) =|
