7586 |!***********************************************************************|
7587 |!|
7588 |      entry OptimizeWeeksPumpedStorage(|
7589 |     +   R_PUMPING_CAP_MW, ! cannot be inferred from efficiency|
7590 |     +   R_MIN_GEN_CAP_MW, ! due to a RoR component or min-flow reqmt?|
7591 |     +   R_MAX_GEN_CAP_MW,|
7592 |     +   R_AVG_GEN_CAP_MW,|
7593 |     +   R_PUMPING_STORAGE_EFFICIENCY,|
7594 |     +   R_WEEKLY_LOAD_ORG, ! 24x7 detail indexed on [1,168]|
7595 |     +   R_WEEKLY_LOAD_MOD) ! 24x7 detail indexed on [1,168]|
7596 |!***********************************************************************|
7597 |!|
7598 |!     This routine assumes that for the purpose of the optimization,|
7599 |!     market prices and pumping costs are monotonically related to loads.|
7600 |!     Lacking other information on time-of-day operational constraints,|
7601 |!     it assumes that the generation hours and pumping hours can be|
7602 |!     anywhere in the week, i.e., that reservoir capacity is not binding.|
7603 |!     Its only output is the array of loads modified by the PS operation.|
7604 |!     If it is assumed that the PS operation affects the market prices and|
7605 |!     costs by its operation, then the operation can continue in shoulder|
7606 |!     hours at reduced capacity until pumping and generation hours collide.|
7607 |!     AGT 20020823|
7608 |!|
7609 |!     first account for the possibility of non-zero minimum required generation|
7610 |      EnergyRatio=1.0/R_PUMPING_STORAGE_EFFICIENCY ! PmpMWH/GenMWH|
7611 |      CapyMW(0)=R_MAX_GEN_CAP_MW-R_MIN_GEN_CAP_MW|
7612 |      CapyMW(1)=R_PUMPING_CAP_MW|
7613 |!     energy-balance constraint:  PmpMW=EnergyRatio*GenMWH|
7614 |!       CapyMW(1)*HrsUse(1)=EnergyRatio*CapyMW(0)*HrsUse(0)|
7615 |      TimeRatio(0)=CapyMW(1)/(EnergyRatio*CapyMW(0)) ! HrsUse(0)/HrsUse(1)|
7616 |      TimeRatio(1)=EnergyRatio*CapyMW(0)/CapyMW(1)   ! HrsUse(1)/HrsUse(0)|
7617 |      TgtGenMWH=168.0*(R_AVG_GEN_CAP_MW-R_MIN_GEN_CAP_MW)|
7618 |      do iHr=1,168|
7619 |        R_WEEKLY_LOAD_MOD(iHr)=R_WEEKLY_LOAD_ORG(iHr)-R_MIN_GEN_CAP_MW|
7620 |        DescOrder(iHr)=iHr|
7621 |      end do|
7622 |      call Indexed_Sort_Ascending(R_WEEKLY_LOAD_MOD,DescOrder,|
7623 |     +  int2(168),L1_FALSE) ! for descending order|
7624 |!     scan the sorted array to determine the number of full-capacity gen hours|
7625 |      do nFullCapHr=1,168|
7626 |        SumGenMWH=CapyMW(0)*float(nFullCapHr)|
7627 |        ShoulderLoad=R_WEEKLY_LOAD_MOD(DescOrder(nFullCapHr))-CapyMW(0)|
7628 |        do iHr=nFullCapHr+1,168|
7629 |          OriginalLoad=R_WEEKLY_LOAD_MOD(DescOrder(iHr))|
7630 |          if(OriginalLoad<=ShoulderLoad) exit|
7631 |          SumGenMWH=SumGenMWH+amin1(CapyMW(0),OriginalLoad-ShoulderLoad)|
7632 |        end do|
7633 |!        if(PrtDetail>1) write(*,'(2i4,2f6.1,2f8.1)')|
7634 |!     +    nFullCapHr,iHr,OriginalLoad,ShoulderLoad,SumGenMWH,TgtGenMWH|
7635 |        if(iHr==nFullCapHr+1) exit ! no loads lie above the shoulder|
7636 |        if(SumGenMWH>TgtGenMWH) exit|
7637 |      end do|
7638 |      nFullCapHr=nFullCapHr-1|
7639 |!     if(nFullCapHr>nint(168.0*TimeRatio(0)/(TimeRatio(0)+TimeRatio(1))))|
7640 |      if(nFullCapHr>nint(168.0/(1.0+TimeRatio(1)/TimeRatio(0))))|
7641 |     +   nFullCapHr=nint(168.0/(1.0+TimeRatio(1)/TimeRatio(0)))|
7642 |      if(nFullCapHr>0) then|
7643 |        ShoulderLoad=R_WEEKLY_LOAD_MOD(DescOrder(nFullCapHr))-CapyMW(0)|
7644 |      else|
7645 |!     ! in the unlikely case of relatively level load or small PS facility,|
7646 |!     ! find the ShoulderLoad which meets the TgtGenMWH|
7647 |        ShoulderLoad=R_WEEKLY_LOAD_MOD(DescOrder(1))|
7648 |        SumGenMWH=0.0|
7649 |        do iHr=1,168|
7650 |          OriginalLoad=ShoulderLoad|
7651 |          ShoulderLoad=R_WEEKLY_LOAD_MOD(DescOrder(iHr+1))|
7652 |          SumGenMWH=SumGenMWH+(OriginalLoad-ShoulderLoad)*float(iHr)|
7653 |!          if(PrtDetail>1) write(*,'(2i4,2f6.1,2f8.1)')|
7654 |!     +      nFullCapHr,iHr,OriginalLoad,ShoulderLoad,SumGenMWH,TgtGenMWH|
7655 |          if(SumGenMWH>TgtGenMWH) exit|
7656 |        end do|
7657 |!       ShoulderLoad=ShoulderLoad+(OriginalLoad-ShoulderLoad)*|
7658 |!    +    (SumGenMWH-TgtGenMWH)/((OriginalLoad-ShoulderLoad)*float(iHr))|
7659 |        ShoulderLoad=ShoulderLoad+|
7660 |     +    (SumGenMWH-TgtGenMWH)/float(iHr) ! equivalent to above|
7661 |!        if(PrtDetail>1) write(*,'(2i4,2f6.1,2f8.1)')|
7662 |!     +    nFullCapHr,iHr,OriginalLoad,ShoulderLoad,SumGenMWH,TgtGenMWH|
7663 |      end if|
7664 |!     walk in from both ends of the sorted array, accumulating energy until|
7665 |!     the pumping and generation collide (unlikely), the generating capacity|
7666 |!     is exceeded, or the target energy is met|
7667 |      SumGenMWH=0.0|
7668 |      GPRank(0)=1|
7669 |      GPRank(1)=168|
7670 |!     NominalCap=0.0|
7671 |      do iGP=0,1 ! 0 for generation, 1 for pumping|
7672 |        GPHour(iGP)=DescOrder(GPRank(iGP))|
7673 |        GPLoad(iGP)=R_WEEKLY_LOAD_MOD(GPHour(iGP))-|
7674 |     +    CapyMW(iGP)*float(1-2*iGP)|
7675 |        FracHrCurLoad(iGP)=0.0|
7676 |        HrsUse(iGP)=0.0|
7677 |        CeffMW(iGP)=CapyMW(iGP)|
7678 |!       NominalCap=NominalCap+CapyMW(iGP)|
7679 |      end do|
7680 |!     first two checks below are unlikely to be binding in real-life cases:|
7681 |      GPSameHour=(GPRank(0)>=GPRank(1)) ! cannot pump and gen in same hour|
7682 |      GPShoulder=(GPLoad(0)<=GPLoad(1)) ! load difference is too small for full-cap operation|
7683 |      TgtAttained=(SumGenMWH>=TgtGenMWH) ! target generation attained|
7684 |!      if(PrtDetail>1) write(*,'(a)')|
7685 |!     +  ' RkG RkP HrG HrP LoadG LoadP IncrG IncrP FracG FracP'//|
7686 |!     +  ' nHrsG nHrsP  GenMWH v',|
7687 |!     +  ' --- --- --- --- ----- ----- ----- ----- ----- -----'//|
7688 |!     +  ' ----- ----- ------- -'|
7689 |      do|
7690 |!       if(GPSameHour.or.GPShoulder.or.TgtAttained) exit ! reduced-cap operation is not allowed|
7691 |        if(GPSameHour.or.TgtAttained) exit|
7692 |        do iGP=0,1|
7693 |          if(FracHrCurLoad(iGP)>Nearly1) then|
7694 |!         ! incr/decrement rank of current hour of generation/pumping, respectively|
7695 |            GPRank(iGP)=GPRank(iGP)+1-2*iGP ! i.e., decrement for iGP==1|
7696 |            GPHour(iGP)=DescOrder(GPRank(iGP))|
7697 |            GPLoad(iGP)=R_WEEKLY_LOAD_MOD(GPHour(iGP))-|
7698 |     +        CapyMW(iGP)*float(1-2*iGP)|
7699 |            FracHrCurLoad(iGP)=0.0|
7700 |            GPSameHour=(GPRank(0)>=GPRank(1))|
7701 |!           GPShoulder=(GPLoad(0)<=GPLoad(1))|
7702 |          end if|
7703 |!       ! probe an increment during current hour|
7704 |          IncrHrCurLoad(iGP)=amin1(1.0-FracHrCurLoad(iGP),|
7705 |     +             TimeRatio(iGP)*(1.0-FracHrCurLoad(mod(iGP+1,2))))|
7706 |        end do ! this loop must complete before the next is begun|
7707 |        GPShoulder=(GPRank(0)>nFullCapHr)|
7708 |!       if(GPSameHour.or.GPShoulder) exit ! reduced-cap operation is not allowed|
7709 |        if(GPSameHour) exit|
7710 |        if(GPShoulder) then|
7711 |!       ! prorate generation and pump capacities to levelize shoulder loads|
7712 |!         ReducedCap=GPLoad(0)-GPLoad(1)+NominalCap|
7713 |!         CeffMW(0)=CapyMW(0)*ReducedCap/NominalCap|
7714 |!         CeffMW(1)=CapyMW(1)*ReducedCap/NominalCap|
7715 |          CeffMW(0)=amax1(0.001,GPLoad(0)+CapyMW(0)-ShoulderLoad)|
7716 |          CeffMW(1)=CapyMW(1)*CeffMW(0)/CapyMW(0)|
7717 |!     ! else retain use of full nominal capacities|
7718 |        end if|
7719 |        IncrHrCurLoad(0)=amin1(IncrHrCurLoad(0),|
7720 |     +    (TgtGenMWH-SumGenMWH)/CeffMW(0))|
7721 |!     ! IncrHrCurLoad here is the maximum increment in use in current hour|
7722 |        do iGP=0,1|
7723 |          TimeConstraint=|
7724 |     +      IncrHrCurLoad(mod(iGP+1,2))*TimeRatio(iGP)|
7725 |          if(IncrHrCurLoad(iGP)>TimeConstraint)|
7726 |     +       IncrHrCurLoad(iGP)=TimeConstraint|
7727 |          FracHrCurLoad(iGP)=|
7728 |     +    FracHrCurLoad(iGP)+|
7729 |     +    IncrHrCurLoad(iGP) ! at most 1.0|
7730 |          HrsUse(iGP)=|
7731 |     +    HrsUse(iGP)+IncrHrCurLoad(iGP)|
7732 |          R_WEEKLY_LOAD_MOD(GPHour(iGP))=|
7733 |     +    R_WEEKLY_LOAD_MOD(GPHour(iGP))-CeffMW(iGP)*float(1-2*iGP)*|
7734 |     +    IncrHrCurLoad(iGP)|
7735 |        end do ! iGP|
7736 |        SumGenMWH=SumGenMWH+CeffMW(0)*IncrHrCurLoad(0)|
7737 |        TgtAttained=(SumGenMWH>Nearly1*TgtGenMWH)|
7738 |!        if(PrtDetail>1) write(*,'(4i4,2f6.1,4f6.3,2f6.2,f8.1,L2)')|
7739 |!     +    GPRank,GPHour,|
7740 |!     +    R_WEEKLY_LOAD_ORG(GPHour(0)),|
7741 |!     +    R_WEEKLY_LOAD_ORG(GPHour(1)),|
7742 |!     +    IncrHrCurLoad,|
7743 |!     +    FracHrCurLoad,|
7744 |!     +    HrsUse,|
7745 |!     +    SumGenMWH,GPShoulder|
7746 |      end do|
7747 |!      if(PrtDetail>1) then ! output the org/mod LDC for graphing|
7748 |!        do iHr=1,168|
7749 |!          write(*,'(i4,f8.3)') iHr,R_WEEKLY_LOAD_ORG(DescOrder(iHr))|
7750 |!        end do|
7751 |!        do iHr=1,168|
7752 |!          write(*,'(i4,f8.3)') iHr,R_WEEKLY_LOAD_MOD(DescOrder(iHr))|
7753 |!        end do|
7754 |!      end if|
7755 |      return ! entry OptimizeWeeksPumpedStorage|
7756 |!|
7757 |      end ! subroutine OnlyDeclarations|
