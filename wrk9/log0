11104 |     +                                TRANS == MARGINAL_FUEL_DERIV).AND.|
11105 |     +                 TEST_DATE <= END_EP(TRANS) .AND.|
11106 |     +                                TEST_DATE >= BEGIN_EP(TRANS)) THEN|
11107 |               HOURLY_IN_THE_MONEY = .TRUE.|
11108 |!|
11109 |! 072214. TEST.|
11110 |!|
11111 |!            IF(DERIVATIVE_TYPE(TRANS) == 2 .OR.|
11112 |!     +                                 DERIVATIVE_TYPE(TRANS) == 5) THEN|
11113 |!               IF(HOURLY_PRICE(TRANS) > HOURLY_COST(TRANS)) THEN|
11114 |!                  HOURLY_IN_THE_MONEY = .TRUE.|
11115 |!               ENDIF|
11116 |!            ENDIF|
11117 |!|
11118 |               HOURLY_TRANS_HEAT(R_HOUR,TRANS) =|
