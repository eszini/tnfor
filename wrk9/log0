12619 |      SUBROUTINE FIND_PRICE_AND_QUANT(R_HR,|
12620 |     +                                R_MONTH,|
12621 |     +                                R_TEMP_TRANSACTION,|
12622 |     +                                R_TEMP_INTERP_TRANSACTION,|
12623 |     +                                R_TRANSACTION_COMPLETED,|
12624 |     +                                R_BUYER_DB,|
12625 |     +                                R_SELLER_DB,|
12626 |     +                                R_BUYERS_COST,|
12627 |     +                                R_SELLERS_COST,|
12628 |     +                                R_CONVERGENCE_PATH,|
12629 |     +                                R_SELLERS_LOAD,|
12630 |     +                                R_BUYERS_LOAD,|
12631 |     +                                R_SELLER_SCARCITY_COST,|
12632 |     +                                R_BUYER_SCARCITY_COST,|
12633 |     +                                R_SELLER_SCARCITY_MULT,|
12634 |     +                                R_BUYER_SCARCITY_MULT,|
12635 |     +                                R_L_M,|
12636 |     +                                R_TIE_PLUS_MARKET_SCARCITY,|
12637 |     +                                R_TOTAL_DELIVERED_COST,|
12638 |     +                                R_SEARCHES_WITHIN_TRANSACTIONS,|
12639 |     +                                R_TWH,|
12640 |     +                                R_HOURLY_DUMP_USED)|
12641 |      use end_routine, only: end_program, er_message|
12642 |!|
12643 |!***********************************************************************|
12644 |!|
12645 |! TWO EQUATIONS, TWO UNKNOWNS|
12646 ||
12647 |!|
12648 |      LOGICAL*1 SEARCH_SUCCESSFUL,R_TRANSACTION_COMPLETED|
12649 |      INTEGER*2 R_HR,|
12650 |     +          R_MONTH,|
12651 |     +          R_BUYER_DB,|
12652 |     +          R_SELLER_DB,|
12653 |     +          R_L_M,|
12654 |     +          R_TWH|
12655 |      INTEGER*4 R_SEARCHES_WITHIN_TRANSACTIONS,|
12656 |     +          MAX_SEARCHES_WITHIN_TRANS/50/|
12657 ||
12658 ||
12659 |      REAL*4   R_BUYERS_COST,|
12660 |     +         R_SELLERS_COST,|
12661 |     +         R_TEMP_TRANSACTION,|
12662 |     +         R_CONVERGENCE_PATH,|
12663 |     +         R_SELLER_SCARCITY_COST,|
12664 |     +         R_BUYER_SCARCITY_COST,|
12665 |     +         R_SELLER_SCARCITY_MULT,|
12666 |     +         R_BUYER_SCARCITY_MULT,|
12667 |     +         R_TIE_PLUS_MARKET_SCARCITY,|
12668 |     +         R_TOTAL_DELIVERED_COST,|
12669 |     +         R_HOURLY_DUMP_USED|
12670 |      REAL*8   R_TEMP_INTERP_TRANSACTION,|
12671 |     +         DENOM,|
12672 |     +         GET_MARGINAL_COST_AT_MARKET,|
12673 |     +         r8_X_TEMP,|
12674 |     +         r8_Y_TEMP,|
12675 |     +         SELLER_SLOPE,SELLER_INTERCEPT,|
12676 |     +         BUYER_SLOPE,BUYER_INTERCEPT,|
12677 |     +         R_SELLERS_LOAD,R_BUYERS_LOAD,|
12678 |     +         SELLER_PRICE_AT_MAX_TRANS,|
12679 |     +         SELLER_PRICE_AT_MIN_TRANS,|
12680 |     +         BUYER_PRICE_AT_MAX_TRANS,|
12681 |     +         BUYER_PRICE_AT_MIN_TRANS,|
12682 |     +         SELLER_PRICE_AT_TEST_TRANS,|
12683 |     +         BUYER_PRICE_AT_TEST_TRANS,|
12684 |     +         QUANT_AT_MAX_TRANS,|
12685 |     +         QUANT_AT_MIN_TRANS|
12686 |!|
12687 |! END DATA DECLARATIONS|
12688 |!|
12689 |         IF(R_TRANSACTION_COMPLETED) RETURN|
12690 |!|
12691 |         QUANT_AT_MAX_TRANS = R_TEMP_INTERP_TRANSACTION|
12692 |         QUANT_AT_MIN_TRANS = 0.|
12693 |!|
12694 |         R_SEARCHES_WITHIN_TRANSACTIONS = 0D0|
12695 |!|
12696 |         SEARCH_SUCCESSFUL = .FALSE.|
12697 |!|
12698 |         DOWHILE(R_BUYER_DB > 0 .AND. .NOT. SEARCH_SUCCESSFUL .AND.|
12699 |     +                  R_SEARCHES_WITHIN_TRANSACTIONS <|
12700 |     +                                        MAX_SEARCHES_WITHIN_TRANS)|
12701 |!|
12702 |!|
12703 |            SELLER_PRICE_AT_MAX_TRANS =|
12704 |     +                     GET_MARGINAL_COST_AT_MARKET(|
12705 |     +                            R_SELLERS_LOAD+QUANT_AT_MAX_TRANS,|
12706 |     +                              R_SELLER_DB,|
12707 |     +                          R_SELLER_SCARCITY_COST,R_L_M,|
12708 |     +                          R_SELLER_SCARCITY_MULT) +|
12709 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12710 |            SELLER_PRICE_AT_MIN_TRANS =|
12711 |     +                     GET_MARGINAL_COST_AT_MARKET(|
12712 |     +                            R_SELLERS_LOAD+QUANT_AT_MIN_TRANS,|
12713 |     +                              R_SELLER_DB,|
12714 |     +                          R_SELLER_SCARCITY_COST,R_L_M,|
12715 |     +                          R_SELLER_SCARCITY_MULT) +|
12716 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12717 |            BUYER_PRICE_AT_MAX_TRANS =|
12718 |     +                        GET_MARGINAL_COST_AT_MARKET(|
12719 |     +                        R_BUYERS_LOAD-QUANT_AT_MAX_TRANS,|
12720 |     +                        R_BUYER_DB,|
12721 |     +                        R_BUYER_SCARCITY_COST,R_L_M,|
12722 |     +                        R_BUYER_SCARCITY_MULT)|
12723 |            BUYER_PRICE_AT_MIN_TRANS =|
12724 |     +                        GET_MARGINAL_COST_AT_MARKET(|
12725 |     +                        R_BUYERS_LOAD-QUANT_AT_MIN_TRANS,|
12726 |     +                        R_BUYER_DB,|
12727 |     +                        R_BUYER_SCARCITY_COST,R_L_M,|
12728 |     +                        R_BUYER_SCARCITY_MULT)|
12729 |!|
12730 |            DENOM = QUANT_AT_MAX_TRANS - QUANT_AT_MIN_TRANS|
12731 |!|
12732 |            IF(DENOM == 0.d0) THEN|
12733 |               WRITE(4,*)'*** line 6351 TRANSOBJ.FOR ***'|
12734 |               WRITE(4,*)|
12735 |     +                                  "IRREGULAR COST CURVES DETECTED"|
12736 |               er_message='See WARNING MESSAGES -wh_objt.for-2'|
12737 |               call end_program(er_message)|
12738 |            ENDIF|
12739 |!|
12740 |            SELLER_SLOPE =|
12741 |     +                        (SELLER_PRICE_AT_MAX_TRANS -|
12742 |     +                                SELLER_PRICE_AT_MIN_TRANS) / DENOM ! unused|
12743 |            BUYER_SLOPE =|
12744 |     +                        (BUYER_PRICE_AT_MAX_TRANS -|
12745 |     +                                 BUYER_PRICE_AT_MIN_TRANS) / DENOM ! unused|
12746 |!|
12747 |            SELLER_INTERCEPT = SELLER_PRICE_AT_MIN_TRANS|
12748 |                        BUYER_INTERCEPT = BUYER_PRICE_AT_MIN_TRANS|
12749 |!|
12750 |            IF(SELLER_SLOPE == BUYER_SLOPE) THEN|
12751 |               WRITE(4,*) "Slopes identical",SELLER_SLOPE|
12752 |                           SELLER_SLOPE = BUYER_SLOPE + .1d0|
12753 |            ENDIF|
12754 |!|
12755 |            r8_X_TEMP =|
12756 |     +                        (BUYER_INTERCEPT - SELLER_INTERCEPT)/|
12757 |     +                                      (SELLER_SLOPE - BUYER_SLOPE)|
12758 |!|
12759 |            r8_Y_TEMP = SELLER_INTERCEPT + SELLER_SLOPE *|
12760 |     +                                                         r8_X_TEMP|
12761 |!|
12762 |!  EVERYTHING ABOVE WORKS OFF OF DENOM, OR THE ORIGIN OF THE INTERSECTION|
12763 |!  AT THE QUANT_AT_MIN_TRANS.|
12764 |!|
12765 |            r8_X_TEMP = r8_X_TEMP + QUANT_AT_MIN_TRANS ! PREVIOUS MIN VALUE|
12766 |!|
12767 |            R_SEARCHES_WITHIN_TRANSACTIONS =|
12768 |     +                                R_SEARCHES_WITHIN_TRANSACTIONS + 1|
12769 |!|
12770 |            IF(R_SEARCHES_WITHIN_TRANSACTIONS >=|
12771 |     +                            MAX_SEARCHES_WITHIN_TRANS) THEN|
12772 |!               R_TRANSACTION_COMPLETED = .TRUE.|
12773 |               IF(R_TEMP_TRANSACTION > 0. .AND.|
12774 |     +                              R_SELLERS_COST < R_BUYERS_COST) THEN|
12775 |!|
12776 |                  SEARCH_SUCCESSFUL = .TRUE.|
12777 |                  R_CONVERGENCE_PATH = 35.|
12778 |               ENDIF|
12779 |            ELSEIF(r8_Y_TEMP >|
12780 |     +                            SELLER_PRICE_AT_MIN_TRANS .AND.|
12781 |     +                                 SELLER_PRICE_AT_MAX_TRANS >|
12782 |     +                                    BUYER_PRICE_AT_MAX_TRANS) THEN|
12783 |!|
12784 |               SELLER_PRICE_AT_TEST_TRANS =|
12785 |     +                     GET_MARGINAL_COST_AT_MARKET(|
12786 |     +                           R_SELLERS_LOAD+r8_X_TEMP,|
12787 |     +                           R_SELLER_DB,|
12788 |     +                           R_SELLER_SCARCITY_COST,R_L_M,|
12789 |     +                           R_SELLER_SCARCITY_MULT) +|
12790 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12791 |               BUYER_PRICE_AT_TEST_TRANS =|
12792 |     +                     GET_MARGINAL_COST_AT_MARKET(|
12793 |     +                           R_BUYERS_LOAD-r8_X_TEMP,|
12794 |     +                           R_BUYER_DB,|
12795 |     +                           R_BUYER_SCARCITY_COST,R_L_M,|
12796 |     +                           R_BUYER_SCARCITY_MULT)|
12797 |!|
12798 |               IF(ABS(BUYER_PRICE_AT_TEST_TRANS -|
12799 |     +                           SELLER_PRICE_AT_TEST_TRANS) < .05 .AND.|
12800 |     +                      BUYER_PRICE_AT_TEST_TRANS -|
12801 |     +                      SELLER_PRICE_AT_TEST_TRANS > -.005) THEN|
12802 |                  R_BUYERS_COST = BUYER_PRICE_AT_TEST_TRANS|
12803 |                  R_SELLERS_COST =|
12804 |     +                              SELLER_PRICE_AT_TEST_TRANS -|
12805 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12806 |                  R_TEMP_TRANSACTION = r8_X_TEMP|
12807 ||
12808 |                  SEARCH_SUCCESSFUL = .TRUE.|
12809 |                  R_CONVERGENCE_PATH = 32.|
12810 |               ELSEIF(BUYER_PRICE_AT_TEST_TRANS >|
12811 |     +                                  SELLER_PRICE_AT_TEST_TRANS) THEN|
12812 |! MAKE X THE LOWER BOUND AND RETEST|
12813 |                  QUANT_AT_MIN_TRANS = r8_X_TEMP|
12814 |! FEASIBLE SOLUTION ADDRESSES PAC ISSUE: BUYER COST < DELIVERED COST|
12815 |                  R_BUYERS_COST = BUYER_PRICE_AT_TEST_TRANS|
12816 |                  R_SELLERS_COST =|
12817 |     +                              SELLER_PRICE_AT_TEST_TRANS -|
12818 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12819 |                  R_TEMP_TRANSACTION = r8_X_TEMP|
12820 |               ELSEIF(BUYER_PRICE_AT_TEST_TRANS <|
12821 |     +                                  SELLER_PRICE_AT_TEST_TRANS) THEN|
12822 |! MAKE X THE UPPER BOUND AND RETEST|
12823 |                  QUANT_AT_MAX_TRANS = r8_X_TEMP|
12824 |               ENDIF|
12825 |            ELSEIF( SELLER_PRICE_AT_MAX_TRANS -|
12826 |     +                            BUYER_PRICE_AT_MAX_TRANS < 0.010) THEN|
12827 |               R_TEMP_TRANSACTION = QUANT_AT_MAX_TRANS|
12828 |               R_BUYERS_COST = BUYER_PRICE_AT_MAX_TRANS|
12829 |               R_SELLERS_COST = SELLER_PRICE_AT_MAX_TRANS -|
12830 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12831 |!!              R_TRANSACTION_COMPLETED = .TRUE.|
12832 |               SEARCH_SUCCESSFUL = .TRUE.|
12833 |               R_CONVERGENCE_PATH = 33.|
12834 |            ELSEIF(r8_Y_TEMP <=|
12835 |     +                                   SELLER_PRICE_AT_MIN_TRANS) THEN|
12836 |               R_BUYERS_COST = BUYER_PRICE_AT_MIN_TRANS|
12837 |               R_SELLERS_COST = SELLER_PRICE_AT_MIN_TRANS -|
12838 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12839 |               R_TEMP_TRANSACTION = QUANT_AT_MIN_TRANS|
12840 ||
12841 |               SEARCH_SUCCESSFUL = .TRUE.|
12842 |               R_CONVERGENCE_PATH = 34.|
12843 |            ENDIF|
12844 |         ENDDO|
12845 |!|
12846 |         IF(SEARCH_SUCCESSFUL) THEN|
12847 |!|
12848 |            IF(R_CONVERGENCE_PATH /= 33) THEN|
12849 ||
12850 |               R_BUYERS_COST = BUYER_PRICE_AT_MIN_TRANS|
12851 |               R_SELLERS_COST = SELLER_PRICE_AT_MIN_TRANS -|
12852 |     +                                    R_TIE_PLUS_MARKET_SCARCITY|
12853 ||
12854 |            ENDIF|
12855 |!|
12856 |            R_TOTAL_DELIVERED_COST =|
12857 |     +                                 R_SELLERS_COST +|
12858 |     +                                      R_TIE_PLUS_MARKET_SCARCITY|
12859 |            IF( R_TOTAL_DELIVERED_COST -|
12860 |     +                                          R_BUYERS_COST > 0.2)THEN|
12861 |               WRITE(4,*) 'DELIVERED COST EXCEEDS BUYERS'|
12862 |               WRITE(4,*) 'INTERAL COST. MONTH= ',|
12863 |     +                                       R_MONTH,' HOUR= ',R_HR|
12864 |!                                 STOP|
12865 |               SEARCH_SUCCESSFUL = .FALSE.|
12866 |               R_SEARCHES_WITHIN_TRANSACTIONS = 0|
12867 |            ENDIF|
12868 |            R_TRANSACTION_COMPLETED = SEARCH_SUCCESSFUL|
12869 |!            IF(R_HOURLY_DUMP_USED  > 0.) THEN|
12870 |!               R_TEMP_TRANSACTION = MAX(0.,R_TEMP_TRANSACTION -|
12871 |!     +                                               R_HOURLY_DUMP_USED)|
12872 |!            ENDIF|
12873 |         ELSE|
12874 |            R_SEARCHES_WITHIN_TRANSACTIONS = 0|
12875 |         ENDIF|
12876 |!|
12877 |      RETURN|
12878 |      END|
