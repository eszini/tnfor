7570 |     +   IncrHrCurLoad(0:1),|
7571 |     +   FracHrCurLoad(0:1),|
7572 |     +   TimeRatio(0:1),|
7573 |     +   GPLoad(0:1),|
7574 |     +   CapyMW(0:1),|
7575 |     +   CeffMW(0:1),|
7576 |     +   HrsUse(0:1),|
7577 |     +   EnergyRatio,|
7578 |     +   TimeConstraint,|
7579 |     +   OriginalLoad,|
7580 |     +   ShoulderLoad,|
7581 |!    +   NominalCap,|
