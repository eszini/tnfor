1532 |      ENTRY GET_MONTHLY_DISP_COST_BY_UNIT(|
1533 |     +                                R_UN,|
1534 |     +                                R_LOCAL_COEFF,|
1535 |     +                                R_DISPATCH) ! 2x12|
1536 ||
1537 |!***********************************************************************|
1538 |!|
1539 |      UN = R_UN|
1540 |      EXISTING_UNIT = .TRUE.|
1541 |      BASE_DATE = (YEAR + BASE_YEAR - 1900) * 100|
1542 |!|
1543 |      RFT = GET_PRIMARY_MOVER(UN)|
1544 |      IF(RFT > 3 .OR. RFT < 1) RFT = 1|
1545 |!|
1546 |      DO J = 1, 12|
1547 |         CALL GET_MRX_DELIVERY_COST(      UN,|
1548 |     +                                    TOTAL_DELIVERY_COST,|
1549 |     +                                    J,YEAR,|
1550 |     +                                    FUEL_POINTERS_USED,|
1551 |     +                                    EXISTING_UNIT)|
1552 |!|
1553 |         FUEL_SCEN_MULT = 1.0|
1554 |         IF(RFT == 1) THEN|
1555 |            FUEL_SCEN_MULT =  GET_SCENARIO_COAL_PRICES(YEAR,J)|
1556 |         ELSEIF(RFT == 2) THEN|
1557 |            FUEL_SCEN_MULT =  GET_SCENARIO_GAS_PRICES(YEAR,J)|
1558 |         ELSEIF(RFT == 3) THEN|
1559 |            FUEL_SCEN_MULT =  GET_SCENARIO_OIL_PRICES(YEAR,J)|
1560 |         ELSEIF(RFT == 4) THEN|
1561 |            FUEL_SCEN_MULT =  GET_SCENARIO_URANIUM_PRICES(YEAR,J)|
1562 |         ENDIF|
1563 |!|
1564 |         DISPATCHING_BTU_COST = TOTAL_DELIVERY_COST * FUEL_SCEN_MULT|
1565 |!|
1566 |         LOCAL_DATE = BASE_DATE + J|
1567 |!|
1568 |         DO I = 1, 2|
1569 ||
1570 |            EMIS_DISPATCH_1 =|
1571 |     +                     TRANS_DISPATCH_EMIS_ADDER(1,J,YEAR,UN)|
1572 |            EMIS_DISPATCH_2 =|
1573 |     +                     TRANS_DISPATCH_EMIS_ADDER(2,J,YEAR,UN)|
1574 |            EMIS_DISPATCH_3 =|
1575 |     +                     TRANS_DISPATCH_EMIS_ADDER(3,J,YEAR,UN)|
1576 |            EMIS_DISPATCH_4 =|
1577 |     +                     TRANS_DISPATCH_EMIS_ADDER(4,J,YEAR,UN)|
1578 |            EMIS_DISPATCH_5 =|
1579 |     +                     TRANS_DISPATCH_EMIS_ADDER(5,J,YEAR,UN)|
1580 ||
1581 |            IF(ONLINE(UN) <= LOCAL_DATE .AND.|
1582 |     +                                    OFLINE(UN) >= LOCAL_DATE) THEN|
1583 |               IF(GET_MAINTENANCE_RATE_FOR_MONTH(UN,J) /= 1. .AND.|
1584 |     +                                            EAVAIL(UN) /= 0.) THEN|
1585 ||
1586 |                  IF(USE_SECONDARY_FUEL(UN) .OR.|
1587 |     +               ((SOUTHERN_COMPANY .OR. SECOND_FUEL_EMIS_DISPATCH)|
1588 |     +                                     .AND. FUELMX(UN) < 0.) ) THEN|
1589 |                     F_MIX = 0.|
1590 |                     S_MIX = 1.|
1591 |                  ELSE|
1592 |                     F_MIX = ABS(FUELMX(UN))|
1593 |                     S_MIX = 1. - F_MIX|
1594 |                  ENDIF|
1595 ||
1596 |                  TEMP_R4 = GET_DISPADJ_SAVE(UN)|
1597 |                  IF(TEMP_R4 < 0.0) THEN|
1598 |                     TEMP_R4 = GET_VAR(RTEMP,J,UNITNM(UN))|
1599 |                     IF(TEMP_R4 < 0.0) THEN|
1600 |                        DISP_ADJUSTER = GET_VAR(RTEMP,J,UNITNM(UN))|
1601 |                     ELSE|
1602 |                        DISP_ADJUSTER = TEMP_R4|
1603 |                     ENDIF|
1604 |                  ELSE|
1605 |                     DISP_ADJUSTER = TEMP_R4|
1606 |                  ENDIF|
1607 |                  NOX_RATE = F_MIX * NOX(UN) +|
1608 |     +                                           S_MIX * SEC_NOX_BK1(UN)|
1609 ||
1610 |!|
1611 |                  TEMP_DISPATCH_MULT = DISPATCH_MULT(UN)|
1612 |                  IF(TEMP_DISPATCH_MULT < 0.) THEN ! 030506. ADDED MONTH.|
