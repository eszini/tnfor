i: 10078  |     +            CONTRACT_CAPACITY(LOWEST_COST_CONTRACT))| 
i: 10079  |            ENDIF| 
i: 10080  |         ELSE| 
i: 10081  |            CURRENT_CONTRACT_CAPACITY =| 
i: 10082  |     +         MAXIMUM_CAPACITY(LOWEST_COST_CONTRACT) -| 
i: 10083  |     +                          CONTRACT_CAPACITY(LOWEST_COST_CONTRACT)| 
i: 10084  |            LD_PTS = ISTOP| 
i: 10085  |         ENDIF| 
i: 10086  |!| 
i: 10087  |!        SURPLUS CAPACITY AVAILABLE| 
i: 10088  |!| 
i: 10089  |         LIMITED_ENERGY =| 
i: 10090  |     +            MAXIMUM_ENERGY(LOWEST_COST_CONTRACT)/HOURS -| 
i: 10091  |     +                            CONTRACT_ENERGY(LOWEST_COST_CONTRACT)| 
i: 10092  |!| 
i: 10093  |!| 
i: 10094  |            A = B| 
i: 10095  |            B = B + MAX(CURRENT_CONTRACT_CAPACITY*1.0001,.0001)| 
i: 10096  |! 12/23/94. GAT. TESTING FOR PALO ALTO| 
i: 10097  |            IF(LAST_ENERGY_ONLY_PRICE < NEXT_LOWEST_VARIABLE_COST) THEN| 
i: 10098  |               ENERGY_ONLY_FOR_DISPATCHING = MAX(0.,| 
i: 10099  |     +                     MIN(LIMITED_ENERGY,REMAINING_ENRG_ONLY_ENRG))| 
i: 10100  |            ELSE| 
i: 10101  |               ENERGY_ONLY_FOR_DISPATCHING = 0.0| 
i: 10102  |            ENDIF| 
i: 10103  |!| 
i: 10104  |!| 
i: 10105  |!     LOAD THE LOWEST_COST_CONTRACT INTO THE ELDC FROM B TO| 
i: 10106  |!     B PLUS CONTRACT_CAPACITY, OR UNTIL MAXIMUM_CONTRACT_ENERGY| 
i: 10107  |!| 
i: 10108  |         CALL CALC_CONTRACT_ENERGY(LODDUR,LPROB,DX,A,B,| 
i: 10109  |     +                     CURRENT_CONTRACT_ENERGY,| 
i: 10110  |     +                     LEFT,RIGHT,LIMITED_ENERGY,| 
i: 10111  |     +                     ISTART,LAST_POINT,| 
i: 10112  |     +                     ENERGY_ONLY_FOR_DISPATCHING,| 
i: 10113  |!| 
i: 10114  |     +                     ENRG_ONLY_ENRG_USED)| 
i: 10115  |!| 
i: 10116  |! 12/23/94. GAT. TESTING FOR PALO ALTO| 
i: 10117  |         IF(LAST_ENERGY_ONLY_PRICE <| 
i: 10118  |     +                              NEXT_LOWEST_VARIABLE_COST)| 
i: 10119  |     +            REMAINING_ENRG_ONLY_ENRG = REMAINING_ENRG_ONLY_ENRG -| 
i: 10120  |     +                                               ENRG_ONLY_ENRG_USED| 
i: 10121  |!| 
i: 10122  |!        TAKE INTO ACCOUNT PROBLEM WITH PEAK SHIFT ALGORITHM| 
i: 10123  |!| 
i: 10124  |         IF((CURRENT_CONTRACT_ENERGY + ENRG_ONLY_ENRG_USED) .GT.| 
i: 10125  |     +                                           REMAINING_ENERGY .OR.| 
i: 10126  |     +               (RIGHT .EQ. 0 .AND. REMAINING_ENERGY .GT. 0.)) THEN| 
