1786 |         IF(RIGHT > .0000001 .AND. REMAINING_ENERGY == 0.) THEN|
1787 |!|
1788 |!|
1789 |!|
1790 |!|
1791 |            CONTRACTS_ACTIVE = .FALSE.|
1792 |            RETURN|
1793 |         ENDIF|
1794 |         TEMP_CONTRACT_COST = 9999999.|
1795 |         LOWEST_COST = CL_DISPATCH_COST|
1796 |         LOWEST_COST_CONTRACT = 0|
1797 |         NEXT_LOWEST_VARIABLE_COST = 999999999.|
1798 |         NEXT_LOWEST_TOTAL_COST =    999999999.|
1799 |         DO CONTRACT = 1 , NUMBER_OF_CONTRACTS|
1800 |            IF(AVAILABLE_CONTRACT(CONTRACT) .AND.|
1801 |     +                     CNTR_CAPACITY_SWITCH(CONTRACT) .NE. "E") THEN|
1802 |               IF(CNTR_CAPACITY_SWITCH(CONTRACT) .EQ. 'V') THEN|
1803 |                  TEMP_CONTRACT_COST =|
1804 |     +               (CONTRACT_VARIABLE_COST(CONTRACT) +|
1805 |     +                      CT_ENERGY_COST_ADDER(CONTRACT) +|
1806 |     +            12*1000*CONTRACT_FIXED_COST(CONTRACT)/(HOURS*|
1807 |     +               (RIGHT)*PRODUCTION_COST_PERIODS))*10.|
