1899 |     +                  TEMP_CROSSOVER_PROB+.0001 .LT. RIGHT .AND.|
1900 |     +                  TEMP_CROSSOVER_PROB+.0001 .GT. 0.0 .AND.|
1901 |     +                  TEMP_CROSSOVER_COST .GT. 0.) THEN|
1902 |!|
1903 |!|
1904 |                     FIXED_COST_FACTOR =|
1905 |     +                    (12.*1000./(HOURS*RIGHT*|
1906 |     +                                     PRODUCTION_COST_PERIODS))*10.|
1907 |                     IF(CNTR_CAPACITY_SWITCH(CONTRACT) .EQ. 'V') THEN|
1908 |                        NEXT_LOWEST_TOTAL_COST =|
1909 |     +                     10.*CONTRACT_VARIABLE_COST(CONTRACT) +|
1910 |     +                               CONTRACT_FIXED_COST(CONTRACT) *|
1911 |     +                                                 FIXED_COST_FACTOR|
1912 |                     ELSE|
1913 |                        NEXT_LOWEST_TOTAL_COST =|
1914 |     +                              10.*CONTRACT_VARIABLE_COST(CONTRACT)|
1915 |                     ENDIF|
1916 |                     CROSSOVER_COST = TEMP_CROSSOVER_COST|
1917 |                     CONTRACT_CROSSOVER_PROB = TEMP_CROSSOVER_PROB|
1918 |                  ENDIF|
1919 |               ENDIF|
1920 |            ENDDO|
1921 |!|
1922 |!           NEXT BEST CL UNIT - CONSTRAINT (4)|
1923 |!           6/21/93. GAT. TRAPPED FOR 10.*CONTRACT...|
1924 |!|
1925 |! MARK QUESTIONS: SHOULD THE ADDER BE IN THIS|
1926 |!|
1927 |            LOWEST_VARIABLE_COST =|
1928 |     +                    CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT) +|
1929 |     +                        CT_ENERGY_COST_ADDER(LOWEST_COST_CONTRACT)|
1930 |            IF(CL_DISPATCH_COST /= 10.* LOWEST_VARIABLE_COST)|
1931 |     +         CL_CROSSOVER_PROB = 10. * FIX_LOWEST/|
