3187 |     +                                    ISEAS,|
3188 |     +                                    PSI_CLASS_NUMBER,|
3189 |     +                                    THIS_MONTH_ENERGY,|
3190 |     +                                    THIS_MONTH_PEAK)|
3191 |!|
3192 |         PSI_ENERGY_DEMAND =(THIS_MONTH_ENERGY +|
3193 |     +                       FORECAST_DSM_ENERGY(PSI_CLASS_NUMBER))/|
3194 |     +                                                        SEAS_HOURS|
3195 |         PSI_PEAK_DEMAND = THIS_MONTH_PEAK ! ASSUMES MONTHLY PRODUCTION|
3196 |         PSI_BASE_DEMAND = MAX(0.,|
3197 |     +                           2.*PSI_ENERGY_DEMAND - PSI_PEAK_DEMAND)|
3198 |         DO GIB = 1 , 2|
3199 |            IF(GIB == 1) THEN ! CALCULATE TOTAL GIBSON ENERGY|
3200 |               GIB5_CAP = MW(2,UNITNO) *|
3201 |     +                   (1.-AREA_CAPACITY_LOSSES(3,ISEAS,ARRAY_POINTR))|
3202 |            ELSE|
3203 |               GIB5_CAP = BLK_MW|
3204 |            ENDIF|
3205 |            IF(GIB5_CAP <= PSI_BASE_DEMAND) THEN|
3206 |               GIB5_ENERGY = GIB5_CAP|
3207 |            ELSE|
3208 |               IF(GIB5_CAP > PSI_PEAK_DEMAND) GIB5_CAP = PSI_PEAK_DEMAND|
3209 |               PSI_LDC = (PSI_PEAK_DEMAND - GIB5_CAP)/|
3210 |     +                               (PSI_PEAK_DEMAND - PSI_BASE_DEMAND)|
3211 |               GIB5_ENERGY = PSI_BASE_DEMAND + (1. + PSI_LDC) *|
3212 |     +                                   (GIB5_CAP - PSI_BASE_DEMAND)/2.|
3213 |            ENDIF|
3214 |            IF(GIB == 1) THEN|
3215 |               GIBSON_TOTAL_ENERGY = GIB5_ENERGY|
3216 |            ELSE|
3217 |               GIBSON_BLOCK1_ENERGY = GIB5_ENERGY|
3218 |            ENDIF|
3219 |         ENDDO|
3220 |         GIBSON_BLOCK2_ENERGY = GIBSON_TOTAL_ENERGY-GIBSON_BLOCK1_ENERGY|
3221 |      RETURN|
3222 |      END SUBROUTINE GET_GIBSON5_ENERGY|
