i:   713  |C| 
i:   714  |C***********************************************************************| 
i:   715  |      SUBROUTINE CALCULATE_CLASS_PEAKS(IYR,CLASS_COIN_LOSS_FACTOR,| 
i:   716  |     +                         CLSMW1,CLSMW2,CLASS,CONTRIBUTES_TO_TOTAL)| 
i:   717  |C***********************************************************************| 
i:   718  |C| 
i:   719  |      USE SIZECOM| 
i:   720  |      INCLUDE 'SpinLib.MON'| 
i:   721  |      REAL CLASS_COIN_LOSS_FACTOR,CLSMW1(*),CLSMW2(*)| 
i:   722  |      REAL PLANNING_PEAK,CLASS_PEAK,R_PEAK| 
i:   723  |      INTEGER*2 IYR,MO,YEAR,CLASS,TOTAL_CLASSES,PEAK_MONTH,PEAK_DAY,| 
i:   724  |     +            R_CLASS,R_YR,R_MONTH,MAX_CLASS/7/,MIN_CLASS/1/| 
i:   725  |      LOGICAL*1 FIRST_CLASS/.TRUE./| 
i:   726  |C SYSTEM PEAK VARIABLES| 
i:   727  |      REAL PEAKS(12,2),SYS_FC_DATA(*),REAL_TEMP,R_CLASS_PEAK| 
i:   728  |      REAL STORE_ANNUAL_PEAK_AND_MONTH| 
i:   729  |      INTEGER*2 MO_OFFSET| 
i:   730  |C| 
i:   731  |C INCLUDE COMMON BLOCK OF YEARLY SYSTEM FORECAST STATISTICS| 
i:   732  |C| 
i:   733  |      REAL FYREGY(AVAIL_DATA_YEARS),FYRPK(AVAIL_DATA_YEARS)| 
i:   734  |      COMMON/FRC2/ FYREGY,FYRPK| 
i:   735  |C VARIBLES FOR CAPACITY PLANNING PEAKS| 
i:   736  |      INTEGER*1 FORECAST_GROWTH_YEARS| 
i:   737  |      PARAMETER (FORECAST_GROWTH_YEARS = AVAIL_DATA_YEARS)| 
i:   738  |      REAL SUM_CLASS_PEAKS(:,:,:,:),CLASS_ANN_COIN_PEAK(:,:)| 
i:   739  |      LOGICAL*1 CONTRIBUTES_TO_TOTAL| 
i:   740  |      ALLOCATABLE SUM_CLASS_PEAKS,CLASS_ANN_COIN_PEAK| 
i:   741  |      REAL CLASS_GROWTH_TRIGGER,CLASS_GROWTH_TRIGGER_LEVEL| 
i:   742  |      REAL SYS_GROWTH_TRIGGER,SYS_GROWTH_TRIGGER_LEVEL| 
i:   743  |      SAVE SUM_CLASS_PEAKS,PEAKS,CLASS_ANN_COIN_PEAK| 
i:   744  |C| 
i:   745  |      TOTAL_CLASSES = MAX_LOAD_CLASSES + 1| 
i:   746  |C     FORECAST_GROWTH_YEARS = AVAIL_DATA_YEARS| 
i:   747  |      IF(IYR == 1 .AND. FIRST_CLASS) THEN| 
i:   748  |         IF(ALLOCATED(SUM_CLASS_PEAKS)) DEALLOCATE(SUM_CLASS_PEAKS)| 
i:   749  |         ALLOCATE(SUM_CLASS_PEAKS(12,2,FORECAST_GROWTH_YEARS,| 
i:   750  |     +                                                   TOTAL_CLASSES))| 
i:   751  |         SUM_CLASS_PEAKS = 0.| 
i:   752  |         IF(ALLOCATED(CLASS_ANN_COIN_PEAK))| 
i:   753  |     +                                   DEALLOCATE(CLASS_ANN_COIN_PEAK)| 
i:   754  |         ALLOCATE(CLASS_ANN_COIN_PEAK(MAX_LOAD_CLASSES,| 
i:   755  |     +                                           FORECAST_GROWTH_YEARS))| 
i:   756  |         CLASS_ANN_COIN_PEAK = 0.| 
i:   757  |         FIRST_CLASS = .FALSE.| 
i:   758  |      ENDIF| 
i:   759  |      CLASS_GROWTH_TRIGGER_LEVEL = CLASS_GROWTH_TRIGGER()| 
i:   760  |      DO MO = 1, 12| 
i:   761  |         IF(IYR == 1) THEN| 
i:   762  |            PEAKS(MO,1) = CLSMW1(MO)| 
i:   763  |            PEAKS(MO,2) = CLSMW2(MO)| 
i:   764  |         ELSE| 
i:   765  |            CLASS_PEAK = CLSMW1(MO)| 
i:   766  |            IF(CLASS_PEAK <= CLASS_GROWTH_TRIGGER_LEVEL) THEN| 
i:   767  |               PEAKS(MO,1) = (1.+CLASS_PEAK/100.) * PEAKS(MO,1)| 
i:   768  |            ELSE| 
i:   769  |               PEAKS(MO,1) = CLSMW1(MO)| 
i:   770  |            ENDIF| 
i:   771  |            CLASS_PEAK = CLSMW2(MO)| 
i:   772  |            IF(CLASS_PEAK <= CLASS_GROWTH_TRIGGER_LEVEL) THEN| 
i:   773  |               PEAKS(MO,2) = (1.+CLASS_PEAK/100.) * PEAKS(MO,2)| 
i:   774  |            ELSE| 
i:   775  |               PEAKS(MO,2) = CLSMW2(MO)| 
i:   776  |            ENDIF| 
i:   777  |         ENDIF| 
i:   778  |!         | 
i:   779  |! ADDED 2/11/98. GAT. LARRY KEY, SRP| 
i:   780  |!| 
i:   781  |         IF(CLASS < MIN_CLASS .OR. CLASS > MAX_CLASS) THEN| 
i:   782  |            WRITE(4,*) "A class forecast file contains class"| 
i:   783  |            WRITE(4,*) "number ",CLASS," In year ",IYR| 
i:   784  |            WRITE(4,*) "It has been reassigned to Class=1."| 
i:   785  |            CLASS = 1| 
i:   786  |         ENDIF| 
i:   787  |!         | 
i:   788  |         IF(CONTRIBUTES_TO_TOTAL) THEN| 
i:   789  |C         | 
i:   790  |            SUM_CLASS_PEAKS(MO,1,IYR,CLASS) = | 
i:   791  |     +                 SUM_CLASS_PEAKS(MO,1,IYR,CLASS) +| 
i:   792  |     +                                PEAKS(MO,1)*CLASS_COIN_LOSS_FACTOR| 
i:   793  |            SUM_CLASS_PEAKS(MO,2,IYR,CLASS) = | 
i:   794  |     +                 SUM_CLASS_PEAKS(MO,2,IYR,CLASS) +| 
i:   795  |     +                                PEAKS(MO,2)*CLASS_COIN_LOSS_FACTOR| 
i:   796  |C     | 
i:   797  |            SUM_CLASS_PEAKS(MO,1,IYR,TOTAL_CLASSES) = | 
i:   798  |     +                 SUM_CLASS_PEAKS(MO,1,IYR,TOTAL_CLASSES) +| 
i:   799  |     +                                PEAKS(MO,1)*CLASS_COIN_LOSS_FACTOR| 
i:   800  |            SUM_CLASS_PEAKS(MO,2,IYR,TOTAL_CLASSES) = | 
i:   801  |     +                 SUM_CLASS_PEAKS(MO,2,IYR,TOTAL_CLASSES) +| 
i:   802  |     +                                PEAKS(MO,2)*CLASS_COIN_LOSS_FACTOR| 
i:   803  |         ENDIF| 
i:   804  |C     | 
i:   805  |      ENDDO| 
i:   806  |      RETURN| 
i:   807  |C| 
i:   808  |C***********************************************************************| 
i:   809  |      ENTRY FIND_AND_STORE_SYSTEM_PEAKS| 
i:   810  |C***********************************************************************| 
i:   811  |C| 
i:   812  |         DO YEAR = 1, FORECAST_GROWTH_YEARS| 
i:   813  |            CLASS_PEAK = 0.| 
i:   814  |            PEAK_MONTH = 0| 
i:   815  |            PEAK_DAY = 0| 
i:   816  |            DO MO = 1, 12| 
i:   817  |               IF(CLASS_PEAK > | 
i:   818  |     +             MAX(SUM_CLASS_PEAKS(MO,1,YEAR,TOTAL_CLASSES),| 
i:   819  |     +                  SUM_CLASS_PEAKS(MO,2,YEAR,TOTAL_CLASSES))) CYCLE| 
i:   820  |               PEAK_MONTH = MO| 
i:   821  |               IF(SUM_CLASS_PEAKS(MO,1,YEAR,TOTAL_CLASSES) >| 
i:   822  |     +                    SUM_CLASS_PEAKS(MO,2,YEAR,TOTAL_CLASSES)) THEN| 
i:   823  |                  PEAK_DAY = 1| 
i:   824  |               ELSE| 
i:   825  |                  PEAK_DAY = 2| 
i:   826  |               ENDIF| 
i:   827  |               CLASS_PEAK = | 
i:   828  |     +           SUM_CLASS_PEAKS(PEAK_MONTH,PEAK_DAY,YEAR,TOTAL_CLASSES)| 
i:   829  |            ENDDO| 
i:   830  |            PLANNING_PEAK = STORE_ANNUAL_PEAK_AND_MONTH(PEAK_MONTH,YEAR,| 
i:   831  |     +                                                       CLASS_PEAK)| 
i:   832  |            DO CLASS = 1 , MAX_LOAD_CLASSES| 
i:   833  |               CLASS_ANN_COIN_PEAK(CLASS,YEAR) = | 
i:   834  |     +                   SUM_CLASS_PEAKS(PEAK_MONTH,PEAK_DAY,YEAR,CLASS)| 
i:   835  |            ENDDO| 
i:   836  |         ENDDO| 
i:   837  |      RETURN| 
i:   838  |C      | 
i:   839  |C***********************************************************************| 
i:   840  |      ENTRY DEALLOCATE_SUM_CLASS_PEAKS| 
i:   841  |C***********************************************************************| 
i:   842  |         IF(ALLOCATED(SUM_CLASS_PEAKS)) DEALLOCATE(SUM_CLASS_PEAKS)| 
i:   843  |      RETURN| 
i:   844  |C***********************************************************************| 
i:   845  |      ENTRY GET_CLASS_PEAK_FOR_CAPACITY(R_CLASS,R_YR,R_CLASS_PEAK)| 
i:   846  |C***********************************************************************| 
i:   847  |         R_CLASS_PEAK = CLASS_ANN_COIN_PEAK(R_CLASS,R_YR)         | 
i:   848  |      RETURN| 
i:   849  |C***********************************************************************| 
i:   850  |      ENTRY CALCULATE_SYSTEM_PEAKS(SYS_FC_DATA,IYR)| 
i:   851  |C***********************************************************************| 
i:   852  |C| 
i:   853  |         IF(IYR == 1 .AND. FIRST_CLASS) THEN| 
i:   854  |            IF(ALLOCATED(SUM_CLASS_PEAKS)) DEALLOCATE(SUM_CLASS_PEAKS)| 
i:   855  |            ALLOCATE(SUM_CLASS_PEAKS(12,2,FORECAST_GROWTH_YEARS,1))| 
i:   856  |            SUM_CLASS_PEAKS = 0.| 
i:   857  |            FIRST_CLASS = .FALSE.| 
i:   858  |         ENDIF| 
i:   859  |C| 
i:   860  |         PLANNING_PEAK = 0.| 
i:   861  |         SYS_GROWTH_TRIGGER_LEVEL = SYS_GROWTH_TRIGGER()| 
i:   862  |         DO MO = 1, 12| 
i:   863  |            MO_OFFSET = 4*(MO-1)| 
i:   864  |            IF(IYR == 1) THEN| 
i:   865  |               PEAKS(MO,1) = SYS_FC_DATA(MO_OFFSET+2)| 
i:   866  |               PEAKS(MO,2) = SYS_FC_DATA(MO_OFFSET+4)| 
i:   867  |            ELSE| 
i:   868  |               REAL_TEMP = SYS_FC_DATA(MO_OFFSET+2)| 
i:   869  |               IF(REAL_TEMP <= SYS_GROWTH_TRIGGER_LEVEL) THEN| 
i:   870  |                  PEAKS(MO,1) = (1. + REAL_TEMP/100.) * PEAKS(MO,1)| 
i:   871  |               ELSE| 
i:   872  |                  PEAKS(MO,1) = REAL_TEMP| 
i:   873  |               ENDIF| 
i:   874  |               REAL_TEMP = SYS_FC_DATA(MO_OFFSET+4)| 
i:   875  |               IF(REAL_TEMP <= SYS_GROWTH_TRIGGER_LEVEL) THEN| 
i:   876  |                  PEAKS(MO,2) = (1. + REAL_TEMP/100.) * PEAKS(MO,2)| 
i:   877  |               ELSE| 
i:   878  |                  PEAKS(MO,2) = REAL_TEMP| 
i:   879  |               ENDIF| 
i:   880  |            ENDIF| 
i:   881  |            IF(MAX(PEAKS(MO,1),PEAKS(MO,2)) >= PLANNING_PEAK) THEN| 
i:   882  |               PLANNING_PEAK = STORE_ANNUAL_PEAK_AND_MONTH(MO,IYR,| 
i:   883  |     +                                     MAX(PEAKS(MO,1),PEAKS(MO,2)))| 
i:   884  |            ENDIF| 
i:   885  |            SUM_CLASS_PEAKS(MO,1,IYR,1) = SUM_CLASS_PEAKS(MO,1,IYR,1) +| 
i:   886  |     +                                                       PEAKS(MO,1)| 
i:   887  |            SUM_CLASS_PEAKS(MO,2,IYR,1) = SUM_CLASS_PEAKS(MO,2,IYR,1) +| 
i:   888  |     +                                                       PEAKS(MO,2)| 
i:   889  |         ENDDO| 
i:   890  |      RETURN| 
i:   891  |C***********************************************************************| 
i:   892  |      ENTRY SET_FIRST_CLASS_TRUE| 
i:   893  |C***********************************************************************| 
i:   894  |        FIRST_CLASS = .TRUE.| 
i:   895  |      RETURN| 
