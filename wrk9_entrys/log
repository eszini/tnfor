i:  1822  |            IF(IOS_BASE /= 0) EXIT| 
i:  1823  |            IF(IOS == 0) THEN| 
i:  1824  |               RECLN = trim(RECLN)//',,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,'| 
i:  1825  |               READ(RECLN,*,ERR=200) DELETE,YEAR,| 
i:  1826  |     +            (EMIS_DISPATCH_ADDER(I),I=1,3),(EMIS_CAP(I),I=1,3),| 
i:  1827  |     +            (PURCH_CRED_PRICE(I),I=1,3),| 
