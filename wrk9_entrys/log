2178 |               TIER_2_ENERGY = TIER_2_ENERGY - TIER_2_TEMP|
2179 |               REMAINING_ENRG_ONLY_ENRG = REMAINING_ENRG_ONLY_ENRG -|
2180 |     +                                                       TIER_2_TEMP|
2181 |            ENDIF|
2182 |!|
2183 |            IF( CONTRACT_CAPACITY(TIER_2_CT) > 0. .AND.|
2184 |     +                   CONTRACT_ENERGY(TIER_2_CT)/|
2185 |     +                       CONTRACT_CAPACITY(TIER_2_CT) > 1.0001) THEN|
2186 |               CONTRACT_CAPACITY(TIER_2_CT) =|
