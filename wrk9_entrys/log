2811 |      SUBROUTINE EMISSIONS_BY_BLENDED_FUEL(UNIT_NO,BLK1_HEAT,BLK2_HEAT)|
2812 |!**********************************************************************|
2813 |      implicit none|
2814 |      integer (kind=2) , intent(in) :: UNIT_NO|
