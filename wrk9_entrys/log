i:  3817  |         ESCALATE_DISP_ADDER_VALUES = NUM_VALS | 
i:  3818  |C         IF(ITERATE_GRX_PLANNING() .AND. GRX_ITERATIONS > 1) RETURN REMOVED 3/4/11 | 
i:  3819  |         DO I = 1, NUM_VALS| 
