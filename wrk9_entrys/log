1843 |!|
1844 |!     MAXIMUM_CAPACITY PROB - CONSTRAINT (2) (INPUT ASSUMPTION)|
1845 |!|
1846 |!        NO CALCULATION NECESSARY. KEEP IN MW'S UNITS.|
1847 |!|
1848 |!     NEXT BEST CONTRACT PROBABILITY - CONSTRAINT (3)|
1849 |!|
1850 |         FIXED_COST_FACTOR =|
1851 |     +                    (12.*1000./(HOURS*RIGHT*|
1852 |     +                                     PRODUCTION_COST_PERIODS))*10.|
1853 |!|
1854 |         IF(CNTR_CAPACITY_SWITCH(LOWEST_COST_CONTRACT) .EQ. 'V') THEN|
1855 |            FIX_LOWEST = 12*1000*|
1856 |     +                  CONTRACT_FIXED_COST(LOWEST_COST_CONTRACT)/|
1857 |     +                  (HOURS*PRODUCTION_COST_PERIODS)|
1858 |            CROSSOVER_COST = 999999.|
1859 |            CONTRACT_CROSSOVER_PROB = 0.0000001|
1860 |            DO CONTRACT = 1, NUMBER_OF_CONTRACTS|
1861 |               LOWEST_VARIABLE_COST =|
1862 |     +                    CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT) +|
1863 |     +                        CT_ENERGY_COST_ADDER(LOWEST_COST_CONTRACT)|
1864 |               CURRENT_VARIABLE_COST=CONTRACT_VARIABLE_COST(CONTRACT) +|
1865 |     +                                    CT_ENERGY_COST_ADDER(CONTRACT)|
1866 |!|
1867 |! MARK QUESTIONS: SHOULD THE ADDER BE IN THIS|
1868 |!|
1869 |! UPDATE: 9/8/94. GAT.|
1870 |               IF( CONTRACT_FIXED_COST(LOWEST_COST_CONTRACT) ==|
1871 |     +                 CONTRACT_FIXED_COST(CONTRACT) .AND.|
1872 |     +                      CNTR_CAPACITY_SWITCH(CONTRACT) == 'V') CYCLE|
1873 |               IF(LOWEST_VARIABLE_COST /= CURRENT_VARIABLE_COST .AND.|
1874 |     +                                AVAILABLE_CONTRACT(CONTRACT) .AND.|
1875 |     +                            CONTRACT /= LOWEST_COST_CONTRACT .AND.|
1876 |     +                       CNTR_CAPACITY_SWITCH(CONTRACT) /= "E") THEN|
