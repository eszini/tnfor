2666 |      SUBROUTINE SHADOW_FUEL_INVENTORY(ENERGY,MMBTU_FUEL_BALANCE,|
2667 |     +                                 EA,COEFF,HEAT_RATE_FACTOR,|
2668 |     +                                 SEAS_HOURS,B,A,|
2669 |     +                                 LEFT,RIGHT,|
2670 |     +                                 AVAILABLE_SHADOW_CAPACITY,|
2671 |     +                                 MWBLOK,LODDUR,LPROB,|
2672 |     +                                 BLENDING_RATE,|
2673 |     +                                 SEC_BTU_COST)|
2674 |!|
2675 |      REAL ::  EA|
2676 |      REAL ::  COEFF|
2677 |      REAL ::  HEAT_RATE_FACTOR|
2678 |      REAL ::  SEAS_HOURS|
2679 |      REAL ::  GET_HEAT_CONVERSION|
2680 |      REAL ::  ENERGY|
2681 |      REAL ::  B|
2682 |      REAL ::  A|
2683 |      REAL ::  LEFT|
2684 |      REAL ::  RIGHT|
2685 |      REAL ::  AVAILABLE_SHADOW_CAPACITY|
2686 |      REAL :: ADJUSTED_ENERGY,B_ADJUSTED,MWBLOK,SEC_BTU_COST|
2687 |      REAL :: LODDUR(*),LPROB(*),BLENDING_RATE|
2688 |      REAL (kind=8) ::   DBLE_TEMP,HEAT,MMBTU_FUEL_BALANCE|
2689 |!|
2690 |      DBLE_TEMP = DBLE((EA * COEFF * HEAT_RATE_FACTOR * SEAS_HOURS)/|
2691 |     +                         GET_HEAT_CONVERSION())|
2692 |      HEAT = DBLE_TEMP * DBLE(ENERGY * (1. - BLENDING_RATE))|
2693 |      IF(HEAT <= MMBTU_FUEL_BALANCE) THEN|
2694 |         MMBTU_FUEL_BALANCE = MMBTU_FUEL_BALANCE - HEAT|
2695 |         AVAILABLE_SHADOW_CAPACITY = 0.|
2696 |      ELSE|
2697 |         HEAT = MMBTU_FUEL_BALANCE/(DBLE_TEMP*DBLE(1. - BLENDING_RATE))|
2698 |         ADJUSTED_ENERGY = SNGL(HEAT)|
2699 |         IF(A + ADJUSTED_ENERGY <= LODDUR(1)) THEN|
2700 |            B_ADJUSTED = A + ADJUSTED_ENERGY|
2701 |            RIGHT = 1.|
2702 |         ELSEIF(ABS(LEFT - RIGHT) < .0001) THEN|
2703 |            B_ADJUSTED = A + ADJUSTED_ENERGY/LEFT|
2704 |         ELSE|
2705 |!|
2706 |! FIND THE INCREMENT THAT HAS THE ENERGY CROSS-OVER|
2707 |!|
2708 |            CALL FIND_ENRGY_CROSSOVER(A,LEFT,ADJUSTED_ENERGY,LODDUR,|
2709 |     +                                LPROB,B_ADJUSTED,RIGHT)|
2710 |         ENDIF|
2711 |         AVAILABLE_SHADOW_CAPACITY = (B - B_ADJUSTED)*MWBLOK/(B-A)|
2712 |         MWBLOK = MWBLOK - AVAILABLE_SHADOW_CAPACITY|
2713 |         MMBTU_FUEL_BALANCE = 0.|
2714 |         ENERGY = ADJUSTED_ENERGY|
2715 |         B = B_ADJUSTED|
2716 |         IF(SEC_BTU_COST == 0.) AVAILABLE_SHADOW_CAPACITY = 0.|
2717 |      ENDIF|
2718 |      RETURN|
2719 |      END SUBROUTINE SHADOW_FUEL_INVENTORY|
