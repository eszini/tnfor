i:  7039  |      SUBROUTINE SHADOW_FUEL_INVENTORY(ENERGY,MMBTU_FUEL_BALANCE,| 
i:  7040  |     +                                 EA,COEFF,HEAT_RATE_FACTOR,| 
i:  7041  |     +                                 SEAS_HOURS,B,A,| 
i:  7042  |     +                                 LEFT,RIGHT,| 
i:  7043  |     +                                 AVAILABLE_SHADOW_CAPACITY,| 
i:  7044  |     +                                 MWBLOK,LODDUR,LPROB,| 
i:  7045  |     +                                 BLENDING_RATE,| 
i:  7046  |     +                                 SEC_BTU_COST)| 
i:  7047  |!| 
i:  7048  |      REAL ::  EA| 
i:  7049  |      REAL ::  COEFF| 
i:  7050  |      REAL ::  HEAT_RATE_FACTOR| 
i:  7051  |      REAL ::  SEAS_HOURS| 
i:  7052  |      REAL ::  GET_HEAT_CONVERSION| 
i:  7053  |      REAL ::  ENERGY| 
i:  7054  |      REAL ::  B| 
i:  7055  |      REAL ::  A| 
i:  7056  |      REAL ::  LEFT| 
i:  7057  |      REAL ::  RIGHT| 
i:  7058  |      REAL ::  AVAILABLE_SHADOW_CAPACITY| 
i:  7059  |      REAL :: ADJUSTED_ENERGY,B_ADJUSTED,MWBLOK,SEC_BTU_COST| 
i:  7060  |      REAL :: LODDUR(*),LPROB(*),BLENDING_RATE| 
i:  7061  |      REAL (kind=8) ::   DBLE_TEMP,HEAT,MMBTU_FUEL_BALANCE| 
i:  7062  |!| 
i:  7063  |      DBLE_TEMP = DBLE((EA * COEFF * HEAT_RATE_FACTOR * SEAS_HOURS)/| 
i:  7064  |     +                         GET_HEAT_CONVERSION())| 
i:  7065  |      HEAT = DBLE_TEMP * DBLE(ENERGY * (1. - BLENDING_RATE))| 
i:  7066  |      IF(HEAT <= MMBTU_FUEL_BALANCE) THEN| 
i:  7067  |         MMBTU_FUEL_BALANCE = MMBTU_FUEL_BALANCE - HEAT| 
i:  7068  |         AVAILABLE_SHADOW_CAPACITY = 0.| 
i:  7069  |      ELSE| 
i:  7070  |         HEAT = MMBTU_FUEL_BALANCE/(DBLE_TEMP*DBLE(1. - BLENDING_RATE))| 
i:  7071  |         ADJUSTED_ENERGY = SNGL(HEAT)| 
i:  7072  |         IF(A + ADJUSTED_ENERGY <= LODDUR(1)) THEN| 
i:  7073  |            B_ADJUSTED = A + ADJUSTED_ENERGY| 
i:  7074  |            RIGHT = 1.| 
i:  7075  |         ELSEIF(ABS(LEFT - RIGHT) < .0001) THEN| 
i:  7076  |            B_ADJUSTED = A + ADJUSTED_ENERGY/LEFT| 
i:  7077  |         ELSE| 
i:  7078  |!| 
i:  7079  |! FIND THE INCREMENT THAT HAS THE ENERGY CROSS-OVER| 
i:  7080  |!| 
i:  7081  |            CALL FIND_ENRGY_CROSSOVER(A,LEFT,ADJUSTED_ENERGY,LODDUR,| 
i:  7082  |     +                                LPROB,B_ADJUSTED,RIGHT)| 
i:  7083  |         ENDIF| 
i:  7084  |         AVAILABLE_SHADOW_CAPACITY = (B - B_ADJUSTED)*MWBLOK/(B-A)| 
i:  7085  |         MWBLOK = MWBLOK - AVAILABLE_SHADOW_CAPACITY| 
i:  7086  |         MMBTU_FUEL_BALANCE = 0.| 
i:  7087  |         ENERGY = ADJUSTED_ENERGY| 
i:  7088  |         B = B_ADJUSTED| 
i:  7089  |         IF(SEC_BTU_COST == 0.) AVAILABLE_SHADOW_CAPACITY = 0.| 
i:  7090  |      ENDIF| 
i:  7091  |      RETURN| 
i:  7092  |      END SUBROUTINE SHADOW_FUEL_INVENTORY| 
