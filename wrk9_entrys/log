2748 |      ENERGY_EXCEEDED_AT_FIRST_PASS = .FALSE.|
2749 |      IF(A > BASE) THEN|
2750 |         INCREMENTAL_ENERGY = (LODDUR(ISTART)-A)*(LPROB(ISTART)+LEFT)/2.|
2751 |         ENERGY = ENERGY + INCREMENTAL_ENERGY|
2752 |         IF(ENERGY > TARGET_ENERGY) ENERGY_EXCEEDED_AT_FIRST_PASS =|
2753 |     +                                                            .TRUE.|
2754 |      ENDIF|
2755 |      I = ISTART|
2756 |      DOWHILE (ENERGY < TARGET_ENERGY)|
2757 |         INCREMENTAL_ENERGY =(LPROB(I) + LPROB(I+1)) *|
2758 |     +                                      (LODDUR(I+1) - LODDUR(I))/2.|
2759 |         ENERGY = ENERGY + INCREMENTAL_ENERGY|
2760 |         I = I + 1|
2761 |      ENDDO|
2762 |      ENERGY = ENERGY - INCREMENTAL_ENERGY|
2763 |      I = MAX(ISTART,I - 1)|
2764 |      IF(ENERGY_EXCEEDED_AT_FIRST_PASS) THEN|
2765 |         CALL FIND_MAXIMUM_ENERGY(A,LODDUR(I),|
2766 |     +                         LEFT,LPROB(I),ENERGY,|
2767 |     +                         TARGET_ENERGY,B_ADJUSTED,RIGHT)|
2768 |      ELSE|
2769 |         CALL FIND_MAXIMUM_ENERGY(LODDUR(I),LODDUR(I+1),|
2770 |     +                         LPROB(I),LPROB(I+1),ENERGY,|
2771 |     +                         TARGET_ENERGY,B_ADJUSTED,RIGHT)|
2772 |      ENDIF|
2773 |      RETURN|
