1602 |     +         CONTRACT_ENERGY(LOWEST_COST_CONTRACT) - SURPLUS_ENERGY)|
1603 |         TOTAL_CONTRACT_ENRG = TOTAL_CONTRACT_ENRG +|
1604 |     +                           CONTRACT_ENERGY(LOWEST_COST_CONTRACT) -|
1605 |     +                           CURRENT_CONTRACT_ENERGY|
1606 |      ENDIF|
1607 |      IF(AVAILABLE_CONTRACT_NO .EQ. 0) CONTRACTS_ACTIVE = .FALSE.|
1608 |      RETURN|
1609 |      END|
