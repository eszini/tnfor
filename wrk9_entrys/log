i:  1819  |     +                   PURCH_CRED_PRICE,SELL_CRED_PRICE,EMIS_STRAT,| 
i:  1820  |     +                   MIN_BANK,MAX_BANK,EPA_EAS,EPA_SETASIDE_RATE,| 
