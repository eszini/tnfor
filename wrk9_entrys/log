i:  7534  || 
i:  7535  |      LOGICAL (kind=1) ::   FOUND_THIS_MONTH_FORECAST| 
i:  7536  |      LOGICAL (kind=1) ::   GET_THIS_MONTH_CLASS_FORECAST| 
i:  7537  |      INTEGER (kind=2) ::   GIB| 
i:  7538  |      INTEGER (kind=2) ::   ISEAS,UNITNO,ARRAY_POINTR,PSI_CLASS_NUMBER| 
i:  7539  |      REAL ::  PSI_LDC| 
i:  7540  |      REAL ::  PSI_ENERGY_DEMAND| 
i:  7541  |      REAL ::  PSI_PEAK_DEMAND| 
i:  7542  |      REAL ::  PSI_BASE_DEMAND| 
i:  7543  |      REAL ::  GIB5_CAP| 
i:  7544  |      REAL ::  GIB5_ENERGY| 
i:  7545  |      REAL ::  GIBSON_BLOCK1_ENERGY| 
i:  7546  |      REAL ::  GIBSON_BLOCK2_ENERGY| 
i:  7547  |      REAL ::  GIBSON_TOTAL_ENERGY| 
i:  7548  |      REAL ::  BLK_MW| 
i:  7549  |      REAL ::  SEAS_HOURS| 
i:  7550  |      REAL ::  FORECAST_DSM_ENERGY(MAX_LOAD_CLASSES)| 
i:  7551  |      REAL ::  THIS_MONTH_ENERGY| 
i:  7552  |      REAL ::  THIS_MONTH_PEAK| 
i:  7553  |!| 
i:  7554  |! ADDED 9/1/94. GAT.| 
i:  7555  |!| 
i:  7556  |         CALL GET_CLASS_DSM_ENERGY_ALLOC(ISEAS,FORECAST_DSM_ENERGY)| 
i:  7557  |!| 
i:  7558  |         PSI_CLASS_NUMBER = 3| 
i:  7559  |         FOUND_THIS_MONTH_FORECAST = GET_THIS_MONTH_CLASS_FORECAST(| 
i:  7560  |     +                                    ISEAS,| 
i:  7561  |     +                                    PSI_CLASS_NUMBER,| 
i:  7562  |     +                                    THIS_MONTH_ENERGY,| 
i:  7563  |     +                                    THIS_MONTH_PEAK)| 
i:  7564  |!| 
i:  7565  |         PSI_ENERGY_DEMAND =(THIS_MONTH_ENERGY +| 
i:  7566  |     +                       FORECAST_DSM_ENERGY(PSI_CLASS_NUMBER))/| 
i:  7567  |     +                                                        SEAS_HOURS| 
i:  7568  |         PSI_PEAK_DEMAND = THIS_MONTH_PEAK ! ASSUMES MONTHLY PRODUCTION| 
i:  7569  |         PSI_BASE_DEMAND = MAX(0.,| 
i:  7570  |     +                           2.*PSI_ENERGY_DEMAND - PSI_PEAK_DEMAND)| 
i:  7571  |         DO GIB = 1 , 2| 
i:  7572  |            IF(GIB == 1) THEN ! CALCULATE TOTAL GIBSON ENERGY| 
i:  7573  |               GIB5_CAP = MW(2,UNITNO) *| 
i:  7574  |     +                   (1.-AREA_CAPACITY_LOSSES(3,ISEAS,ARRAY_POINTR))| 
i:  7575  |            ELSE| 
i:  7576  |               GIB5_CAP = BLK_MW| 
i:  7577  |            ENDIF| 
i:  7578  |            IF(GIB5_CAP <= PSI_BASE_DEMAND) THEN| 
i:  7579  |               GIB5_ENERGY = GIB5_CAP| 
i:  7580  |            ELSE| 
i:  7581  |               IF(GIB5_CAP > PSI_PEAK_DEMAND) GIB5_CAP = PSI_PEAK_DEMAND| 
i:  7582  |               PSI_LDC = (PSI_PEAK_DEMAND - GIB5_CAP)/| 
i:  7583  |     +                               (PSI_PEAK_DEMAND - PSI_BASE_DEMAND)| 
i:  7584  |               GIB5_ENERGY = PSI_BASE_DEMAND + (1. + PSI_LDC) *| 
i:  7585  |     +                                   (GIB5_CAP - PSI_BASE_DEMAND)/2.| 
i:  7586  |            ENDIF| 
i:  7587  |            IF(GIB == 1) THEN| 
i:  7588  |               GIBSON_TOTAL_ENERGY = GIB5_ENERGY| 
i:  7589  |            ELSE| 
i:  7590  |               GIBSON_BLOCK1_ENERGY = GIB5_ENERGY| 
i:  7591  |            ENDIF| 
i:  7592  |         ENDDO| 
i:  7593  |         GIBSON_BLOCK2_ENERGY = GIBSON_TOTAL_ENERGY-GIBSON_BLOCK1_ENERGY| 
i:  7594  |      RETURN| 
i:  7595  |      END SUBROUTINE GET_GIBSON5_ENERGY| 
