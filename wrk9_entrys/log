i:  3712  |         DO I4 = -1, MAXIMUM_VECTORS| 
i:  3713  |            IF(VECTOR_TYPE_IS_VALUE(I4)) THEN| 
i:  3714  |               IF(INTO_EXTENSION_PERIOD) THEN| 
i:  3715  |                  ACTIVE_VECTOR_VALUES(I4) = 1. + VECTOR_VALUES(YR,I4)| 
i:  3716  |               ELSE| 
i:  3717  |                  ACTIVE_VECTOR_VALUES(I4) = VECTOR_VALUES(YR,I4) | 
i:  3718  |               ENDIF| 
i:  3719  |            ELSE| 
i:  3720  |               ACTIVE_VECTOR_VALUES(I4) = 1. + VECTOR_VALUES(YR,I4)| 
