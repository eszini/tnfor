268 |      INTEGER (kind=2) ::  I,UNITNO|
269 |      REAL ::  BASE,CAPBLK,CHKVAL|
270 |      REAL ::  MAINTENANCE_RATE(MAX_CL_UNITS)|
271 |!|
272 |      CHKVAL = MWBLOK(1) * (1. - MAINTENANCE_RATE(UNIT(1)))|
273 |      DO I = 2, NBLOCK|
274 |         IF(CHKVAL .GT. BASE) EXIT|
275 |         UNITNO = UNIT(I)|
276 |         CAPBLK = MWBLOK(I) * (1. - MAINTENANCE_RATE(UNITNO))|
277 |         CHKVAL = CHKVAL + CAPBLK|
278 |         IF(BLKNO(I).EQ.2 .AND. UNIT(I-1) .NE. UNITNO) CALL MOVE_UNIT(I)|
279 |      ENDDO|
280 |      RETURN|
281 |      END|
