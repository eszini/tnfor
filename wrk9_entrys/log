i:  9941  |         ENDIF| 
i:  9942  |!| 
i:  9943  |!     LOAD THE LOWEST_COST_CONTRACT INTO THE ELDC, UNTIL EITHER:| 
i:  9944  |!| 
i:  9945  |!        (1) MAXIMUM_ENERGY IS VIOLATED, OR| 
i:  9946  |!        (2) MAXIMUM_CAPACITY IS VIOLATED, OR| 
i:  9947  |!        (3) ANOTHER CONTRACT IS LOWEST_COST, OR| 
i:  9948  |!        (4) THE NEXT CL UNIT IS LOWEST_COST| 
i:  9949  |!        (5) CONTRACTS EVALUATED BEYOND THE END OF THE NEXT CL UNIT| 
i:  9950  |!| 
i:  9951  |!     CONSTRAINT (1) IS TESTED INSIDE CONTRACT_ENERGY.| 
i:  9952  |!     CONSTRAINTS 2-5 ARE CAPACITY CONSTRAINTS.  THE MINIMUM OF THE| 
i:  9953  |!     FOUR IS BINDING.| 
i:  9954  |!| 
i:  9955  |!| 
i:  9956  |!     MAXIMUM_CAPACITY PROB - CONSTRAINT (2) (INPUT ASSUMPTION)| 
i:  9957  |!| 
i:  9958  |!        NO CALCULATION NECESSARY. KEEP IN MW'S UNITS.| 
i:  9959  |!| 
i:  9960  |!     NEXT BEST CONTRACT PROBABILITY - CONSTRAINT (3)| 
i:  9961  |!| 
i:  9962  |         FIXED_COST_FACTOR =| 
i:  9963  |     +                    (12.*1000./(HOURS*RIGHT*| 
i:  9964  |     +                                     PRODUCTION_COST_PERIODS))*10.| 
i:  9965  |!| 
i:  9966  |         IF(CNTR_CAPACITY_SWITCH(LOWEST_COST_CONTRACT) .EQ. 'V') THEN| 
i:  9967  |            FIX_LOWEST = 12*1000*| 
i:  9968  |     +                  CONTRACT_FIXED_COST(LOWEST_COST_CONTRACT)/| 
i:  9969  |     +                  (HOURS*PRODUCTION_COST_PERIODS)| 
i:  9970  |            CROSSOVER_COST = 999999.| 
i:  9971  |            CONTRACT_CROSSOVER_PROB = 0.0000001| 
i:  9972  |            DO CONTRACT = 1, NUMBER_OF_CONTRACTS| 
i:  9973  |               LOWEST_VARIABLE_COST =| 
i:  9974  |     +                    CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT) +| 
i:  9975  |     +                        CT_ENERGY_COST_ADDER(LOWEST_COST_CONTRACT)| 
i:  9976  |               CURRENT_VARIABLE_COST=CONTRACT_VARIABLE_COST(CONTRACT) +| 
i:  9977  |     +                                    CT_ENERGY_COST_ADDER(CONTRACT)| 
i:  9978  |!| 
i:  9979  |! MARK QUESTIONS: SHOULD THE ADDER BE IN THIS| 
i:  9980  |!| 
i:  9981  |! UPDATE: 9/8/94. GAT.| 
i:  9982  |               IF( CONTRACT_FIXED_COST(LOWEST_COST_CONTRACT) ==| 
i:  9983  |     +                 CONTRACT_FIXED_COST(CONTRACT) .AND.| 
i:  9984  |     +                      CNTR_CAPACITY_SWITCH(CONTRACT) == 'V') CYCLE| 
i:  9985  |               IF(LOWEST_VARIABLE_COST /= CURRENT_VARIABLE_COST .AND.| 
i:  9986  |     +                                AVAILABLE_CONTRACT(CONTRACT) .AND.| 
i:  9987  |     +                            CONTRACT /= LOWEST_COST_CONTRACT .AND.| 
i:  9988  |     +                       CNTR_CAPACITY_SWITCH(CONTRACT) /= "E") THEN| 
i:  9989  |!| 
i:  9990  |!              FIND THE POINT WHERE THE CURRENT CONTRACT INTERSECTS THE| 
i:  9991  |!              LOWEST COST CONTRACT.| 
i:  9992  |!| 
i:  9993  |                  IF(CNTR_CAPACITY_SWITCH(CONTRACT) .EQ. 'V') THEN| 
i:  9994  |                     TEMP_FIX_CURRENT = 12.*1000.*| 
i:  9995  |     +                  CONTRACT_FIXED_COST(CONTRACT)/| 
i:  9996  |     +                  (HOURS*PRODUCTION_COST_PERIODS)| 
i:  9997  |                  ELSE| 
i:  9998  |                     TEMP_FIX_CURRENT = 0.| 
i:  9999  |                  ENDIF| 
i: 10000  |!| 
i: 10001  |! MARK QUESTIONS: SHOULD THE ADDER BE IN THIS| 
i: 10002  |!| 
i: 10003  |                  TEMP_CROSSOVER_COST =| 
i: 10004  |     +               (LOWEST_VARIABLE_COST * TEMP_FIX_CURRENT -| 
i: 10005  |     +                           CURRENT_VARIABLE_COST * FIX_LOWEST ) /| 
i: 10006  |     +               (TEMP_FIX_CURRENT - FIX_LOWEST)| 
i: 10007  |                  TEMP_CROSSOVER_PROB = (FIX_LOWEST - TEMP_FIX_CURRENT)/| 
i: 10008  |     +                        (CURRENT_VARIABLE_COST -| 
i: 10009  |     +                                             LOWEST_VARIABLE_COST)| 
i: 10010  |                  IF(TEMP_CROSSOVER_COST  < CROSSOVER_COST .AND.| 
i: 10011  |     +                  TEMP_CROSSOVER_PROB+.0001 .LT. RIGHT .AND.| 
i: 10012  |     +                  TEMP_CROSSOVER_PROB+.0001 .GT. 0.0 .AND.| 
i: 10013  |     +                  TEMP_CROSSOVER_COST .GT. 0.) THEN| 
i: 10014  |!| 
i: 10015  |!| 
i: 10016  |                     FIXED_COST_FACTOR =| 
i: 10017  |     +                    (12.*1000./(HOURS*RIGHT*| 
i: 10018  |     +                                     PRODUCTION_COST_PERIODS))*10.| 
i: 10019  |                     IF(CNTR_CAPACITY_SWITCH(CONTRACT) .EQ. 'V') THEN| 
i: 10020  |                        NEXT_LOWEST_TOTAL_COST =| 
i: 10021  |     +                     10.*CONTRACT_VARIABLE_COST(CONTRACT) +| 
i: 10022  |     +                               CONTRACT_FIXED_COST(CONTRACT) *| 
i: 10023  |     +                                                 FIXED_COST_FACTOR| 
