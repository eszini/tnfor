284 |      SUBROUTINE MOVE_UNIT(I)|
285 |      use SpinDriftLib|
286 |      use prod_arrays_dimensions|
287 |      use mwunih|
288 |      USE SIZECOM|
289 |      use prodcom|
290 ||
291 ||
292 |      INTEGER (kind=2) ::  I,J,L|
293 |      INTEGER (kind=2) ::  ITEMPUN,ITEMPBK|
294 |      REAL ::  RTEMPIHR,RTEMPMW|
295 |      DO J = 1, I-2|
296 |         IF(UNIT(J) .EQ. UNIT(I)) THEN|
297 |            RTEMPMW = MWBLOK(J)|
298 |            ITEMPUN = UNIT(J)|
299 |            ITEMPBK = BLKNO(J)|
300 |            RTEMPIHR = INHEAT(J)|
301 |            DO L = J, I-2|
302 |               MWBLOK(L) = MWBLOK(L+1)|
303 |               UNIT(L) = UNIT(L+1)|
304 |               BLKNO(L) = BLKNO(L+1)|
305 |               INHEAT(L) = INHEAT(L+1)|
306 |            ENDDO|
307 |            MWBLOK(I-1) = RTEMPMW|
308 |            UNIT(I-1) = ITEMPUN|
309 |            BLKNO(I-1) = ITEMPBK|
310 |            INHEAT(I-1) = RTEMPIHR|
311 |            RETURN|
312 |         ENDIF|
313 |      ENDDO|
314 |      RETURN|
