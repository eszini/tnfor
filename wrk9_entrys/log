714 |C***********************************************************************|
715 |      SUBROUTINE CALCULATE_CLASS_PEAKS(IYR,CLASS_COIN_LOSS_FACTOR,|
716 |     +                         CLSMW1,CLSMW2,CLASS,CONTRIBUTES_TO_TOTAL)|
717 |C***********************************************************************|
718 |C|
719 |      USE SIZECOM|
720 |      INCLUDE 'SpinLib.MON'|
721 |      REAL CLASS_COIN_LOSS_FACTOR,CLSMW1(*),CLSMW2(*)|
722 |      REAL PLANNING_PEAK,CLASS_PEAK,R_PEAK|
723 |      INTEGER*2 IYR,MO,YEAR,CLASS,TOTAL_CLASSES,PEAK_MONTH,PEAK_DAY,|
724 |     +            R_CLASS,R_YR,R_MONTH,MAX_CLASS/7/,MIN_CLASS/1/|
725 |      LOGICAL*1 FIRST_CLASS/.TRUE./|
726 |C SYSTEM PEAK VARIABLES|
727 |      REAL PEAKS(12,2),SYS_FC_DATA(*),REAL_TEMP,R_CLASS_PEAK|
728 |      REAL STORE_ANNUAL_PEAK_AND_MONTH|
729 |      INTEGER*2 MO_OFFSET|
730 |C|
731 |C INCLUDE COMMON BLOCK OF YEARLY SYSTEM FORECAST STATISTICS|
732 |C|
733 |      REAL FYREGY(AVAIL_DATA_YEARS),FYRPK(AVAIL_DATA_YEARS)|
734 |      COMMON/FRC2/ FYREGY,FYRPK|
735 |C VARIBLES FOR CAPACITY PLANNING PEAKS|
736 |      INTEGER*1 FORECAST_GROWTH_YEARS|
737 |      PARAMETER (FORECAST_GROWTH_YEARS = AVAIL_DATA_YEARS)|
738 |      REAL SUM_CLASS_PEAKS(:,:,:,:),CLASS_ANN_COIN_PEAK(:,:)|
739 |      LOGICAL*1 CONTRIBUTES_TO_TOTAL|
740 |      ALLOCATABLE SUM_CLASS_PEAKS,CLASS_ANN_COIN_PEAK|
741 |      REAL CLASS_GROWTH_TRIGGER,CLASS_GROWTH_TRIGGER_LEVEL|
742 |      REAL SYS_GROWTH_TRIGGER,SYS_GROWTH_TRIGGER_LEVEL|
743 |      SAVE SUM_CLASS_PEAKS,PEAKS,CLASS_ANN_COIN_PEAK|
744 |C|
745 |      TOTAL_CLASSES = MAX_LOAD_CLASSES + 1|
746 |C     FORECAST_GROWTH_YEARS = AVAIL_DATA_YEARS|
747 |      IF(IYR == 1 .AND. FIRST_CLASS) THEN|
748 |         IF(ALLOCATED(SUM_CLASS_PEAKS)) DEALLOCATE(SUM_CLASS_PEAKS)|
749 |         ALLOCATE(SUM_CLASS_PEAKS(12,2,FORECAST_GROWTH_YEARS,|
750 |     +                                                   TOTAL_CLASSES))|
751 |         SUM_CLASS_PEAKS = 0.|
752 |         IF(ALLOCATED(CLASS_ANN_COIN_PEAK))|
753 |     +                                   DEALLOCATE(CLASS_ANN_COIN_PEAK)|
754 |         ALLOCATE(CLASS_ANN_COIN_PEAK(MAX_LOAD_CLASSES,|
755 |     +                                           FORECAST_GROWTH_YEARS))|
756 |         CLASS_ANN_COIN_PEAK = 0.|
757 |         FIRST_CLASS = .FALSE.|
758 |      ENDIF|
759 |      CLASS_GROWTH_TRIGGER_LEVEL = CLASS_GROWTH_TRIGGER()|
760 |      DO MO = 1, 12|
761 |         IF(IYR == 1) THEN|
762 |            PEAKS(MO,1) = CLSMW1(MO)|
763 |            PEAKS(MO,2) = CLSMW2(MO)|
764 |         ELSE|
765 |            CLASS_PEAK = CLSMW1(MO)|
766 |            IF(CLASS_PEAK <= CLASS_GROWTH_TRIGGER_LEVEL) THEN|
767 |               PEAKS(MO,1) = (1.+CLASS_PEAK/100.) * PEAKS(MO,1)|
768 |            ELSE|
769 |               PEAKS(MO,1) = CLSMW1(MO)|
770 |            ENDIF|
771 |            CLASS_PEAK = CLSMW2(MO)|
772 |            IF(CLASS_PEAK <= CLASS_GROWTH_TRIGGER_LEVEL) THEN|
773 |               PEAKS(MO,2) = (1.+CLASS_PEAK/100.) * PEAKS(MO,2)|
774 |            ELSE|
775 |               PEAKS(MO,2) = CLSMW2(MO)|
776 |            ENDIF|
777 |         ENDIF|
778 |!         |
779 |! ADDED 2/11/98. GAT. LARRY KEY, SRP|
780 |!|
781 |         IF(CLASS < MIN_CLASS .OR. CLASS > MAX_CLASS) THEN|
782 |            WRITE(4,*) "A class forecast file contains class"|
783 |            WRITE(4,*) "number ",CLASS," In year ",IYR|
784 |            WRITE(4,*) "It has been reassigned to Class=1."|
785 |            CLASS = 1|
786 |         ENDIF|
787 |!         |
788 |         IF(CONTRIBUTES_TO_TOTAL) THEN|
789 |C         |
790 |            SUM_CLASS_PEAKS(MO,1,IYR,CLASS) = |
791 |     +                 SUM_CLASS_PEAKS(MO,1,IYR,CLASS) +|
792 |     +                                PEAKS(MO,1)*CLASS_COIN_LOSS_FACTOR|
793 |            SUM_CLASS_PEAKS(MO,2,IYR,CLASS) = |
794 |     +                 SUM_CLASS_PEAKS(MO,2,IYR,CLASS) +|
795 |     +                                PEAKS(MO,2)*CLASS_COIN_LOSS_FACTOR|
796 |C     |
797 |            SUM_CLASS_PEAKS(MO,1,IYR,TOTAL_CLASSES) = |
798 |     +                 SUM_CLASS_PEAKS(MO,1,IYR,TOTAL_CLASSES) +|
799 |     +                                PEAKS(MO,1)*CLASS_COIN_LOSS_FACTOR|
800 |            SUM_CLASS_PEAKS(MO,2,IYR,TOTAL_CLASSES) = |
801 |     +                 SUM_CLASS_PEAKS(MO,2,IYR,TOTAL_CLASSES) +|
802 |     +                                PEAKS(MO,2)*CLASS_COIN_LOSS_FACTOR|
803 |         ENDIF|
804 |C     |
805 |      ENDDO|
806 |      RETURN|
807 |C|
808 |C***********************************************************************|
809 |      ENTRY FIND_AND_STORE_SYSTEM_PEAKS|
810 |C***********************************************************************|
811 |C|
812 |         DO YEAR = 1, FORECAST_GROWTH_YEARS|
813 |            CLASS_PEAK = 0.|
814 |            PEAK_MONTH = 0|
815 |            PEAK_DAY = 0|
816 |            DO MO = 1, 12|
817 |               IF(CLASS_PEAK > |
818 |     +             MAX(SUM_CLASS_PEAKS(MO,1,YEAR,TOTAL_CLASSES),|
819 |     +                  SUM_CLASS_PEAKS(MO,2,YEAR,TOTAL_CLASSES))) CYCLE|
820 |               PEAK_MONTH = MO|
821 |               IF(SUM_CLASS_PEAKS(MO,1,YEAR,TOTAL_CLASSES) >|
822 |     +                    SUM_CLASS_PEAKS(MO,2,YEAR,TOTAL_CLASSES)) THEN|
823 |                  PEAK_DAY = 1|
824 |               ELSE|
825 |                  PEAK_DAY = 2|
826 |               ENDIF|
827 |               CLASS_PEAK = |
828 |     +           SUM_CLASS_PEAKS(PEAK_MONTH,PEAK_DAY,YEAR,TOTAL_CLASSES)|
829 |            ENDDO|
830 |            PLANNING_PEAK = STORE_ANNUAL_PEAK_AND_MONTH(PEAK_MONTH,YEAR,|
831 |     +                                                       CLASS_PEAK)|
832 |            DO CLASS = 1 , MAX_LOAD_CLASSES|
833 |               CLASS_ANN_COIN_PEAK(CLASS,YEAR) = |
834 |     +                   SUM_CLASS_PEAKS(PEAK_MONTH,PEAK_DAY,YEAR,CLASS)|
835 |            ENDDO|
836 |         ENDDO|
837 |      RETURN|
838 |C      |
839 |C***********************************************************************|
840 |      ENTRY DEALLOCATE_SUM_CLASS_PEAKS|
841 |C***********************************************************************|
842 |         IF(ALLOCATED(SUM_CLASS_PEAKS)) DEALLOCATE(SUM_CLASS_PEAKS)|
843 |      RETURN|
844 |C***********************************************************************|
845 |      ENTRY GET_CLASS_PEAK_FOR_CAPACITY(R_CLASS,R_YR,R_CLASS_PEAK)|
846 |C***********************************************************************|
847 |         R_CLASS_PEAK = CLASS_ANN_COIN_PEAK(R_CLASS,R_YR)         |
848 |      RETURN|
849 |C***********************************************************************|
850 |      ENTRY CALCULATE_SYSTEM_PEAKS(SYS_FC_DATA,IYR)|
851 |C***********************************************************************|
852 |C|
853 |         IF(IYR == 1 .AND. FIRST_CLASS) THEN|
854 |            IF(ALLOCATED(SUM_CLASS_PEAKS)) DEALLOCATE(SUM_CLASS_PEAKS)|
855 |            ALLOCATE(SUM_CLASS_PEAKS(12,2,FORECAST_GROWTH_YEARS,1))|
856 |            SUM_CLASS_PEAKS = 0.|
857 |            FIRST_CLASS = .FALSE.|
858 |         ENDIF|
859 |C|
860 |         PLANNING_PEAK = 0.|
861 |         SYS_GROWTH_TRIGGER_LEVEL = SYS_GROWTH_TRIGGER()|
862 |         DO MO = 1, 12|
863 |            MO_OFFSET = 4*(MO-1)|
864 |            IF(IYR == 1) THEN|
865 |               PEAKS(MO,1) = SYS_FC_DATA(MO_OFFSET+2)|
866 |               PEAKS(MO,2) = SYS_FC_DATA(MO_OFFSET+4)|
867 |            ELSE|
868 |               REAL_TEMP = SYS_FC_DATA(MO_OFFSET+2)|
869 |               IF(REAL_TEMP <= SYS_GROWTH_TRIGGER_LEVEL) THEN|
870 |                  PEAKS(MO,1) = (1. + REAL_TEMP/100.) * PEAKS(MO,1)|
871 |               ELSE|
872 |                  PEAKS(MO,1) = REAL_TEMP|
873 |               ENDIF|
874 |               REAL_TEMP = SYS_FC_DATA(MO_OFFSET+4)|
875 |               IF(REAL_TEMP <= SYS_GROWTH_TRIGGER_LEVEL) THEN|
876 |                  PEAKS(MO,2) = (1. + REAL_TEMP/100.) * PEAKS(MO,2)|
877 |               ELSE|
878 |                  PEAKS(MO,2) = REAL_TEMP|
879 |               ENDIF|
880 |            ENDIF|
881 |            IF(MAX(PEAKS(MO,1),PEAKS(MO,2)) >= PLANNING_PEAK) THEN|
882 |               PLANNING_PEAK = STORE_ANNUAL_PEAK_AND_MONTH(MO,IYR,|
883 |     +                                     MAX(PEAKS(MO,1),PEAKS(MO,2)))|
884 |            ENDIF|
885 |            SUM_CLASS_PEAKS(MO,1,IYR,1) = SUM_CLASS_PEAKS(MO,1,IYR,1) +|
886 |     +                                                       PEAKS(MO,1)|
887 |            SUM_CLASS_PEAKS(MO,2,IYR,1) = SUM_CLASS_PEAKS(MO,2,IYR,1) +|
888 |     +                                                       PEAKS(MO,2)|
889 |         ENDDO|
890 |      RETURN|
891 |C***********************************************************************|
892 |      ENTRY SET_FIRST_CLASS_TRUE|
893 |C***********************************************************************|
894 |        FIRST_CLASS = .TRUE.|
