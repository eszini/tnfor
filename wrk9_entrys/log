i:  7525  |     +                              GIBSON_BLOCK2_ENERGY,SEAS_HOURS,| 
i:  7526  |     +                              ISEAS,UNITNO,BLK_MW,ARRAY_POINTR)| 
i:  7527  |!**********************************************************************| 
i:  7528  |      use SpinDriftLib| 
i:  7529  |      use prod_arrays_dimensions| 
i:  7530  |      use kepcocom| 
i:  7531  |      USE SIZECOM| 
