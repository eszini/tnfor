i:  8257  |      SUBROUTINE LOLP_ANALYSIS(CAPACITY,LPROB,LODDUR)| 
i:  8258  |!| 
i:  8259  |      use SpinDriftLib| 
i:  8260  |      use prod_arrays_dimensions| 
i:  8261  |      USE IREC_ENDPOINT_CONTROL| 
i:  8262  |      use grx_planning_routines| 
i:  8263  || 
i:  8264  |      REAL ::  CAPACITY,LPROB(*),LODDUR(*),ELDC_Y_AXIS_VALUE| 
i:  8265  |      INTEGER (kind=2) ::  LOLP_POS=-1,BOX| 
i:  8266  |      SAVE BOX| 
i:  8267  |      REAL ::  LOLP(1000),X_AXIS(1000),LOLP_VALUE| 
i:  8268  |      SAVE LOLP,X_AXIS| 
i:  8269  |      LOGICAL (kind=1) ::  WRITE_LOLP_CURVE_NOT_OPEN=.TRUE. | 
i:  8270  |      INTEGER (kind=2) ::  I,ISEAS,END_POINT,YEAR,START_CURVE| 
i:  8271  |      INTEGER (kind=2) ::  LOLP_CURVE_NO,LOLP_CURVE_HEADER,PEAK_MONTH| 
i:  8272  |      SAVE LOLP_CURVE_NO| 
i:  8273  |      REAL ::  HOURS| 
i:  8274  |      REAL ::  MONTHLY_LOLP(12),ANNUAL_LOLP=0. | 
i:  8275  |      SAVE MONTHLY_LOLP| 
i:  8276  |      LOGICAL (kind=1) ::  LOLP_MONTHLY_REPORT_NOT_OPEN=.TRUE. | 
i:  8277  |      INTEGER (kind=2) ::  LOLP_MONTHLY_REPORT_NO,LOLP_MONTHLY_HEADER| 
i:  8278  |      INTEGER ::  LOLP_MONTHLY_REPORT_REC| 
i:  8279  |      SAVE LOLP_MONTHLY_REPORT_NO,LOLP_MONTHLY_REPORT_REC| 
i:  8280  |      REAL ::  NEAR_ZERO| 
i:  8281  |      PARAMETER (NEAR_ZERO = 10.**(-10))| 
i:  8282  |!| 
i:  8283  |         IF(LOLP_POS == -1) THEN| 
i:  8284  |            LOLP = 0.| 
i:  8285  |            X_AXIS = 0.| 
i:  8286  |            LOLP_POS = 1| 
i:  8287  |            BOX = 1| 
i:  8288  |         ENDIF| 
i:  8289  |         IF(CAPACITY <= LODDUR(1)) THEN| 
i:  8290  |            LOLP(1) = 1.| 
i:  8291  |            X_AXIS(1) = CAPACITY| 
i:  8292  |         ELSE| 
i:  8293  |            LOLP_VALUE = ELDC_Y_AXIS_VALUE(CAPACITY,LPROB,LODDUR,BOX)| 
i:  8294  |            IF(LOLP_VALUE < NEAR_ZERO) LOLP_VALUE = 0.| 
i:  8295  |            LOLP_POS = LOLP_POS + 1| 
i:  8296  |            LOLP(LOLP_POS) = LOLP_VALUE| 
i:  8297  |            X_AXIS(LOLP_POS) = CAPACITY| 
i:  8298  |         ENDIF| 
i:  8299  |      RETURN| 
i:  8300  |!| 
i:  8301  |!**********************************************************************| 
i:  8302  |      ENTRY CALCULATE_MONTHLY_LOLP(ISEAS,HOURS,CAPACITY,LPROB,LODDUR)| 
i:  8303  |!**********************************************************************| 
i:  8304  |!| 
i:  8305  |         IF(CAPACITY <= LODDUR(1)) THEN| 
i:  8306  |            MONTHLY_LOLP(ISEAS) = 1.| 
i:  8307  |         ELSE| 
i:  8308  |            BOX = 1| 
i:  8309  |            MONTHLY_LOLP(ISEAS) =| 
i:  8310  |     +                      ELDC_Y_AXIS_VALUE(CAPACITY,LPROB,LODDUR,BOX)| 
i:  8311  |            IF(MONTHLY_LOLP(ISEAS) < 0.) MONTHLY_LOLP(ISEAS) = 0.| 
i:  8312  |         ENDIF| 
i:  8313  |         ANNUAL_LOLP = ANNUAL_LOLP + MONTHLY_LOLP(ISEAS) * HOURS| 
i:  8314  |      RETURN| 
i:  8315  |!**********************************************************************| 
i:  8316  |      ENTRY LOLP_ANALYSIS_REPORT(ISEAS,END_POINT,PEAK_MONTH,YEAR)| 
i:  8317  |!**********************************************************************| 
i:  8318  |!| 
i:  8319  |         IF(ISEAS == PEAK_MONTH) THEN| 
i:  8320  |            IF(WRITE_LOLP_CURVE_NOT_OPEN) THEN| 
i:  8321  |               LOLP_CURVE_NO = LOLP_CURVE_HEADER()| 
i:  8322  |               WRITE_LOLP_CURVE_NOT_OPEN = .FALSE.| 
i:  8323  |            ENDIF| 
i:  8324  |            START_CURVE = MAX(1,LOLP_POS-40)| 
i:  8325  |            WRITE(LOLP_CURVE_NO,1010) END_POINT,YEAR,ISEAS,| 
