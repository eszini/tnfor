i:  3896  |      ENTRY ESCALATE_ALL_MONTHLY_VALUES(R_VALUE_ARRAY,R_VECTOR_NO_ARRAY,| 
i:  3897  |     +                                        NUM_VALS,RECORD_NAME,R_YR,| 
i:  3898  |     +                                        R_START_MONTH,R_END_MONTH)| 
i:  3899  |C***********************************************************************| 
i:  3900  |C THIS ASSUMES THAT R_VALUE HAS BEEN ESCALATED TO THE PREVIOUS YEAR| 
i:  3901  |C THE NEW VALUE IS RETURNED| 
i:  3902  |C| 
i:  3903  |         ESCALATE_ALL_MONTHLY_VALUES = NUM_VALS | 
i:  3904  |C         IF(ITERATE_GRX_PLANNING() .AND. GRX_ITERATIONS > 1) RETURN REMOVED 3/4/11 | 
i:  3905  |         SEASONS = FLOAT(R_END_MONTH - R_START_MONTH + 1)| 
i:  3906  |         DO I = 1, NUM_VALS| 
i:  3907  |            POSITION_IN_VECTOR_MAP = R_VECTOR_NO_ARRAY(I)| 
i:  3908  |            IF(POSITION_IN_VECTOR_MAP < -1 .OR. | 
i:  3909  |     +         POSITION_IN_VECTOR_MAP > MAXIMUM_VECTOR_NUM) | 
i:  3910  |     +            CALL BAD_ESC_VECTOR_NUMBER(| 
i:  3911  |     +             POSITION_IN_VECTOR_MAP,MAXIMUM_VECTOR_NUM,| 
i:  3912  |     +                                                   RECORD_NAME(I))| 
i:  3913  |            IF(VECTOR_PERIOD_IS_ANNUAL(POSITION_IN_VECTOR_MAP)) THEN| 
i:  3914  |               I4 = I4_VECTOR_MAP(POSITION_IN_VECTOR_MAP)| 
i:  3915  |               IF(R_START_MONTH > 0) CYCLE| 
i:  3916  |               IF(VECTOR_TYPE_IS_VALUE(I4)) THEN| 
i:  3917  |                  IF(INTO_EXTENSION_PERIOD) THEN| 
i:  3918  |                     IF(GRX_ITERATIONS == 0 .OR. I > GRX_NUNITS) THEN| 
i:  3919  |                        R_VALUE_ARRAY(I) = R_VALUE_ARRAY(I) * | 
i:  3920  |     +                                          ACTIVE_VECTOR_VALUES(I4)| 
i:  3921  |                     ENDIF| 
i:  3922  |                  ELSE| 
i:  3923  |                     R_VALUE_ARRAY(I) = ACTIVE_VECTOR_VALUES(I4) | 
i:  3924  |                  ENDIF| 
i:  3925  |               ELSEIF(GRX_ITERATIONS == 0 .OR. I > GRX_NUNITS) THEN| 
i:  3926  |                  R_VALUE_ARRAY(I) = R_VALUE_ARRAY(I) * | 
i:  3927  |     +                                      ACTIVE_VECTOR_VALUES(I4)| 
i:  3928  |               ENDIF| 
i:  3929  |            ELSE ! MONTHLY REPRESENTATION| 
i:  3930  |               SAVE_MONTHLY_ESCALATIONS = .TRUE.| 
i:  3931  |               IF(R_START_MONTH < 1) CYCLE| 
i:  3932  |               TEMP_VALUE = 0.| 
i:  3933  |               IF(INTO_EXTENSION_PERIOD) THEN| 
i:  3934  |                  DO MO = R_START_MONTH, R_END_MONTH| 
i:  3935  |                     I4 = | 
i:  3936  |     +                  I4_MONTHLY_VECTOR_MAP(POSITION_IN_VECTOR_MAP,MO)| 
i:  3937  |                     IF(GRX_ITERATIONS == 0 .OR. I > GRX_NUNITS) THEN| 
i:  3938  |                        TEMP_VALUE = TEMP_VALUE + R_VALUE_ARRAY(I4) *| 
i:  3939  |     +                          VECTOR_VALUES(AVAIL_DATA_YEARS+1,I4)| 
i:  3940  |                     ELSE| 
i:  3941  |                       TEMP_VALUE = TEMP_VALUE + R_VALUE_ARRAY(I4)| 
i:  3942  |                     ENDIF  | 
i:  3943  |                  ENDDO| 
i:  3944  |               ELSE| 
i:  3945  |                  DO MO = R_START_MONTH, R_END_MONTH| 
i:  3946  |                     I4 = | 
i:  3947  |     +                  I4_MONTHLY_VECTOR_MAP(POSITION_IN_VECTOR_MAP,MO)| 
i:  3948  |                     TEMP_VALUE = TEMP_VALUE+VECTOR_VALUES(R_YR,I4)| 
i:  3949  |                  ENDDO| 
i:  3950  |               ENDIF| 
i:  3951  |               R_VALUE_ARRAY(I4) = TEMP_VALUE / SEASONS| 
i:  3952  |            ENDIF| 
