1985 |            IF(LAST_ENERGY_ONLY_PRICE < NEXT_LOWEST_VARIABLE_COST) THEN|
1986 |               ENERGY_ONLY_FOR_DISPATCHING = MAX(0.,|
1987 |     +                     MIN(LIMITED_ENERGY,REMAINING_ENRG_ONLY_ENRG))|
