i:  1829  |     +            COMMENT,(EMIS_STRAT(I),I=1,3),(MIN_BANK(I),I=1,3),| 
i:  1830  |     +            (MAX_BANK(I),I=1,3),EPA_EAS,EPA_SETASIDE_RATE,| 
i:  1831  |     +            (EMIS_DISPATCH_ADDER(I),I=4,5),(EMIS_CAP(I),I=4,5),| 
i:  1832  |     +            (PURCH_CRED_PRICE(I),I=4,5),| 
i:  1833  |     +            (SELL_CRED_PRICE(I),I=4,5),| 
i:  1834  |     +            (EMIS_STRAT(I),I=4,5),(MIN_BANK(I),I=4,5),| 
i:  1835  |     +            (MAX_BANK(I),I=4,5),CLASS_NAME,CLASS_NUM,| 
i:  1836  |     +            (EMISS_COMMENT,I=1,5),| 
i:  1837  |     +             CO2_PUSH_OK,SO2_PUSH_OK| 
i:  1838  |            ENDIF| 
i:  1839  |            WRITE(12,REC=IREC) DELETE,YEAR,| 
i:  1840  |     +                   EMIS_DISPATCH_ADDER,EMIS_CAP,| 
i:  1841  |     +                   PURCH_CRED_PRICE,SELL_CRED_PRICE,EMIS_STRAT,| 
i:  1842  |     +                   MIN_BANK,MAX_BANK,EPA_EAS,EPA_SETASIDE_RATE,| 
