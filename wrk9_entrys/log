i: 10045  |!| 
i: 10046  |! COMPARE CONSTRAINTS (2), (3), (4) AND (5):| 
i: 10047  |!| 
i: 10048  |            CONTRACT_MINIMUM_PROB =| 
i: 10049  |     +         MAX(CONTRACT_CROSSOVER_PROB, CL_CROSSOVER_PROB, 0.000001)| 
i: 10050  |!| 
i: 10051  |!           FIND THE CAPACITY ASSOCIATED WITH CONTRACT_MINIMUM_PROB AND COMPARE| 
i: 10052  |!           TO CONSTRAINT (2)| 
i: 10053  |!| 
i: 10054  |            LD_PTS = ISTOP| 
i: 10055  |            DOWHILE( CONTRACT_MINIMUM_PROB .LT. LPROB(LD_PTS))| 
