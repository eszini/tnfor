3165 |      INTEGER (kind=2) ::   ISEAS,UNITNO,ARRAY_POINTR,PSI_CLASS_NUMBER|
3166 |      REAL ::  PSI_LDC|
3167 |      REAL ::  PSI_ENERGY_DEMAND|
3168 |      REAL ::  PSI_PEAK_DEMAND|
3169 |      REAL ::  PSI_BASE_DEMAND|
3170 |      REAL ::  GIB5_CAP|
3171 |      REAL ::  GIB5_ENERGY|
3172 |      REAL ::  GIBSON_BLOCK1_ENERGY|
3173 |      REAL ::  GIBSON_BLOCK2_ENERGY|
3174 |      REAL ::  GIBSON_TOTAL_ENERGY|
3175 |      REAL ::  BLK_MW|
3176 |      REAL ::  SEAS_HOURS|
3177 |      REAL ::  FORECAST_DSM_ENERGY(MAX_LOAD_CLASSES)|
3178 |      REAL ::  THIS_MONTH_ENERGY|
3179 |      REAL ::  THIS_MONTH_PEAK|
3180 |!|
3181 |! ADDED 9/1/94. GAT.|
3182 |!|
3183 |         CALL GET_CLASS_DSM_ENERGY_ALLOC(ISEAS,FORECAST_DSM_ENERGY)|
3184 |!|
