i:  9862  |!| 
i:  9863  |!| 
i:  9864  |! INTEGRATE ALONG THE ELDC UNTIL THE TARGET CAPACITY| 
i:  9865  |! AND ENERGY IS MET, OR ALL POINTS ON THE LOAD CURVE ARE EVALUATED.| 
i:  9866  |!| 
i:  9867  |! DETERMINE THE LOWEST COST CONTRACT FOR THE NEXT LOAD INTERVAL(S)| 
i:  9868  |! THE ORDERED PAIR (RIGHT,A) ACTS AS THE STARTING POINT FOR THE| 
i:  9869  |! EVALUATION.| 
i:  9870  |!| 
i:  9871  |      INTPL8(X1,Y1,X3,Y2,X2) = Y1 + (Y2-Y1) * (X3-X1)/(X2-X1)| 
i:  9872  |      CALL RETURN_TIER_2(TIER_2_ENERGY,TIER_2_CT)| 
i:  9873  |      CALL USING_FIXED_LOGIC(FIXED_COST_LOGIC)| 
i:  9874  |      LAST_ENERGY_ONLY_PRICE = GET_LAST_ENERGY_ONLY_PRICE()| 
i:  9875  |!| 
i:  9876  |      PRODUCTION_COST_PERIODS = PRODUCTION_PERIODS()| 
i:  9877  |      IF(B .GT. LODDUR(1)) THEN| 
i:  9878  |         ISTOP = MAX(ISTART,1)| 
i:  9879  |         DOWHILE(.NOT.(LODDUR(ISTOP).LE.B .AND. B.LE.LODDUR(ISTOP+1)))| 
i:  9880  |            IF(LODDUR(ISTOP) .GT. B) THEN| 
i:  9881  |               ISTOP = ISTOP - 1| 
i:  9882  |            ELSE| 
i:  9883  |               ISTOP = ISTOP + 1| 
i:  9884  |            ENDIF| 
i:  9885  |         ENDDO| 
i:  9886  |         RIGHT = INTPL8(LODDUR(ISTOP),LPROB(ISTOP),B,| 
i:  9887  |     +           LPROB(ISTOP+1),LODDUR(ISTOP+1))| 
i:  9888  |         IF(RIGHT .LT. .0001) RIGHT = 0.0| 
i:  9889  |      ELSE| 
i:  9890  |         RIGHT = 1.0| 
i:  9891  |         ISTOP = 1| 
i:  9892  |      ENDIF| 
i:  9893  |!| 
i:  9894  |      IF(REMAINING_ENERGY .LT. .000001) REMAINING_ENERGY = 0.| 
i:  9895  |!| 
i:  9896  |!| 
i:  9897  |      DOWHILE(RIGHT .GT. 0. .AND. CONTRACTS_ACTIVE)| 
i:  9898  |         IF(RIGHT > .0000001 .AND. REMAINING_ENERGY == 0.) THEN| 
i:  9899  |!| 
i:  9900  |!| 
i:  9901  |!| 
i:  9902  |!| 
i:  9903  |            CONTRACTS_ACTIVE = .FALSE.| 
i:  9904  |            RETURN| 
i:  9905  |         ENDIF| 
i:  9906  |         TEMP_CONTRACT_COST = 9999999.| 
i:  9907  |         LOWEST_COST = CL_DISPATCH_COST| 
i:  9908  |         LOWEST_COST_CONTRACT = 0| 
i:  9909  |         NEXT_LOWEST_VARIABLE_COST = 999999999.| 
i:  9910  |         NEXT_LOWEST_TOTAL_COST =    999999999.| 
i:  9911  |         DO CONTRACT = 1 , NUMBER_OF_CONTRACTS| 
i:  9912  |            IF(AVAILABLE_CONTRACT(CONTRACT) .AND.| 
i:  9913  |     +                     CNTR_CAPACITY_SWITCH(CONTRACT) .NE. "E") THEN| 
i:  9914  |               IF(CNTR_CAPACITY_SWITCH(CONTRACT) .EQ. 'V') THEN| 
i:  9915  |                  TEMP_CONTRACT_COST =| 
i:  9916  |     +               (CONTRACT_VARIABLE_COST(CONTRACT) +| 
i:  9917  |     +                      CT_ENERGY_COST_ADDER(CONTRACT) +| 
i:  9918  |     +            12*1000*CONTRACT_FIXED_COST(CONTRACT)/(HOURS*| 
i:  9919  |     +               (RIGHT)*PRODUCTION_COST_PERIODS))*10.| 
i:  9920  |               ELSE| 
i:  9921  |                  TEMP_CONTRACT_COST = 10. *| 
i:  9922  |     +                                (CT_ENERGY_COST_ADDER(CONTRACT) +| 
i:  9923  |     +                                 CONTRACT_VARIABLE_COST(CONTRACT))| 
i:  9924  |               ENDIF| 
i:  9925  |               IF(TEMP_CONTRACT_COST < LOWEST_COST .AND.| 
i:  9926  |     +                                AVAILABLE_CONTRACT(CONTRACT)) THEN| 
i:  9927  |                  IF(LOWEST_COST_CONTRACT > 0) THEN| 
i:  9928  |                     NEXT_LOWEST_VARIABLE_COST =| 
i:  9929  |     +                      CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT)| 
i:  9930  |                     NEXT_LOWEST_TOTAL_COST = LOWEST_COST| 
i:  9931  |                  ENDIF| 
i:  9932  |                  LOWEST_COST = TEMP_CONTRACT_COST| 
i:  9933  |                  LOWEST_COST_CONTRACT = CONTRACT| 
i:  9934  |               ENDIF| 
i:  9935  |            ENDIF| 
i:  9936  |         ENDDO| 
