i:  8151  |!| 
i:  8152  |      SUBROUTINE CONVOL(CAPON,EA,CURRENT,LIMR,LPROB,LODDUR,LAST_POINT)| 
i:  8153  |!| 
i:  8154  |      INTEGER (kind=2) ::  BOX,CURRENT,NEXT,I,LAST_POINT| 
i:  8155  |      REAL ::  EA| 
i:  8156  |      REAL ::  Q| 
i:  8157  |      REAL ::  CAPON| 
i:  8158  |      REAL ::  XTEMP| 
i:  8159  |      REAL ::  YTEMP| 
i:  8160  |      REAL ::  LPROB(1000,2)| 
i:  8161  |      REAL ::  LODDUR(1000)| 
i:  8162  |      REAL ::  SLOPE| 
i:  8163  |      REAL ::  NEAR_ZERO| 
i:  8164  |      REAL ::  LIMR| 
i:  8165  |      PARAMETER (NEAR_ZERO = 10.**(-10))| 
i:  8166  |      LOGICAL (kind=1) ::  BOTH_NOT_ZERO| 
i:  8167  |!| 
i:  8168  |      IF(EA .GT. 0.999 .OR. EA .LT. .001) RETURN| 
i:  8169  |      Q = 1. - EA| 
i:  8170  |!| 
i:  8171  |      NEXT = MOD(CURRENT,2) + 1| 
i:  8172  |      LPROB(1,NEXT) = 1.| 
i:  8173  |      BOX = 1| 
i:  8174  |      I = 2| 
i:  8175  |      BOTH_NOT_ZERO = .TRUE.| 
i:  8176  |      DOWHILE (BOTH_NOT_ZERO)| 
i:  8177  |         XTEMP = LODDUR(I) - CAPON| 
i:  8178  |         IF(XTEMP .LE. LODDUR(1)) THEN| 
i:  8179  |            LPROB(I,NEXT) = EA * LPROB(I,CURRENT) + Q| 
i:  8180  |         ELSE| 
i:  8181  |            DOWHILE (.NOT. (LODDUR(BOX) .LE. XTEMP .AND.| 
i:  8182  |     +                                        LODDUR(BOX+1) .GT. XTEMP))| 
i:  8183  |               IF(LODDUR(BOX) .GT. XTEMP) THEN| 
i:  8184  |                  BOX = BOX - 1| 
i:  8185  |               ELSE| 
i:  8186  |                  BOX = BOX + 1| 
i:  8187  |               ENDIF| 
i:  8188  |            ENDDO| 
i:  8189  |            IF(LODDUR(BOX) .EQ. XTEMP) THEN| 
i:  8190  |               YTEMP = LPROB(BOX,CURRENT)| 
i:  8191  |            ELSE| 
i:  8192  |               SLOPE = (XTEMP-LODDUR(BOX))| 
i:  8193  |               YTEMP = (LODDUR(BOX+1)-LODDUR(BOX))| 
i:  8194  |               SLOPE = SLOPE/YTEMP| 
i:  8195  |               YTEMP = LPROB(BOX,CURRENT)*(1. - SLOPE) +| 
i:  8196  |     +                 LPROB(BOX+1,CURRENT) * SLOPE| 
i:  8197  |            ENDIF| 
i:  8198  |            IF(YTEMP .LT. NEAR_ZERO) YTEMP = 0.| 
i:  8199  |!| 
i:  8200  |            LPROB(I,NEXT) = EA * LPROB(I,CURRENT) + Q * YTEMP| 
i:  8201  |         ENDIF| 
i:  8202  |         BOTH_NOT_ZERO = (LPROB(I,NEXT) .NE. 0.) .AND.| 
i:  8203  |     +                      (I + 1 .LE. LAST_POINT) .AND.| 
i:  8204  |     +                           (LODDUR(I) .LT. LIMR)| 
i:  8205  |         I = I + 1| 
i:  8206  |      ENDDO| 
i:  8207  |      CURRENT = NEXT| 
i:  8208  |      RETURN| 
i:  8209  |      END| 
i:  8210  |!***********************************************************************| 
i:  8211  |!| 
i:  8212  |!            RETURNS THE LOLP (Y-AXIS) VALUE FOR A LOAD VALUE| 
i:  8213  |!                   COPYRIGHT (C) 1996| 
i:  8214  |!               M.S. GERBER & ASSOCIATES, INC.| 
i:  8215  |!                   ALL RIGHTS RESERVED| 
i:  8216  |!| 
i:  8217  |!**********************************************************************| 
i:  8218  |!| 
i:  8219  |      FUNCTION ELDC_Y_AXIS_VALUE(LOAD_POINT,LPROB,LODDUR,BOX)| 
i:  8220  |!| 
i:  8221  |      REAL ::  LOAD_POINT,LPROB(*),LODDUR(*),ELDC_Y_AXIS_VALUE| 
i:  8222  |      REAL ::  SLOPE,LOLP_VALUE,DELTA_X| 
i:  8223  |      INTEGER (kind=2) ::  BOX| 
i:  8224  |!| 
i:  8225  |         IF(LOAD_POINT <= LODDUR(1)) THEN| 
i:  8226  |            LOLP_VALUE = 1.| 
i:  8227  |         ELSE| 
i:  8228  |            DOWHILE (.NOT. (LODDUR(BOX) <= LOAD_POINT .AND.| 
i:  8229  |     +                                      LODDUR(BOX+1) > LOAD_POINT))| 
i:  8230  |               IF(LODDUR(BOX) > LOAD_POINT) THEN| 
i:  8231  |                  BOX = BOX - 1| 
i:  8232  |               ELSE| 
i:  8233  |                  BOX = BOX + 1| 
i:  8234  |               ENDIF| 
i:  8235  |            ENDDO| 
i:  8236  |            IF(LODDUR(BOX) == LOAD_POINT) THEN| 
i:  8237  |               LOLP_VALUE = LPROB(BOX)| 
i:  8238  |            ELSE| 
i:  8239  |               SLOPE = (LOAD_POINT-LODDUR(BOX))| 
i:  8240  |               DELTA_X = (LODDUR(BOX+1)-LODDUR(BOX))| 
i:  8241  |               SLOPE = SLOPE/DELTA_X| 
i:  8242  |               LOLP_VALUE = LPROB(BOX)*(1.-SLOPE) + LPROB(BOX+1) * SLOPE| 
i:  8243  |            ENDIF| 
i:  8244  |         ENDIF| 
i:  8245  |         ELDC_Y_AXIS_VALUE = LOLP_VALUE| 
i:  8246  |      RETURN| 
i:  8247  |      END| 
