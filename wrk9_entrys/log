1933 |!|
1934 |! COMPARE CONSTRAINTS (2), (3), (4) AND (5):|
1935 |!|
1936 |            CONTRACT_MINIMUM_PROB =|
1937 |     +         MAX(CONTRACT_CROSSOVER_PROB, CL_CROSSOVER_PROB, 0.000001)|
1938 |!|
1939 |!           FIND THE CAPACITY ASSOCIATED WITH CONTRACT_MINIMUM_PROB AND COMPARE|
1940 |!           TO CONSTRAINT (2)|
1941 |!|
1942 |            LD_PTS = ISTOP|
1943 |            DOWHILE( CONTRACT_MINIMUM_PROB .LT. LPROB(LD_PTS))|
1944 |               LD_PTS = LD_PTS + 1|
1945 |            ENDDO|
1946 |            IF(LD_PTS .EQ. 1 ) THEN|
