107 |      FUNCTION ELDC_Y_AXIS_VALUE(LOAD_POINT,LPROB,LODDUR,BOX)|
108 |!|
109 |      REAL ::  LOAD_POINT,LPROB(*),LODDUR(*),ELDC_Y_AXIS_VALUE|
110 |      REAL ::  SLOPE,LOLP_VALUE,DELTA_X|
111 |      INTEGER (kind=2) ::  BOX|
112 |!|
113 |         IF(LOAD_POINT <= LODDUR(1)) THEN|
114 |            LOLP_VALUE = 1.|
115 |         ELSE|
116 |            DOWHILE (.NOT. (LODDUR(BOX) <= LOAD_POINT .AND.|
117 |     +                                      LODDUR(BOX+1) > LOAD_POINT))|
118 |               IF(LODDUR(BOX) > LOAD_POINT) THEN|
119 |                  BOX = BOX - 1|
120 |               ELSE|
121 |                  BOX = BOX + 1|
122 |               ENDIF|
123 |            ENDDO|
124 |            IF(LODDUR(BOX) == LOAD_POINT) THEN|
125 |               LOLP_VALUE = LPROB(BOX)|
126 |            ELSE|
127 |               SLOPE = (LOAD_POINT-LODDUR(BOX))|
128 |               DELTA_X = (LODDUR(BOX+1)-LODDUR(BOX))|
129 |               SLOPE = SLOPE/DELTA_X|
130 |               LOLP_VALUE = LPROB(BOX)*(1.-SLOPE) + LPROB(BOX+1) * SLOPE|
131 |            ENDIF|
132 |         ENDIF|
133 |         ELDC_Y_AXIS_VALUE = LOLP_VALUE|
134 |      RETURN|
135 |      END|
