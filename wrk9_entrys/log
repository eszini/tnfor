i:  7102  |!| 
i:  7103  |      SUBROUTINE FIND_ENRGY_CROSSOVER(A,LEFT,TARGET_ENERGY,| 
i:  7104  |     +                                 LODDUR,LPROB,B_ADJUSTED,RIGHT)| 
i:  7105  |!| 
i:  7106  |      use shared_vars_interg82| 
i:  7107  |      use interg82| 
i:  7108  || 
i:  7109  |      LOGICAL (kind=1) ::   ENERGY_EXCEEDED_AT_FIRST_PASS| 
i:  7110  || 
i:  7111  |      INTEGER (kind=2) ::   ISTART,IXSTOP,I| 
i:  7112  |      REAL :: A,LEFT,TARGET_ENERGY,LODDUR(*),LPROB(*),B_ADJUSTED,RIGHT| 
i:  7113  |      REAL :: INTPL8,X1,Y1,X3,Y2,X2,ENERGY,INCREMENTAL_ENERGY,BASE| 
i:  7114  |!| 
i:  7115  |      INTPL8(X1,Y1,X3,Y2,X2) = Y1 + (Y2-Y1) * (X3-X1)/(X2-X1)| 
i:  7116  |!| 
i:  7117  |      CALL RETURN_ISTART_ISTOP(ISTART,IXSTOP)| 
i:  7118  |      BASE = LODDUR(1)| 
i:  7119  |      ENERGY = MAX(BASE-A,0.0)| 
i:  7120  |      INCREMENTAL_ENERGY = 0.| 
i:  7121  |      ENERGY_EXCEEDED_AT_FIRST_PASS = .FALSE.| 
i:  7122  |      IF(A > BASE) THEN| 
i:  7123  |         INCREMENTAL_ENERGY = (LODDUR(ISTART)-A)*(LPROB(ISTART)+LEFT)/2.| 
i:  7124  |         ENERGY = ENERGY + INCREMENTAL_ENERGY| 
i:  7125  |         IF(ENERGY > TARGET_ENERGY) ENERGY_EXCEEDED_AT_FIRST_PASS =| 
i:  7126  |     +                                                            .TRUE.| 
i:  7127  |      ENDIF| 
i:  7128  |      I = ISTART| 
i:  7129  |      DOWHILE (ENERGY < TARGET_ENERGY)| 
i:  7130  |         INCREMENTAL_ENERGY =(LPROB(I) + LPROB(I+1)) *| 
i:  7131  |     +                                      (LODDUR(I+1) - LODDUR(I))/2.| 
i:  7132  |         ENERGY = ENERGY + INCREMENTAL_ENERGY| 
i:  7133  |         I = I + 1| 
i:  7134  |      ENDDO| 
i:  7135  |      ENERGY = ENERGY - INCREMENTAL_ENERGY| 
i:  7136  |      I = MAX(ISTART,I - 1)| 
i:  7137  |      IF(ENERGY_EXCEEDED_AT_FIRST_PASS) THEN| 
i:  7138  |         CALL FIND_MAXIMUM_ENERGY(A,LODDUR(I),| 
i:  7139  |     +                         LEFT,LPROB(I),ENERGY,| 
i:  7140  |     +                         TARGET_ENERGY,B_ADJUSTED,RIGHT)| 
i:  7141  |      ELSE| 
i:  7142  |         CALL FIND_MAXIMUM_ENERGY(LODDUR(I),LODDUR(I+1),| 
i:  7143  |     +                         LPROB(I),LPROB(I+1),ENERGY,| 
i:  7144  |     +                         TARGET_ENERGY,B_ADJUSTED,RIGHT)| 
i:  7145  |      ENDIF| 
i:  7146  |      RETURN| 
i:  7147  |      END SUBROUTINE FIND_ENRGY_CROSSOVER| 
