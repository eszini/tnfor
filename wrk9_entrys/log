2006 |     +                              NEXT_LOWEST_VARIABLE_COST)|
2007 |     +            REMAINING_ENRG_ONLY_ENRG = REMAINING_ENRG_ONLY_ENRG -|
2008 |     +                                               ENRG_ONLY_ENRG_USED|
2009 |!|
2010 |!        TAKE INTO ACCOUNT PROBLEM WITH PEAK SHIFT ALGORITHM|
2011 |!|
2012 |         IF((CURRENT_CONTRACT_ENERGY + ENRG_ONLY_ENRG_USED) .GT.|
2013 |     +                                           REMAINING_ENERGY .OR.|
