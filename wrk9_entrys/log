1580 |     +                     RIGHT*PRODUCTION_COST_PERIODS))*10.|
1581 |               ELSE|
1582 |                  TEMP_CONTRACT_COST = 10. *|
1583 |     +                      (CT_ENERGY_COST_ADDER(CONTRACT) +|
1584 |     +                                 CONTRACT_VARIABLE_COST(CONTRACT))|
1585 |               ENDIF|
1586 |               IF(TEMP_CONTRACT_COST .LT. CONTRACT_DISPATCH_COST .AND.|
1587 |     +                               AVAILABLE_CONTRACT(CONTRACT)) THEN|
1588 |                  CONTRACT_DISPATCH_COST = TEMP_CONTRACT_COST|
