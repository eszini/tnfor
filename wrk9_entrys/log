i:  7184  |      SUBROUTINE EMISSIONS_BY_BLENDED_FUEL(UNIT_NO,BLK1_HEAT,BLK2_HEAT)| 
i:  7185  |!**********************************************************************| 
i:  7186  |      implicit none| 
i:  7187  |      integer (kind=2) , intent(in) :: UNIT_NO| 
i:  7188  |      real, intent(in) :: BLK1_HEAT| 
i:  7189  |      real, intent(in) :: BLK2_HEAT| 
i:  7190  || 
i:  7191  |      integer (kind=2) :: I| 
i:  7192  |      real :: BLENDING_RATE, BLEND_HEAT, PRIM_HEAT| 
i:  7193  || 
i:  7194  |         I = UNIT_NO| 
i:  7195  |         CALL RETURN_BLENDING_MIX(I,BLENDING_RATE)| 
i:  7196  |         IF(BLENDING_RATE > 0.) THEN| 
i:  7197  |            BLEND_HEAT = BLENDING_RATE * (BLK1_HEAT + BLK2_HEAT)| 
i:  7198  |            BLOCK1_HEAT = BLENDING_RATE * BLK1_HEAT| 
i:  7199  |            BLOCK2_HEAT = BLENDING_RATE * BLK2_HEAT| 
i:  7200  |            CALL RETURN_BLEND_EMISSION_RATES(I,SOX,NOX1,NOX2,CO2,| 
i:  7201  |     +                                                        OTH2,OTH3)| 
i:  7202  |            SOX_BY_FUEL_TYPE(3,I) = BLEND_HEAT * SOX| 
i:  7203  |            NOX_BY_FUEL_TYPE(3,I) = BLENDING_RATE *| 
i:  7204  |     +                             (BLK1_HEAT * NOX1 + BLK2_HEAT * NOX2)| 
i:  7205  |            CO2_BY_FUEL_TYPE(3,I) = BLEND_HEAT * CO2| 
i:  7206  |            OTH2_BY_FUEL_TYPE(3,I) = BLEND_HEAT * OTH2| 
i:  7207  |            OTH3_BY_FUEL_TYPE(3,I) = BLEND_HEAT * OTH3| 
i:  7208  |            UNIT_HEAT_BY_FUEL(3,I) = UNIT_HEAT_BY_FUEL(3,I) + BLEND_HEAT| 
i:  7209  |            CALL SAVE_EMISSIONS_BY_BLOCK(UNIT_NO)| 
i:  7210  |!| 
i:  7211  |! DO PRIM FUEL PROTION| 
i:  7212  |!| 
i:  7213  |            PRIM_HEAT = BLK1_HEAT + BLK2_HEAT - BLEND_HEAT| 
i:  7214  |            BLOCK1_HEAT = BLK1_HEAT - BLOCK1_HEAT| 
i:  7215  |            BLOCK2_HEAT = BLK2_HEAT - BLOCK2_HEAT| 
i:  7216  |         ELSE| 
i:  7217  |            BLOCK1_HEAT = BLK1_HEAT| 
i:  7218  |            BLOCK2_HEAT = BLK2_HEAT| 
i:  7219  |            PRIM_HEAT = BLK1_HEAT + BLK2_HEAT| 
i:  7220  |            BLEND_HEAT = 0.| 
i:  7221  |         ENDIF| 
i:  7222  |         CALL RETURN_PRIM_EMISSION_RATES(I,SOX,NOX1,NOX2,CO2,OTH2,OTH3)| 
i:  7223  |         CALL SAVE_EMISSIONS_BY_BLOCK(UNIT_NO)| 
i:  7224  |         SOX_BY_FUEL_TYPE(1,I) = PRIM_HEAT * SOX| 
i:  7225  |         NOX_BY_FUEL_TYPE(1,I) = (1.-BLENDING_RATE) *| 
i:  7226  |     +                             (BLK1_HEAT * NOX1 + BLK2_HEAT * NOX2)| 
i:  7227  |         CO2_BY_FUEL_TYPE(1,I) = PRIM_HEAT * CO2| 
i:  7228  |         OTH2_BY_FUEL_TYPE(1,I) = PRIM_HEAT * OTH2| 
i:  7229  |         OTH3_BY_FUEL_TYPE(1,I) = PRIM_HEAT * OTH3| 
i:  7230  |         UNIT_HEAT_BY_FUEL(1,I) = UNIT_HEAT_BY_FUEL(1,I) + PRIM_HEAT| 
i:  7231  |      RETURN| 
i:  7232  |      END SUBROUTINE EMISSIONS_BY_BLENDED_FUEL| 
