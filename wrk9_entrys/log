1615 |      SUBROUTINE CONTRACTS(CL_DISPATCH_COST,|
1616 |     +                     LPROB,LODDUR,HOURS,DX,|
1617 |     +                     A,B,REMAINING_ENERGY,|
1618 |     +                     ISTART,|
