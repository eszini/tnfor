i:  3750  |                  IF(GRX_ITERATIONS == 0 .OR. I > GRX_NUNITS)| 
i:  3751  |     +                  R_VALUE_ARRAY(I) = R_VALUE_ARRAY(I) * | 
i:  3752  |     +                                          ACTIVE_VECTOR_VALUES(I4)| 
i:  3753  |               ELSE| 
i:  3754  |                  R_VALUE_ARRAY(I) = ACTIVE_VECTOR_VALUES(I4) | 
i:  3755  |               ENDIF| 
i:  3756  |            ELSEIF(GRX_ITERATIONS == 0 .OR. I > GRX_NUNITS) THEN| 
i:  3757  |               R_VALUE_ARRAY(I) = R_VALUE_ARRAY(I) * | 
i:  3758  |     +                                      ACTIVE_VECTOR_VALUES(I4)| 
i:  3759  |            ENDIF| 
i:  3760  |         ENDDO| 
i:  3761  |      RETURN| 
