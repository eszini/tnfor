2015 |            REMAINING_ENRG_ONLY_ENRG = REMAINING_ENRG_ONLY_ENRG +|
2016 |     +                                               ENRG_ONLY_ENRG_USED|
2017 |! 3/18/93. GAT. THE CONDITIONAL BELOW WAS PUT BACK-IN FOR PALO ALTO|
2018 |            IF(CURRENT_CONTRACT_ENERGY .GE. REMAINING_ENERGY) THEN|
2019 |               ENRG_ONLY_ENRG_USED = 0.|
2020 |               CURRENT_CONTRACT_ENERGY = REMAINING_ENERGY|
2021 |            ELSE|
2022 |               ENRG_ONLY_ENRG_USED = REMAINING_ENERGY -|
2023 |     +                                           CURRENT_CONTRACT_ENERGY|
2024 |               REMAINING_ENRG_ONLY_ENRG = REMAINING_ENRG_ONLY_ENRG -|
2025 |     +                                               ENRG_ONLY_ENRG_USED|
2026 |            ENDIF|
2027 |         ENDIF|
2028 |!|
2029 |! PALO ALTO 2 TIER|
2030 |!|
2031 |         IF(CNTR_ENERGY_SWITCH(LOWEST_COST_CONTRACT) == 'T' .AND.|
2032 |     +         (CONTRACT_CAPACITY(LOWEST_COST_CONTRACT)+B-A > 0.0) .AND.|
2033 |     +         (CONTRACT_ENERGY(LOWEST_COST_CONTRACT) +|
2034 |     +                                    CURRENT_CONTRACT_ENERGY)/|
2035 |     +         (CONTRACT_CAPACITY(LOWEST_COST_CONTRACT)+B-A)> 0.70) THEN|
2036 |            TIER_2_ENERGY =|
2037 |     +         (CONTRACT_ENERGY(LOWEST_COST_CONTRACT) +|
2038 |     +                              CURRENT_CONTRACT_ENERGY) -|
2039 |     +         (CONTRACT_CAPACITY(LOWEST_COST_CONTRACT)+B-A)  * 0.70|
2040 |            TIER_2_CT = LOWEST_COST_CONTRACT|
2041 |!|
2042 |!|
2043 |            IF(ABS(CURRENT_CONTRACT_ENERGY - REMAINING_ENERGY) < .002|
2044 |     +                             .AND. AVAILABLE_CONTRACT_NO > 1) THEN|
2045 |! 12/23/94. GAT. MOVED FROM ABOVE THE IF|
2046 |               IF(REMAINING_ENRG_ONLY_ENRG > 0. .AND.|
2047 |     +                  LAST_ENERGY_ONLY_PRICE <|
2048 |     +                           CT_SECOND_ENERGY_PRICE(TIER_2_CT)) THEN|
2049 |                  TIER_2_TEMP = MIN(REMAINING_ENRG_ONLY_ENRG,|
2050 |     +                         TIER_2_ENERGY,CONTRACT_ENERGY(TIER_2_CT))|
2051 |                  CONTRACT_ENERGY(TIER_2_CT)=CONTRACT_ENERGY(TIER_2_CT)|
2052 |     +                                                     - TIER_2_TEMP|
2053 |                  TIER_2_ENERGY = TIER_2_ENERGY - TIER_2_TEMP|
2054 |                  REMAINING_ENRG_ONLY_ENRG = REMAINING_ENRG_ONLY_ENRG -|
2055 |     +                                                       TIER_2_TEMP|
2056 |               ENDIF|
2057 |               CONTRACT = 1|
2058 |               DOWHILE(CONTRACT <= NUMBER_OF_CONTRACTS .AND.|
2059 |     +                                             TIER_2_ENERGY > 0.0 )|
2060 |                  IF(AVAILABLE_CONTRACT(CONTRACT) .AND.|
2061 |     +                  CNTR_ENERGY_SWITCH(CONTRACT) /= 'T' .AND.|
2062 |     +                  CNTR_CAPACITY_SWITCH(CONTRACT) /= 'E') THEN|
2063 |                     TIER_2_MARGINAL_COST =|
2064 |     +                  CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT)*.7+|
2065 |     +                  CT_SECOND_ENERGY_PRICE(LOWEST_COST_CONTRACT)*.3+|
2066 |     +                  CONTRACT_FIXED_COST(LOWEST_COST_CONTRACT)*12000/|
2067 |     +                  (HOURS*PRODUCTION_COST_PERIODS)|
2068 |                     IF(CNTR_CAPACITY_SWITCH(CONTRACT) /= 'V') THEN|
2069 |                        CANDIDATE_COST =|
2070 |     +                    CONTRACT_VARIABLE_COST(CONTRACT)|
2071 |                     ELSE|
2072 |                        CANDIDATE_COST =|
2073 |     +                     CONTRACT_VARIABLE_COST(CONTRACT) +|
2074 |     +                     CONTRACT_FIXED_COST(CONTRACT)*12000 /|
2075 |     +                     (HOURS*PRODUCTION_COST_PERIODS)|
2076 |                     ENDIF|
2077 |                     IF(CANDIDATE_COST < TIER_2_MARGINAL_COST) THEN|
2078 |                        TIER_2_TEMP = MIN(|
2079 |     +                     ( (CONTRACT_ENERGY(LOWEST_COST_CONTRACT) +|
2080 |     +                                      CURRENT_CONTRACT_ENERGY)|
2081 |     +                     - 0.7*(|
2082 |     +                         CONTRACT_CAPACITY(LOWEST_COST_CONTRACT)|
2083 |     +                                                   + B - A) )/0.3,|
2084 |     +                     MAXIMUM_ENERGY(CONTRACT)/HOURS -|
2085 |     +                     CONTRACT_ENERGY(CONTRACT),|
2086 |     +                     MAXIMUM_CAPACITY(CONTRACT) -|
2087 |     +                     CONTRACT_CAPACITY(CONTRACT))|
2088 |                        CONTRACT_ENERGY(CONTRACT) =|
2089 |     +                     CONTRACT_ENERGY(CONTRACT) + TIER_2_TEMP|
2090 |                        CONTRACT_CAPACITY(CONTRACT) =|
2091 |     +                     CONTRACT_CAPACITY(CONTRACT) + TIER_2_TEMP|
2092 |                        CURRENT_CONTRACT_ENERGY =|
2093 |     +                     CURRENT_CONTRACT_ENERGY - TIER_2_TEMP|
2094 |                        B = B  - TIER_2_TEMP|
2095 |                        TIER_2_ENERGY = TIER_2_ENERGY - TIER_2_TEMP|
2096 |                     ENDIF|
2097 |                  ENDIF|
2098 |                  CONTRACT = CONTRACT + 1|
2099 |               ENDDO|
2100 |            ENDIF|
2101 |         ELSEIF(TIER_2_ENERGY > 0.0 .AND.|
2102 |     +            CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT)|
2103 |     +                     < CT_SECOND_ENERGY_PRICE(TIER_2_CT) .AND.|
2104 |     +            LOWEST_COST_CONTRACT /= TIER_2_CT .AND.|
2105 |     +            CONTRACT_ENERGY(LOWEST_COST_CONTRACT) +|
2106 |     +                                        CURRENT_CONTRACT_ENERGY <|
2107 |     +            MAXIMUM_ENERGY(LOWEST_COST_CONTRACT)/HOURS) THEN|
2108 |            TIER_2_TEMP =|
2109 |     +         MIN(TIER_2_ENERGY,|
2110 |     +            CONTRACT_CAPACITY(LOWEST_COST_CONTRACT) + B - A -|
2111 |     +               CONTRACT_ENERGY(LOWEST_COST_CONTRACT) -|
2112 |     +                                          CURRENT_CONTRACT_ENERGY,|
2113 |     +            MAXIMUM_ENERGY(LOWEST_COST_CONTRACT)/HOURS -|
2114 |     +            CONTRACT_ENERGY(LOWEST_COST_CONTRACT) -|
2115 |     +                                          CURRENT_CONTRACT_ENERGY)|
2116 |            TIER_2_ENERGY = TIER_2_ENERGY - TIER_2_TEMP|
2117 |            CONTRACT_ENERGY(TIER_2_CT) = CONTRACT_ENERGY(TIER_2_CT) -|
2118 |     +                                                    TIER_2_TEMP|
2119 |            IF( .NOT. AVAILABLE_CONTRACT(TIER_2_CT) ) THEN|
2120 |               AVAILABLE_CONTRACT(TIER_2_CT) = .TRUE.|
2121 |               AVAILABLE_CONTRACT_NO = AVAILABLE_CONTRACT_NO + 1|
2122 |            ENDIF|
2123 |            CONTRACT_ENERGY(LOWEST_COST_CONTRACT) =|
2124 |     +            CONTRACT_ENERGY(LOWEST_COST_CONTRACT) + TIER_2_TEMP|
2125 |!|
2126 |         ENDIF|
2127 |! END PALO ALTO 2 TIER|
2128 |!|
2129 |         CUM_CONTRACT_CAP = CUM_CONTRACT_CAP + B - A|
2130 |         REMAINING_ENERGY = REMAINING_ENERGY - CURRENT_CONTRACT_ENERGY -|
2131 |     +                      ENRG_ONLY_ENRG_USED|
2132 |         CONTRACT_CAPACITY(LOWEST_COST_CONTRACT) =|
2133 |     +      CONTRACT_CAPACITY(LOWEST_COST_CONTRACT) + B - A|
2134 |         CONTRACT_ENERGY(LOWEST_COST_CONTRACT) =|
2135 |     +      CONTRACT_ENERGY(LOWEST_COST_CONTRACT) +|
2136 |     +      CURRENT_CONTRACT_ENERGY|
2137 |         TOTAL_CONTRACT_ENRG = TOTAL_CONTRACT_ENRG +|
2138 |     +                                           CURRENT_CONTRACT_ENERGY|
2139 |!|
2140 |!     1/11/93. ADDED DUE TO CHECK DIFFERENCES IN PROGRAMS BETWEEN|
2141 |!     MARK'S AND GREG'S CODE.|
2142 |!|
2143 |         IF(CONTRACT_CAPACITY(LOWEST_COST_CONTRACT) .GE.|
2144 |     +            MAXIMUM_CAPACITY(LOWEST_COST_CONTRACT) .OR.|
2145 |     +            CONTRACT_ENERGY(LOWEST_COST_CONTRACT) .GE.|
2146 |     +            MAXIMUM_ENERGY(LOWEST_COST_CONTRACT)/HOURS) THEN|
2147 |               AVAILABLE_CONTRACT(LOWEST_COST_CONTRACT) = .FALSE.|
2148 |               AVAILABLE_CONTRACT_NO = AVAILABLE_CONTRACT_NO - 1|
2149 |         ENDIF|
2150 |!|
2151 |!         ADJUST OTHER VARIABLES|
2152 |!|
2153 |         IF(RIGHT .LT. .0001) RIGHT = 0.0|
2154 |         IF(AVAILABLE_CONTRACT_NO .EQ. 0) CONTRACTS_ACTIVE = .FALSE.|
2155 |      ENDDO|
2156 |      IF(RIGHT .GT. 0.0 .AND. REMAINING_ENERGY .GT. 0.) THEN|
2157 |         CONTRACT_DISPATCH_COST =|
2158 |     +             (CONTRACT_VARIABLE_COST(LOWEST_COST_CONTRACT) +|
2159 |     +              CT_ENERGY_COST_ADDER(LOWEST_COST_CONTRACT) +|
2160 |     +             12*1000*CONTRACT_FIXED_COST(LOWEST_COST_CONTRACT)/|
2161 |     +             (HOURS*RIGHT*PRODUCTION_COST_PERIODS))*10.|
2162 |      ELSE|
2163 |         REMAINING_ENERGY = 0.0|
2164 |         CONTRACTS_ACTIVE = .FALSE.|
2165 |         IF(TIER_2_CT > 0) THEN|
2166 |           TIER_2_ENERGY =|
2167 |     +         MAX(0.,CONTRACT_ENERGY(TIER_2_CT) -|
2168 |     +                             CONTRACT_CAPACITY(TIER_2_CT) * 0.70)|
2169 |            IF(REMAINING_ENRG_ONLY_ENRG > 0. .AND.|
2170 |     +                  LAST_ENERGY_ONLY_PRICE <|
2171 |     +                           CT_SECOND_ENERGY_PRICE(TIER_2_CT)) THEN|
2172 |!|
2173 |                  TIER_2_TEMP = MIN(REMAINING_ENRG_ONLY_ENRG,|
2174 |     +                         TIER_2_ENERGY,CONTRACT_ENERGY(TIER_2_CT))|
2175 |!|
2176 |               CONTRACT_ENERGY(TIER_2_CT) = CONTRACT_ENERGY(TIER_2_CT)|
