2816 |      real, intent(in) :: BLK2_HEAT|
2817 ||
2818 |      integer (kind=2) :: I|
2819 |      real :: BLENDING_RATE, BLEND_HEAT, PRIM_HEAT|
2820 ||
2821 |         I = UNIT_NO|
2822 |         CALL RETURN_BLENDING_MIX(I,BLENDING_RATE)|
2823 |         IF(BLENDING_RATE > 0.) THEN|
2824 |            BLEND_HEAT = BLENDING_RATE * (BLK1_HEAT + BLK2_HEAT)|
2825 |            BLOCK1_HEAT = BLENDING_RATE * BLK1_HEAT|
2826 |            BLOCK2_HEAT = BLENDING_RATE * BLK2_HEAT|
2827 |            CALL RETURN_BLEND_EMISSION_RATES(I,SOX,NOX1,NOX2,CO2,|
2828 |     +                                                        OTH2,OTH3)|
2829 |            SOX_BY_FUEL_TYPE(3,I) = BLEND_HEAT * SOX|
2830 |            NOX_BY_FUEL_TYPE(3,I) = BLENDING_RATE *|
2831 |     +                             (BLK1_HEAT * NOX1 + BLK2_HEAT * NOX2)|
2832 |            CO2_BY_FUEL_TYPE(3,I) = BLEND_HEAT * CO2|
2833 |            OTH2_BY_FUEL_TYPE(3,I) = BLEND_HEAT * OTH2|
2834 |            OTH3_BY_FUEL_TYPE(3,I) = BLEND_HEAT * OTH3|
2835 |            UNIT_HEAT_BY_FUEL(3,I) = UNIT_HEAT_BY_FUEL(3,I) + BLEND_HEAT|
2836 |            CALL SAVE_EMISSIONS_BY_BLOCK(UNIT_NO)|
2837 |!|
2838 |! DO PRIM FUEL PROTION|
2839 |!|
2840 |            PRIM_HEAT = BLK1_HEAT + BLK2_HEAT - BLEND_HEAT|
2841 |            BLOCK1_HEAT = BLK1_HEAT - BLOCK1_HEAT|
2842 |            BLOCK2_HEAT = BLK2_HEAT - BLOCK2_HEAT|
2843 |         ELSE|
2844 |            BLOCK1_HEAT = BLK1_HEAT|
2845 |            BLOCK2_HEAT = BLK2_HEAT|
2846 |            PRIM_HEAT = BLK1_HEAT + BLK2_HEAT|
2847 |            BLEND_HEAT = 0.|
2848 |         ENDIF|
2849 |         CALL RETURN_PRIM_EMISSION_RATES(I,SOX,NOX1,NOX2,CO2,OTH2,OTH3)|
2850 |         CALL SAVE_EMISSIONS_BY_BLOCK(UNIT_NO)|
2851 |         SOX_BY_FUEL_TYPE(1,I) = PRIM_HEAT * SOX|
2852 |         NOX_BY_FUEL_TYPE(1,I) = (1.-BLENDING_RATE) *|
2853 |     +                             (BLK1_HEAT * NOX1 + BLK2_HEAT * NOX2)|
2854 |         CO2_BY_FUEL_TYPE(1,I) = PRIM_HEAT * CO2|
2855 |         OTH2_BY_FUEL_TYPE(1,I) = PRIM_HEAT * OTH2|
2856 |         OTH3_BY_FUEL_TYPE(1,I) = PRIM_HEAT * OTH3|
2857 |         UNIT_HEAT_BY_FUEL(1,I) = UNIT_HEAT_BY_FUEL(1,I) + PRIM_HEAT|
2858 |      RETURN|
