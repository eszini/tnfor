1590 |               ENDIF|
1591 |            ELSE|
1592 |               REMAINING_ENERGY = 0.0|
1593 |               CONTRACTS_ACTIVE = .FALSE.|
1594 |            ENDIF|
1595 |         ENDIF ! AVAILABLE CONTRACT .AND. .NOT. ENERGY ONLY|
1596 |      ENDDO ! CONTRACTS COUNTER FOR MINIMUM'S|
1597 |!|
1598 |      IF(SURPLUS_ENERGY .LT. 0. .AND. LOWEST_COST_CONTRACT .GT. 0) THEN|
