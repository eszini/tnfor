 40 |      SUBROUTINE CONVOL(CAPON,EA,CURRENT,LIMR,LPROB,LODDUR,LAST_POINT)|
 41 |!|
 42 |      INTEGER (kind=2) ::  BOX,CURRENT,NEXT,I,LAST_POINT|
 43 |      REAL ::  EA|
 44 |      REAL ::  Q|
 45 |      REAL ::  CAPON|
 46 |      REAL ::  XTEMP|
 47 |      REAL ::  YTEMP|
 48 |      REAL ::  LPROB(1000,2)|
 49 |      REAL ::  LODDUR(1000)|
 50 |      REAL ::  SLOPE|
 51 |      REAL ::  NEAR_ZERO|
 52 |      REAL ::  LIMR|
 53 |      PARAMETER (NEAR_ZERO = 10.**(-10))|
 54 |      LOGICAL (kind=1) ::  BOTH_NOT_ZERO|
 55 |!|
 56 |      IF(EA .GT. 0.999 .OR. EA .LT. .001) RETURN|
 57 |      Q = 1. - EA|
 58 |!|
 59 |      NEXT = MOD(CURRENT,2) + 1|
 60 |      LPROB(1,NEXT) = 1.|
 61 |      BOX = 1|
 62 |      I = 2|
 63 |      BOTH_NOT_ZERO = .TRUE.|
 64 |      DOWHILE (BOTH_NOT_ZERO)|
 65 |         XTEMP = LODDUR(I) - CAPON|
 66 |         IF(XTEMP .LE. LODDUR(1)) THEN|
 67 |            LPROB(I,NEXT) = EA * LPROB(I,CURRENT) + Q|
 68 |         ELSE|
 69 |            DOWHILE (.NOT. (LODDUR(BOX) .LE. XTEMP .AND.|
 70 |     +                                        LODDUR(BOX+1) .GT. XTEMP))|
 71 |               IF(LODDUR(BOX) .GT. XTEMP) THEN|
 72 |                  BOX = BOX - 1|
 73 |               ELSE|
 74 |                  BOX = BOX + 1|
 75 |               ENDIF|
 76 |            ENDDO|
 77 |            IF(LODDUR(BOX) .EQ. XTEMP) THEN|
 78 |               YTEMP = LPROB(BOX,CURRENT)|
 79 |            ELSE|
 80 |               SLOPE = (XTEMP-LODDUR(BOX))|
 81 |               YTEMP = (LODDUR(BOX+1)-LODDUR(BOX))|
 82 |               SLOPE = SLOPE/YTEMP|
 83 |               YTEMP = LPROB(BOX,CURRENT)*(1. - SLOPE) +|
 84 |     +                 LPROB(BOX+1,CURRENT) * SLOPE|
 85 |            ENDIF|
 86 |            IF(YTEMP .LT. NEAR_ZERO) YTEMP = 0.|
 87 |!|
 88 |            LPROB(I,NEXT) = EA * LPROB(I,CURRENT) + Q * YTEMP|
 89 |         ENDIF|
 90 |         BOTH_NOT_ZERO = (LPROB(I,NEXT) .NE. 0.) .AND.|
 91 |     +                      (I + 1 .LE. LAST_POINT) .AND.|
 92 |     +                           (LODDUR(I) .LT. LIMR)|
 93 |         I = I + 1|
 94 |      ENDDO|
 95 |      CURRENT = NEXT|
 96 |      RETURN|
 97 |      END|
