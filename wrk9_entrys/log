i:  1674  |C CONVERT THE ENVIRONMENTAL FILE| 
i:  1675  |      ENTRY EN_MAKEBIN| 
i:  1676  |      MAX_BC_CLASS_NUMBER = 0| 
i:  1677  |      MAX_BC_TABLE_NUMBER = 0| 
i:  1678  |      MAX_OL_CLASS_NUMBER = 0| 
i:  1679  |      MAX_OL_TABLE_NUMBER = 0| 
i:  1680  |      FILE_NAME = trim(BASE_FILE_DIRECTORY())//| 
i:  1681  |     +                              "ENB"//trim(ENV_COM_FIL())//".DAT"| 
i:  1682  || 
i:  1683  |      INQUIRE(FILE=FILE_NAME,EXIST=ENVIR_FILE_EXISTS)| 
i:  1684  |      IF(ENVIR_FILE_EXISTS) THEN| 
i:  1685  |         IF(LAHEY_LF95()) THEN| 
i:  1686  |            SCREEN_OUTPUT = trim(FILE_TYPE)//'-'//ENV_COM_FIL()| 
i:  1687  |            CALL MG_LOCATE_WRITE(16,30,SCREEN_OUTPUT,ALL_VERSIONS,0)| 
i:  1688  |         ELSE| 
i:  1689  |            CALL MG_LOCATE_WRITE(16,30,ENV_COM_FIL(),ALL_VERSIONS,0)| 
i:  1690  |            CALL MG_CLEAR_LINE_WRITE(17,9,36,FILE_TYPE,ALL_VERSIONS,0)| 
i:  1691  |         ENDIF| 
i:  1692  |         OPEN(10,FILE=FILE_NAME)| 
i:  1693  |         OPEN(11,FILE=trim(OUTPUT_DIRECTORY())//"BCENVCOM.BIN",| 
i:  1694  |     +                      ACCESS="DIRECT",STATUS="REPLACE",RECL=LRECL)| 
i:  1695  |C INITIALIZE VARIABLES| 
i:  1696  |         EPA_EAS = 0.| 
i:  1697  |         EPA_SETASIDE_RATE = 0.| 
i:  1698  |         CLASS_NUM = 0| 
i:  1699  |         DO EMIS_TYPE = 1, NUMBER_OF_EMISSION_TYPES| 
i:  1700  |            EMIS_DISPATCH_ADDER(EMIS_TYPE) = 0.| 
i:  1701  |            EMIS_CAP(EMIS_TYPE) = 0.| 
i:  1702  |            PURCH_CRED_PRICE(EMIS_TYPE) = 0.| 
i:  1703  |            SELL_CRED_PRICE(EMIS_TYPE) = 0.| 
i:  1704  |            EMIS_STRAT(EMIS_TYPE) = "N"| 
i:  1705  |            MIN_BANK(EMIS_TYPE) = 0.| 
i:  1706  |            MAX_BANK(EMIS_TYPE) = 0.| 
i:  1707  |         ENDDO| 
i:  1708  |         FIRST_RECORD_OF_TABLE = INIT_CREATE_CLASS_LIST(INT2(0))| 
i:  1709  |C| 
i:  1710  |         READ(10,*,IOSTAT=IOS) DELETE| 
i:  1711  |         IREC = 0| 
i:  1712  |         DO| 
i:  1713  |            FIRST_RECORD_OF_TABLE = .TRUE.| 
i:  1714  |            DATA_RECORDS_IN_TABLE = 0| 
i:  1715  |            CO2_PUSH_OK = 'No'| 
i:  1716  |            SO2_PUSH_OK = 'No'| 
i:  1717  |            DO| 
i:  1718  |               READ(10,1000,IOSTAT=IOS) RECLN| 
i:  1719  |               IF(IOS /=0) EXIT| 
i:  1720  |               IF(RECLN(1:1) == '7') EXIT| 
i:  1721  |               RECLN = trim(RECLN)//',,,,,,,,,,,,,,,,,,,,,,,'//| 
i:  1722  |     +                               ',,,,,,,,,,,,,,,,,,,,,,,,'| 
i:  1723  |               READ(RECLN,*,ERR=200) DELETE,YEAR,| 
i:  1724  |     +           (EMIS_DISPATCH_ADDER(I),I=1,3),(EMIS_CAP(I),I=1,3),| 
i:  1725  |     +           (PURCH_CRED_PRICE(I),I=1,3),(SELL_CRED_PRICE(I),I=1,3),| 
i:  1726  |     +           COMMENT,(EMIS_STRAT(I),I=1,3),(MIN_BANK(I),I=1,3),| 
i:  1727  |     +           (MAX_BANK(I),I=1,3),EPA_EAS,EPA_SETASIDE_RATE,| 
i:  1728  |     +           (EMIS_DISPATCH_ADDER(I),I=4,5),(EMIS_CAP(I),I=4,5),| 
i:  1729  |     +           (PURCH_CRED_PRICE(I),I=4,5),(SELL_CRED_PRICE(I),I=4,5),| 
i:  1730  |     +           (EMIS_STRAT(I),I=4,5),(MIN_BANK(I),I=4,5),| 
i:  1731  |     +           (MAX_BANK(I),I=4,5),CLASS_NAME,CLASS_NUM,| 
i:  1732  |     +            (EMISS_COMMENT,I=1,5),| 
i:  1733  |     +            CO2_PUSH_OK,| 
i:  1734  |     +            SO2_PUSH_OK| 
i:  1735  |               IF(INDEX(CO2_PUSH_OK,'Yes') == 0) CO2_PUSH_OK = 'No'| 
i:  1736  |               IF(INDEX(SO2_PUSH_OK,'Yes') == 0) SO2_PUSH_OK = 'No'| 
i:  1737  |C     +           GRX_UPDATES_CO2_PRICES| 
i:  1738  |c               IF(TRANSACT_ANALYST_ONLY() .AND.| 
i:  1739  |c     +                        .NOT. INIT_FILE_IS_ACTIVE()) CLASS_NUM = 0| 
i:  1740  |               IF(.NOT. INIT_FILE_IS_ACTIVE()) CLASS_NUM = 0| 
i:  1741  |               IREC = IREC + 1| 
i:  1742  |               WRITE(11,REC=IREC) DELETE,YEAR,| 
i:  1743  |     +             EMIS_DISPATCH_ADDER,| 
i:  1744  |     +             EMIS_CAP,PURCH_CRED_PRICE,SELL_CRED_PRICE,EMIS_STRAT,| 
i:  1745  |     +             MIN_BANK,MAX_BANK,EPA_EAS,EPA_SETASIDE_RATE,| 
i:  1746  |     +             CO2_PUSH_OK,SO2_PUSH_OK,CLASS_NAME,CLASS_NUM| 
i:  1747  |               DATA_RECORDS_IN_TABLE = DATA_RECORDS_IN_TABLE + 1| 
i:  1748  |C| 
i:  1749  |               IF(FIRST_RECORD_OF_TABLE) THEN| 
i:  1750  |                  VOID_INT2 = CREATE_CLASS_LIST(CLASS_NUM)| 
i:  1751  |                  FIRST_RECORD_OF_TABLE = .FALSE.| 
i:  1752  |               ENDIF| 
i:  1753  |            ENDDO| 
i:  1754  |            IF(DATA_RECORDS_IN_TABLE < AVAIL_DATA_YEARS) THEN| 
i:  1755  |               DOWHILE (DATA_RECORDS_IN_TABLE < AVAIL_DATA_YEARS)| 
i:  1756  |                  IREC = IREC + 1| 
i:  1757  |                  WRITE(11,REC=IREC) DELETE,YEAR,| 
i:  1758  |     +                      EMIS_DISPATCH_ADDER,| 
i:  1759  |     +                      EMIS_CAP,PURCH_CRED_PRICE,| 
i:  1760  |     +                      SELL_CRED_PRICE,EMIS_STRAT,| 
i:  1761  |     +                      MIN_BANK,MAX_BANK,EPA_EAS,EPA_SETASIDE_RATE,| 
i:  1762  |     +                      CO2_PUSH_OK,SO2_PUSH_OK,CLASS_NAME,CLASS_NUM| 
i:  1763  |                  DATA_RECORDS_IN_TABLE = DATA_RECORDS_IN_TABLE + 1| 
i:  1764  |               ENDDO| 
i:  1765  |            ENDIF| 
i:  1766  |            IF(IOS /= 0) EXIT| 
i:  1767  |         ENDDO| 
i:  1768  |         CLOSE(10)| 
i:  1769  |C        ENDFILE(11)| 
i:  1770  |         CLOSE(11)| 
i:  1771  |         MAX_BC_CLASS_NUMBER = MAX_CLASS_IN_TABLE()| 
i:  1772  |         ALLOCATE(BC_TABLE_POSITION_FOR(0:MAX_BC_CLASS_NUMBER))| 
i:  1773  |         MAX_BC_TABLE_NUMBER = PASS_TABLE_POINTER(BC_TABLE_POSITION_FOR)| 
i:  1774  |      ELSE IF(INDEX(ENV_COM_FIL(),'NONE') == 0) THEN| 
i:  1775  |         CALL STOP_NOFILE(FILE_TYPE,FILE_NAME)| 
i:  1776  |      ENDIF| 
i:  1777  |      RETURN| 
