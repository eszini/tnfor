1881 |                  IF(CNTR_CAPACITY_SWITCH(CONTRACT) .EQ. 'V') THEN|
1882 |                     TEMP_FIX_CURRENT = 12.*1000.*|
1883 |     +                  CONTRACT_FIXED_COST(CONTRACT)/|
