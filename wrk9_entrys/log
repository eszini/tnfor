1748 |      SAVE PALO_ALTO_ACTIVE|
1749 |!|
1750 |!|
1751 |!|
1752 |! INTEGRATE ALONG THE ELDC UNTIL THE TARGET CAPACITY|
1753 |! AND ENERGY IS MET, OR ALL POINTS ON THE LOAD CURVE ARE EVALUATED.|
1754 |!|
1755 |! DETERMINE THE LOWEST COST CONTRACT FOR THE NEXT LOAD INTERVAL(S)|
1756 |! THE ORDERED PAIR (RIGHT,A) ACTS AS THE STARTING POINT FOR THE|
1757 |! EVALUATION.|
1758 |!|
1759 |      INTPL8(X1,Y1,X3,Y2,X2) = Y1 + (Y2-Y1) * (X3-X1)/(X2-X1)|
1760 |      CALL RETURN_TIER_2(TIER_2_ENERGY,TIER_2_CT)|
1761 |      CALL USING_FIXED_LOGIC(FIXED_COST_LOGIC)|
1762 |      LAST_ENERGY_ONLY_PRICE = GET_LAST_ENERGY_ONLY_PRICE()|
1763 |!|
1764 |      PRODUCTION_COST_PERIODS = PRODUCTION_PERIODS()|
1765 |      IF(B .GT. LODDUR(1)) THEN|
1766 |         ISTOP = MAX(ISTART,1)|
1767 |         DOWHILE(.NOT.(LODDUR(ISTOP).LE.B .AND. B.LE.LODDUR(ISTOP+1)))|
1768 |            IF(LODDUR(ISTOP) .GT. B) THEN|
1769 |               ISTOP = ISTOP - 1|
1770 |            ELSE|
1771 |               ISTOP = ISTOP + 1|
1772 |            ENDIF|
1773 |         ENDDO|
1774 |         RIGHT = INTPL8(LODDUR(ISTOP),LPROB(ISTOP),B,|
1775 |     +           LPROB(ISTOP+1),LODDUR(ISTOP+1))|
