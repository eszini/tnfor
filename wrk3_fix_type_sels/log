318 |character*1 function GetCh(KeyType)|
319 |  use SpinFuncLocals|
320 |  integer*1 KeyType,B,AsciiCode|
321 |  character*1 KeyedChar,UCKC,UpCase|
322 |  logical*1 AltPrefix,CtlPrefix,NulPrefix,EscKeyStruck|
323 ||
324 |! do|
325 |!   Regs(1)=Z'0200' ! BIOS function used to read the kbd flags|
326 |!   call intrup(Regs,Z'16')|
327 |!   B=iand(Regs(1),Z'ff')|
328 |!   AltPrefix=iand(B,Z'08')>0|
329 |!   CtlPrefix=iand(B,Z'04')>0|
330 |!   if(KeyAvail()) exit|
331 |! end do|
332 ||
333 |  AltPrefix=.false.|
334 |  CtlPrefix=.false.|
335 |  call ReadKey(AsciiCode)|
336 |  EscKeyStruck=AsciiCode==27|
337 |  NulPrefix=AsciiCode==0|
338 |!!write(*,*)AltPrefix,CtlPrefix,NulPrefix,EscKeyStruck,AsciiCode,char(AsciiCode)|
339 |  if(NulPrefix) then ! extended-ASCII keys return a 0-byte prefix|
340 |!   if(KeyAvail()) call ReadKey(AsciiCode) ! flush the keystroke buffer|
341 |                   call ReadKey(AsciiCode) ! flush the keystroke buffer|
342 |  end if|
343 |!!write(*,*)AltPrefix,CtlPrefix,NulPrefix,EscKeyStruck,AsciiCode,char(AsciiCode)|
344 |  KeyedChar=char(AsciiCode)|
345 |  UCKC=UpCase(KeyedChar)|
346 ||
347 |!!if(AltPrefix .and.((15<=AsciiCode).and.(AsciiCode<=50))) then|
348 |!!  KeyedChar=AltChar(AsciiCode)|
349 |!!  AsciiCode=iAChar(KeyedChar)|
350 |!!end if ! decoding the keyboard-specific scan-codes|
351 ||
352 |!!KeyType is coded to conform with Spindrift; ignore Function keys F11 & F12|
353 |  if(NulPrefix) then|
354 |    if    ((59<=AsciiCode).and.(AsciiCode<=68)) then|
355 |      KeyType=0 ! Function-key|
356 |    elseif(((71<=AsciiCode).and.(AsciiCode<=73)).or. &|
357 |           ((75<=AsciiCode).and.(AsciiCode<=77)).or. &|
358 |           ((79<=AsciiCode).and.(AsciiCode<=83))) then|
359 |      KeyType=8 ! Edit-key|
360 |    end if|
361 |  elseif(AltPrefix) then; KeyType=64 ! Alt-key|
362 |  elseif(AsciiCode==13) then; KeyType=4 ! Enter-key|
363 |  elseif(EscKeyStruck) then; KeyType=16 ! Esc-key|
364 |  elseif(((48<=AsciiCode).and.(AsciiCode<=57)).or. & ! '0'..'9'|
365 |    (KeyedChar=='+').or. &|
366 |    (KeyedChar=='-').or. &|
367 |    (KeyedChar=='.')) then; KeyType=3 ! Numeric|
368 |  elseif(CtlPrefix) then|
369 |  ! if    (KeyedChar=='m') then; KeyType=4 ! Enter-key|
370 |    if    (KeyedChar=='h') then; KeyType=8 ! Edit-key (backspace)|
371 |    elseif(KeyedChar=='i') then; KeyType=8 ! Edit-key (tab)|
372 |    elseif(KeyedChar=='j') then; KeyType=8 ! Edit-key (linefeed)|
373 |    elseif(KeyedChar=='(') then; KeyType=16 ! Esc-key|
374 |    else                       ; KeyType=32 ! Ctrl-key|
375 |    end if|
376 |  elseif((8<=AsciiCode).and.(AsciiCode<=10)) then; KeyType=8 ! Edit-key (BS,tab,LF)|
377 |!!elseif(('A'<=UCKC).and.(UCKC<='Z')) then; KeyType:= 2; ! Alphabetic|
378 |  else; KeyType=2 ! Alphabetic (seems the safest default)|
379 |  end if|
380 |!!write(*,*)KeyType,AsciiCode,KeyedChar|
381 |  GetCh=KeyedChar|
382 |end ! function GetCh|
