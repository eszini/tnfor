574 |subroutine ConditionalQuickI(nItems,a,iPos,Condition) ! sorts nItems items into ascending order|
575 |!!based on values in (1-based) key array a;|
576 |!!Shell sort adapted from the source on page 110 of|
577 |!!SOFTWARE TOOLS IN PASCAL, by Kernighan & Plauger, Addison-Wesley 1981|
578 |  integer*4 nItems,i,j,k,Gap,iPsHeld,iPos(*)|
579 |  integer*2 a(nItems),Condition(nItems)|
580 ||
581 |  do i=1,nItems ! assume that the caller has not initialized the index array|
582 |    iPos(i)=i|
583 |  end do|
584 |  Gap=nItems/2|
585 |  do while(Gap>0)|
586 |    do i=Gap,nItems|
587 |      j=i-Gap|
588 |      do while(j>0)|
589 |        k=j+Gap|
590 |        if(a(iPos(j))<=a(iPos(k)) .or. Condition(iPos(j))<=Condition(iPos(k))) then|
591 |          j=0 ! break the while loop (assign j=-1 for 0-based arrays)|
592 |        else ! interchange the indexing array values|
593 |          iPsHeld=iPos(k)|
594 |          iPos(k)=iPos(j)|
595 |          iPos(j)=iPsHeld|
596 |        end if|
597 |        j=j-Gap|
598 |        CALL RW_PROCESS_MESSAGES()|
599 |      end do|
600 |      CALL RW_PROCESS_MESSAGES()|
601 |    end do|
602 |    Gap=Gap/2|
603 |    CALL RW_PROCESS_MESSAGES()|
604 |  end do|
