508 |subroutine QuickR(nItems,a,iPos) ! sorts nItems items into ascending order|
509 |!!based on values in (1-based) key array a;|
510 |!!Shell sort adapted from the source on page 110 of|
511 |!!SOFTWARE TOOLS IN PASCAL, by Kernighan & Plauger, Addison-Wesley 1981|
512 |  integer*4 nItems,i,j,k,Gap,iPsHeld,iPos(*)|
513 |  real*4 a(*)|
514 ||
515 |  do i=1,nItems ! assume that the caller has not initialized the index array|
516 |    iPos(i)=i|
517 |  end do|
518 |  Gap=nItems/2|
519 |  do while(Gap>0)|
520 |    do i=Gap,nItems|
521 |      j=i-Gap|
522 |      do while(j>0)|
523 |        k=j+Gap|
524 |        if(a(iPos(j))<=a(iPos(k))) then|
525 |          j=0 ! break the while loop (assign j=-1 for 0-based arrays)|
526 |        else ! interchange the indexing array values|
527 |          iPsHeld=iPos(k)|
528 |          iPos(k)=iPos(j)|
529 |          iPos(j)=iPsHeld|
530 |        end if|
531 |        j=j-Gap|
532 |        CALL RW_PROCESS_MESSAGES()|
533 |      end do|
534 |      CALL RW_PROCESS_MESSAGES()|
535 |    end do|
536 |    Gap=Gap/2|
537 |    CALL RW_PROCESS_MESSAGES()|
538 |  end do|
539 |end ! subroutine QuickR|
