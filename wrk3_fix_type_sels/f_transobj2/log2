13358 |         IF(R_HIGHEST_INTERVAL < 1) THEN|
13359 |            RETURN|
13360 |         ELSEIF(R_HIGHEST_INTERVAL == PRICE_POINTS) THEN|
13361 |            IF(R_TRANS_GROUP == 0) THEN|
13362 |               MRX_VOLATILITY_MULT = 1.0|
13363 |            ELSE|
13364 |               MRX_VOLATILITY_MULT =|
13365 |     +                  GET_MRX_VOLATILITY_MULT(R_TRANS_GROUP)|
13366 |            ENDIF|
13367 |!|
13368 |            MX_MAX_PRICE = LODDUR(PRICE_POINTS,R_TRANS_GROUP,R_ISEAS)|
13369 |            MX_MIN_PRICE = LODDUR(1,R_TRANS_GROUP,R_ISEAS)|
13370 |!|
13371 |            IF(MX_MIN_PRICE == MX_MAX_PRICE) THEN|
13372 |               MX_SLOPE = 1.0|
13373 |               MX_INTERCEPT = 0.|
13374 |            ELSE|
13375 |               MX_SLOPE =|
13376 |     +            ( MRX_VOLATILITY_MULT*MX_MAX_PRICE - MX_MIN_PRICE ) /|
13377 |     +                                     (MX_MAX_PRICE - MX_MIN_PRICE)|
13378 |               MX_INTERCEPT = MX_MIN_PRICE * ( 1. - MX_SLOPE)|
13379 |            ENDIF|
13380 |!|
13381 |!|
13382 |
|
13383 |            DO I = PRICE_POINTS, 1, -1|
13384 |               R_INTERVALS(I) = CUM_HOURS(I,R_TRANS_GROUP,R_ISEAS)|
13385 |!               R_PRICES(I) = LODDUR(I,R_TRANS_GROUP)|
13386 |               R_PRICES(I) =|
13387 |     +                 (MX_INTERCEPT + MX_SLOPE *|
13388 |     +                                  LODDUR(I,R_TRANS_GROUP,R_ISEAS))|
13389 |               IF(LODDUR(I,R_TRANS_GROUP,R_ISEAS) > 0.) THEN|
13390 |                  PRICE_MULT = R_PRICES(I) /|
13391 |     +                                   LODDUR(I,R_TRANS_GROUP,R_ISEAS)|
13392 |               ELSE|
13393 |                  PRICE_MULT = 1.0|
13394 |               ENDIF|
13395 |!               R_CUM_REVENUES(I) = CUM_REVENUE(I,R_TRANS_GROUP)|
13396 |               R_CUM_REVENUES(I) =|
13397 |     +                   PRICE_MULT*CUM_REVENUE(I,R_TRANS_GROUP,R_ISEAS)|
13398 |            ENDDO|
13399 |            RETURN|
13400 |         ENDIF|
13401 |!|
13402 |         IF(R_TRANS_GROUP == 0) THEN|
13403 |            MRX_VOLATILITY_MULT = 1.0|
13404 |         ELSE|
13405 |            MRX_VOLATILITY_MULT =|
13406 |     +                  GET_MRX_VOLATILITY_MULT(R_TRANS_GROUP)|
13407 |         ENDIF|
13408 |!|
13409 |         MX_MAX_PRICE = LODDUR(PRICE_POINTS,R_TRANS_GROUP,R_ISEAS)|
13410 |         MX_MIN_PRICE = LODDUR(PRICE_POINTS,R_TRANS_GROUP,R_ISEAS)|
13411 |!|
13412 |         R_INTERVALS(R_HIGHEST_INTERVAL) =|
13413 |     +                     CUM_HOURS(PRICE_POINTS,R_TRANS_GROUP,R_ISEAS)|
13414 |         R_CUM_REVENUES(R_HIGHEST_INTERVAL) =|
13415 |     +                   CUM_REVENUE(PRICE_POINTS,R_TRANS_GROUP,R_ISEAS)|
13416 |         R_PRICES(R_HIGHEST_INTERVAL) =|
13417 |     +                        LODDUR(PRICE_POINTS,R_TRANS_GROUP,R_ISEAS)|
13418 |         R_INTERVALS(0) = CUM_HOURS(1,R_TRANS_GROUP,R_ISEAS)|
13419 |         R_CUM_REVENUES(0) = CUM_REVENUE(1,R_TRANS_GROUP,R_ISEAS)|
13420 |         R_PRICES(0) = LODDUR(1,R_TRANS_GROUP,R_ISEAS)|
13421 |!|
13422 |! FIND THE CUM_REVENUE/CUM_HOURS INTERVAL THAT CONTAINS MX_HOURS|
13423 |!|
13424 |         MX_INCREMENT = CUM_HOURS(1,R_TRANS_GROUP,R_ISEAS)/|
13425 |     +                                                R_HIGHEST_INTERVAL|
13426 |         MX_INTERVAL = 1|
13427 |!|
13428 |         R_INTERVALS(MX_INTERVAL) = R_INTERVALS(MX_INTERVAL-1) -|
13429 |     +                                                      MX_INCREMENT|
13430 |!|
13431 |         IF(MX_MIN_PRICE == MX_MAX_PRICE) THEN|
13432 |            MX_SLOPE = 1.0|
13433 |            MX_INTERCEPT = 0.|
13434 |         ELSE|
13435 |            MX_SLOPE =|
13436 |     +        ( MRX_VOLATILITY_MULT*MX_MAX_PRICE - MX_MIN_PRICE ) /|
13437 |     +                                     (MX_MAX_PRICE - MX_MIN_PRICE)|
13438 |            MX_INTERCEPT = MX_MIN_PRICE * ( 1. - MX_SLOPE)|
13439 |         ENDIF|
13440 |!|
13441 |         DO I = 2, PRICE_POINTS|
13442 |!|
13443 |            IF(CUM_HOURS(I,R_TRANS_GROUP,R_ISEAS)|
13444 |     +                                >= R_INTERVALS(MX_INTERVAL)) CYCLE|
13445 |!|
13446 |! FIND THE PRICING.|
13447 |!|
13448 |!|
13449 |            DOWHILE (R_INTERVALS(MX_INTERVAL) >|
13450 |     +                               CUM_HOURS(I,R_TRANS_GROUP,R_ISEAS))|
13451 |!|
13452 |               IF(R_INTERVALS(MX_INTERVAL) -|
13453 |     +                           R_INTERVALS(MX_INTERVAL-1) /= 0.0) THEN|
13454 |                  TOP_CAP_PERCENT =|
13455 |     +               (R_INTERVALS(MX_INTERVAL) -|
13456 |     +                           CUM_HOURS(I-1,R_TRANS_GROUP,R_ISEAS)) /|
13457 |     +                     (CUM_HOURS(I,R_TRANS_GROUP,R_ISEAS) -|
13458 |     +                             CUM_HOURS(I-1,R_TRANS_GROUP,R_ISEAS))|
13459 |               ELSE|
13460 |                  TOP_CAP_PERCENT = 0.0|
13461 |               ENDIF|
13462 |!|
13463 |!|
13464 |!|
13465 |               R_PRICES(MX_INTERVAL) =|
13466 |     +                  TOP_CAP_PERCENT *|
13467 |     +               (MX_INTERCEPT +|
13468 |     +                       MX_SLOPE*LODDUR(I,R_TRANS_GROUP,R_ISEAS)) +|
13469 |     +                           (1.-TOP_CAP_PERCENT) *|
13470 |     +               (MX_INTERCEPT +|
13471 |     +                       MX_SLOPE*LODDUR(I-1,R_TRANS_GROUP,R_ISEAS))|
13472 |               R_CUM_REVENUES(MX_INTERVAL) =|
13473 |     +                 TOP_CAP_PERCENT *|
13474 |     +               (MX_INTERCEPT +|
13475 |     +                  MX_SLOPE*CUM_REVENUE(I,R_TRANS_GROUP,R_ISEAS)) +|
13476 |     +                           (1.-TOP_CAP_PERCENT) *|
13477 |     +               (MX_INTERCEPT +|
13478 |     +                  MX_SLOPE*CUM_REVENUE(I-1,R_TRANS_GROUP,R_ISEAS))|
13479 |!|
13480 |               MX_INTERVAL = MX_INTERVAL + 1|
13481 |               R_INTERVALS(MX_INTERVAL) = R_INTERVALS(MX_INTERVAL-1) -|
13482 |     +                                                      MX_INCREMENT|
13483 |!|
13484 |            ENDDO ! MULTIPLE INTERVALS BETWEEN TWO PRICE POINTS|
13485 |!|
13486 |
|
13487 |!|
13488 |         ENDDO ! SEARCHING FOR PRICE_POINTS CROSSOVER|
13489 |!|
13490 |      RETURN|
13491 |      END|
13492 |!***********************************************************************|
13493 |!|
13494 |!     ROUTINE TO CALCULATE THE MARKET PRICE PROBABILITY|
13495 |!                 CURVE ON AN ODD SPACED GRID|
13496 |!|
13497 |!***********************************************************************|
13498 |!|
13499 |      SUBROUTINE MARKET_PRICE_PROB(HOURS,HOURS_INCREMENT,|
13500 |     +                              MARKET_PRICE,SUM_MARKET_PRICES,|
13501 |     +                              MAX_MARKET_PRICE,MIN_MARKET_PRICE,|
13502 |     +                              R_ISEAS)|
13503 |!|
13504 |      INCLUDE 'SpinLib.MON'|
13505 |      USE IREC_ENDPOINT_CONTROL|
13506 |      use GRX_PLANNING_ROUTINES|
13507 |      use rptreccontrol|
13508 |      USE SIZECOM|
13509 |      SAVE|
13510 |
|
13511 |      INCLUDE 'GLOBECOM.MON'|
13512 |      INTEGER*2 PRICE_POINTS,MAX_POINTS|
13513 |      PARAMETER (PRICE_POINTS=79)|
13514 |      INTEGER*2   I,HR,IMAX,HOURS,HOURS_INCREMENT,IPEAK,COUNT,|
13515 |     +            INTERVALS,COUNTER,POINTS_IN_CURVE,ISEAS,R_ISEAS|
13516 |      INTEGER*2   IPNT,STORE_IPNT,HALF_POINT,START,END,|
13517 |     +            R_HIGHEST_INTERVAL,MX_INTERVAL|
13518 |      REAL PEAK,BASE,OBS(PRICE_POINTS,13),DELTA_PROB,AREA,|
13519 |     +     MIN_LPROB,OBSERVATIONS|
13520 |      REAL LPROB(PRICE_POINTS,13),|
13521 |     +     DX,|
13522 |     +     LODDUR(PRICE_POINTS,13),|
13523 |     +     CUM_HOURS(PRICE_POINTS,13),|
13524 |     +     CUM_REVENUE(PRICE_POINTS,13),|
13525 |     +     MARKET_PRICE(8800),|
13526 |     +     AVE_REVENUE,|
13527 |     +     MAX_MARKET_PRICE,|
13528 |     +     MIN_MARKET_PRICE,LOAD_VAL,PEAK_DX,BASE_DX,|
13529 |     +     BASE_ADJUSTMENT,INTERVAL_HOURS,|
13530 |     +     R_CF,R_AVE_REVENUE,TOP_CAP_PERCENT,|
13531 |     +     TOP_AVE_REVENUE,BOTTOM_AVE_REVENUE,TOTAL_PERIOD_HOURS,|
13532 |     +     TOTAL_RESOURCE_HOURS,R_PRICES(0:*),R_INTERVALS(0:*),|
13533 |     +     R_CUM_REVENUES(0:*),|
13534 |     +     MX_INCREMENT|
13535 |      REAL*8   SUM_MARKET_PRICES,DEMAND,|
13536 |     +         ENERGY(PRICE_POINTS,13),ALPHA,PRECISN|
13537 |!|
13538 |      REAL*4 TEMP_INTERVALS,TEMP_VALUE|
13539 |      LOGICAL*1 SET_POINTS,POINT_NOT_FOUND|
13540 |      INTEGER*2 SET_CURRENT_IPNT|
13541 |!|
13542 |      LOGICAL*1   MARKET_DURATION_NOT_OPEN/.TRUE./,YES_MARKET_DURATION,|
13543 |     +            MARKET_DURATION_REPORT|
13544 |      INTEGER*2   MARKET_DURATION_NO,MARKET_DURATION_HEADER,|
13545 |     +            CURRENT_MONTH,|
13546 |     +            LAST_SEASON/0/,PRODUCTION_PERIODS,CURRENT_YEAR|
13547 |      CHARACTER*9 CL_MONTH_NAME(13)|
13548 |      CHARACTER*20 MONTH_NAME,R_UNIT_NAME|
13549 |      INTEGER MARKET_DURATION_REC|
13550 |!|
13551 |! SAVE ARRAY 8/15/01 MSG|
13552 |!|
13553 |!      SAVE LODDUR,LPROB,CUM_HOURS,CUM_REVENUE|
13554 |!!|
13555 |!      SAVE MARKET_DURATION_NO,MARKET_DURATION_REC|
13556 |!|
13557 |!     END OF DATA DECLARATIONS|
13558 |!|
13559 |!|
13560 |!|
13561 |      YES_MARKET_DURATION = MARKET_DURATION_REPORT()|
13562 |!|
13563 |      IF(MARKET_DURATION_NOT_OPEN .AND.|
13564 |     +                  YES_MARKET_DURATION .AND.|
13565 |     +                                         .NOT. TESTING_PLAN ) THEN|
13566 |         MARKET_DURATION_NOT_OPEN = .FALSE.|
13567 |         MARKET_DURATION_NO = MARKET_DURATION_HEADER(|
13568 |     +                                              MARKET_DURATION_REC)|
13569 |         LAST_SEASON = PRODUCTION_PERIODS()|
13570 |         DO CURRENT_MONTH = 1, LAST_SEASON|
13571 |            CL_MONTH_NAME(CURRENT_MONTH) = MONTH_NAME(CURRENT_MONTH)|
13572 |         ENDDO|
13573 |         CL_MONTH_NAME(LAST_SEASON+1) = 'Annual'|
13574 |      ENDIF|
13575 |!|
13576 |      CURRENT_YEAR = BASE_YEAR + YEAR|
13577 |!|
13578 |!|
13579 |      BASE_ADJUSTMENT = -999.|
13580 |      INTERVALS = PRICE_POINTS/2 + 1|
13581 |      DX = MAX((MAX_MARKET_PRICE-MIN_MARKET_PRICE)/FLOAT(INTERVALS-1),|
13582 |     +                                                             0.01)|
13583 |      POINTS_IN_CURVE = PRICE_POINTS|
13584 |!|
13585 |      PEAK = MAX_MARKET_PRICE|
13586 |      BASE = MIN_MARKET_PRICE|
13587 |!|
13588 |      DO I = 1, PRICE_POINTS|
13589 |         CUM_HOURS(I,R_ISEAS) = 0.|
13590 |         CUM_REVENUE(I,R_ISEAS) = 0.|
13591 |         ENERGY(I,R_ISEAS)= 0.|
13592 |         OBS(I,R_ISEAS) = 0.|
13593 |         LPROB(I,R_ISEAS) = 0.|
13594 |      ENDDO|
13595 |      LPROB(1,R_ISEAS) = 1.|
13596 |!|
13597 |      LODDUR(1,R_ISEAS) = BASE|
13598 |      COUNT = 1|
13599 |      DOWHILE (LODDUR(COUNT,R_ISEAS) < PEAK .AND.|
13600 |     +                                       COUNT + 2 <= PRICE_POINTS )|
13601 |         COUNT = COUNT + 2|
13602 |         LODDUR(COUNT,R_ISEAS) = LODDUR(COUNT-2,R_ISEAS) + DX|
13603 |      ENDDO|
13604 |!|
13605 |      IF(COUNT > PRICE_POINTS) THEN|
13606 |         WRITE(4,*) "In the Market Duration Curve Report"|
13607 |         WRITE(4,*) "the model detected an abnormal price series."|
13608 |         WRITE(4,*) "Model reassigned the distribution of prices."|
13609 |         COUNT = PRICE_POINTS|
13610 |      ENDIF|
13611 |!|
13612 |      IF(LODDUR(COUNT,R_ISEAS) < PEAK) THEN|
13613 |         TEMP_VALUE = LODDUR(COUNT,R_ISEAS) - PEAK|
13614 |      ENDIF|
13615 |      IF(COUNT < 3) THEN|
13616 |         WRITE(4,*) "Market prices appear to be flat."|
13617 |         WRITE(4,*) "Please check that Multi-area simulation"|
13618 |         WRITE(4,*) "has at least two market areas."|
13619 |!         STOP|
13620 |         RETURN ! NOT THE BEST WAY TO HANDLE THIS.|
13621 |      ENDIF|
13622 |      IF(PEAK - LODDUR(COUNT-2,R_ISEAS) < .0001*DX) COUNT = COUNT - 2|
13623 |      LODDUR(COUNT,R_ISEAS) = PEAK|
13624 |      POINTS_IN_CURVE = COUNT|
13625 |      IMAX = COUNT|
13626 |      INTERVALS = COUNT/2 + 1|
13627 |      IPEAK = INTERVALS - 1|
13628 |      DO I = COUNT + 1, PRICE_POINTS|
13629 |         LODDUR(I,R_ISEAS) = LODDUR(I-1,R_ISEAS) + DX|
13630 |      ENDDO|
13631 |!|
13632 |!     PLACES MARKET PRICES INTO PRICE_POINTS/2 - 1 INTERVALS|
13633 |!|
13634 |      DO HR = HOURS,HOURS+HOURS_INCREMENT-1|
13635 |         IF(MARKET_PRICE(HR) .GE. BASE) THEN|
13636 |            I = AINT((MARKET_PRICE(HR) +.0001 - BASE)/DX) + 1|
13637 |            IF(I.GT.IPEAK) I = IPEAK|
13638 |            OBS(I,R_ISEAS) = OBS(I,R_ISEAS) + 1.|
13639 |            ENERGY(I,R_ISEAS) = ENERGY(I,R_ISEAS) + MARKET_PRICE(HR)|
13640 |         ENDIF|
13641 |      ENDDO|
13642 |!|
13643 |!|
13644 |      MIN_LPROB = 1./FLOAT(HOURS_INCREMENT)|
13645 |      OBSERVATIONS = 0.|
13646 |      DO I = 2 , INTERVALS|
13647 |         COUNT = 2*(I) - 2|
13648 |         OBSERVATIONS = OBSERVATIONS + OBS(I-1,R_ISEAS)|
13649 |         DELTA_PROB = 1. - OBSERVATIONS/FLOAT(HOURS_INCREMENT)|
13650 |!|
13651 |!|
13652 |!|
13653 |         IF(OBS(I-1,R_ISEAS) .LE. 0.) THEN|
13654 |            LPROB(COUNT+1,R_ISEAS) = LPROB(COUNT-1,R_ISEAS)|
13655 |            LPROB(COUNT,R_ISEAS) = LPROB(COUNT-1,R_ISEAS)|
13656 |            LODDUR(COUNT,R_ISEAS) = (LODDUR(COUNT+1,R_ISEAS)+|
13657 |     +                                       LODDUR(COUNT-1,R_ISEAS))/2.|
13658 |         ELSE|
13659 |            LODDUR(COUNT,R_ISEAS) = ENERGY(I-1,R_ISEAS)/OBS(I-1,R_ISEAS)|
13660 |            LPROB(COUNT+1,R_ISEAS) = DELTA_PROB|
13661 |            IF(LPROB(COUNT+1,R_ISEAS) < MIN_LPROB)|
13662 |     +                                       LPROB(COUNT+1,R_ISEAS) = 0.|
13663 |            AREA = (ENERGY(I-1,R_ISEAS)-LODDUR(COUNT-1,R_ISEAS)*|
13664 |     +                                                OBS(I-1,R_ISEAS))/|
13665 |     +         FLOAT(HOURS_INCREMENT) +|
13666 |     +         LPROB(COUNT+1,R_ISEAS)*(LODDUR(COUNT+1,R_ISEAS) -|
13667 |     +                                          LODDUR(COUNT-1,R_ISEAS))|
13668 |            LPROB(COUNT,R_ISEAS) = (2*AREA -|
13669 |     +         (LPROB(COUNT-1,R_ISEAS)*(LODDUR(COUNT,R_ISEAS)-|
13670 |     +                                        LODDUR(COUNT-1,R_ISEAS)) +|
13671 |     +         LPROB(COUNT+1,R_ISEAS)*(LODDUR(COUNT+1,R_ISEAS)-|
13672 |     +                                      LODDUR(COUNT,R_ISEAS)))  ) /|
13673 |     +         (LODDUR(COUNT+1,R_ISEAS)-LODDUR(COUNT-1,R_ISEAS))|
13674 |!|
13675 |            IF( ENERGY(I-1,R_ISEAS)/(OBS(I-1,R_ISEAS) *|
13676 |     +                                          LODDUR(COUNT+1,R_ISEAS))|
13677 |     +                                  > .999999 ) THEN|
13678 |               LODDUR(COUNT,R_ISEAS) = LODDUR(COUNT+1,R_ISEAS)|
13679 |               IF(LODDUR(COUNT+1,R_ISEAS) < 10000) THEN|
13680 |                  LODDUR(COUNT+1,R_ISEAS) =|
13681 |     +                                    LODDUR(COUNT+1,R_ISEAS) + .001|
13682 |               ELSE|
13683 |                  LODDUR(COUNT+1,R_ISEAS) =|
13684 |     +                                     LODDUR(COUNT+1,R_ISEAS) + .01|
13685 |               ENDIF|
13686 |            ENDIF|
13687 |            IF(LPROB(COUNT,R_ISEAS) .GT. LPROB(COUNT-1,R_ISEAS)) THEN|
13688 |               LPROB(COUNT,R_ISEAS) = LPROB(COUNT-1,R_ISEAS)|
13689 |            ELSEIF(LPROB(COUNT,R_ISEAS) .LT.|
13690 |     +                                     LPROB(COUNT+1,R_ISEAS) ) THEN|
13691 |               LPROB(COUNT,R_ISEAS) = LPROB(COUNT+1,R_ISEAS)|
13692 |            ENDIF|
13693 |         ENDIF|
13694 |      ENDDO|
13695 |!|
13696 |!     THIS SECTION TAKES THE ROUNDING ERROR FROM THE|
13697 |!     PREVIOUS ALGORITHM (SINGLE PRECISION CALC.) AND|
13698 |!     DISTRIBUTES IT EVENLY ACROSS IPNT-1 POINTS.|
13699 |!|
13700 |      COUNTER = 0.|
13701 |   50 CALL INTEG8(DEMAND,LODDUR(1,R_ISEAS),LPROB(1,R_ISEAS),IMAX,|
13702 |     +            HOURS_INCREMENT,LODDUR(1,R_ISEAS))|
13703 |      IF(BASE_ADJUSTMENT == -999.) THEN|
13704 |         ALPHA = LODDUR(2,R_ISEAS) * FLOAT(HOURS_INCREMENT)|
13705 |         ALPHA = (SUM_MARKET_PRICES-ALPHA)/(DEMAND-ALPHA)|
13706 |      ELSE|
13707 |         ALPHA = 1.|
13708 |      ENDIF|
13709 |      DO I = 2,IMAX|
13710 |         LPROB(I,R_ISEAS) = LPROB(I,R_ISEAS)*ALPHA|
13711 |      ENDDO|
13712 |      LPROB(IMAX,R_ISEAS) = 0.|
13713 |      CALL INTEG8(DEMAND,LODDUR(1,R_ISEAS),LPROB(1,R_ISEAS),IMAX,|
13714 |     +   HOURS_INCREMENT,LODDUR(1,R_ISEAS))|
13715 |      PRECISN = 1.|
13716 |      IF(SUM_MARKET_PRICES .GT. DEMAND) THEN|
13717 |         PRECISN = DEMAND/SUM_MARKET_PRICES|
13718 |      ELSE|
13719 |         PRECISN = SUM_MARKET_PRICES/DEMAND|
13720 |      ENDIF|
13721 |      COUNTER = COUNTER + 1|
13722 |      IF(PRECISN .LT. .999999 .AND. COUNTER .LT. 3) GOTO 50|
13723 |!|
13724 |!     WRITE THE RESULTS TO BE READ BY PROCOST|
13725 |!|
13726 |      HOURS = HOURS + HOURS_INCREMENT|
13727 |      I = POINTS_IN_CURVE|
13728 |      DOWHILE (LPROB(I,R_ISEAS) == 0.)|
13729 |         I = I - 1|
13730 |      ENDDO|
13731 |      POINTS_IN_CURVE = I + 1|
13732 |      DX = (LODDUR(POINTS_IN_CURVE,R_ISEAS)-BASE)/|
13733 |     +                                          FLOAT(POINTS_IN_CURVE-1)|
13734 |      DX = MAX(DX,0.01)|
13735 |
|
13736 |! ASSUME LAST POINT HAS ZERO REVENUE|
13737 |!|
13738 |      IF(YES_MARKET_DURATION) THEN|
13739 |         IF(CUM_HOURS(I,R_ISEAS) > 0.) THEN|
13740 |            AVE_REVENUE = CUM_REVENUE(PRICE_POINTS,R_ISEAS) /|
13741 |     +                                   CUM_HOURS(PRICE_POINTS,R_ISEAS)|
13742 |         ELSE|
13743 |            AVE_REVENUE = 0.|
13744 |         ENDIF|
13745 |         WRITE(MARKET_DURATION_NO,REC=MARKET_DURATION_REC)|
13746 |     +         PRT_ENDPOINT(),|
13747 |     +         FLOAT(CURRENT_YEAR),|
13748 |     +         CL_MONTH_NAME(R_ISEAS),|
13749 |     +         FLOAT(PRICE_POINTS),|
13750 |     +         CUM_HOURS(PRICE_POINTS,R_ISEAS),|
13751 |     +         LODDUR(PRICE_POINTS,R_ISEAS),|
13752 |     +         CUM_REVENUE(PRICE_POINTS,R_ISEAS),|
13753 |     +         AVE_REVENUE|
13754 |         MARKET_DURATION_REC = MARKET_DURATION_REC + 1|
13755 |      ENDIF|
13756 |      DO I = PRICE_POINTS-1, 1, -1|
13757 |         INTERVAL_HOURS =|
13758 |     +             (LPROB(I,R_ISEAS)-LPROB(I+1,R_ISEAS))*HOURS_INCREMENT|
13759 |         CUM_HOURS(I,R_ISEAS) = CUM_HOURS(I+1,R_ISEAS) + INTERVAL_HOURS|
13760 |         CUM_REVENUE(I,R_ISEAS) = CUM_REVENUE(I+1,R_ISEAS) +|
13761 |     +                                LODDUR(I,R_ISEAS) * INTERVAL_HOURS|
13762 |!|
13763 |         IF(YES_MARKET_DURATION) THEN|
13764 |            IF(CUM_HOURS(I,R_ISEAS) > 0.) THEN|
13765 |               AVE_REVENUE = CUM_REVENUE(I,R_ISEAS) /|
13766 |     +                                              CUM_HOURS(I,R_ISEAS)|
13767 |            ELSE|
13768 |               AVE_REVENUE = 0.|
13769 |            ENDIF|
13770 |            WRITE(MARKET_DURATION_NO,REC=MARKET_DURATION_REC)|
13771 |     +         PRT_ENDPOINT(),|
13772 |     +         FLOAT(CURRENT_YEAR),|
13773 |     +         CL_MONTH_NAME(R_ISEAS),|
13774 |     +         FLOAT(I),|
13775 |     +         CUM_HOURS(I,R_ISEAS),|
13776 |     +         LODDUR(I,R_ISEAS),|
13777 |     +         CUM_REVENUE(I,R_ISEAS),|
13778 |     +         AVE_REVENUE|
13779 |            MARKET_DURATION_REC = MARKET_DURATION_REC + 1|
13780 |         ENDIF|
13781 |!|
13782 |      ENDDO|
