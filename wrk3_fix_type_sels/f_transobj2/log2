8396 |                  IND = MONTH_CALL_POSITION(TRANS,R_TRANS_GROUP)|
8397 |               ELSE|
8398 |                  IND = MONTH_PUT_POSITION(TRANS,R_TRANS_GROUP)|
8399 |               ENDIF|
8400 |!|
8401 |               HOURLY_ENERGY_PRICE = MONTHLY_ENERGY_PRICE(IND)|
8402 |!|
8403 |               IF(STRIKES_AVAILABLE(IND) <= 0) CYCLE|
8404 |! 10/24/01.|
8405 |!              TEMP_QUANTITY = HOURLY_QUANTITY(IND) ! AGT wonders 'should this vary day-to-day?'|
8406 |!            ! AGT would duplicate code from DAILY_CALL_PUT_CAPACITY if applicable to monthly|
8407 |!            ! IF(UNIT_CONTINGENCY(IND) /= 'N') THEN|
8408 |!            ! ... code as in ENTRY DAILY_CALL_PUT_CAPACITY ...|
8409 |!            ! ENDIF ! CONTINGENT OPTION|
8410 |               TEMP_L=(DERIVATIVE_TYPE(IND) < 4)|
8411 |               DO PRODUCT=1,6 ! find index of applicable product|
8412 |                  IF(PRODUCT_TYPE(IND)==LOCAL_PRODUCT_TYPE(PRODUCT))EXIT|
8413 |               END DO|
8414 |               IF(PRODUCT>6) CYCLE|
8415 |               IF(PRODUCT==6) THEN ! PRODUCT_PATTERN may vary with IND|
8416 |                  DOW_PROD_APPLIES(:,:,6) = 0. !CINITD(DOW_PROD_APPLIES(1,1,6),8*24,0.)|
8417 |                  DOW_PROD_HOURS(:,6)= 0 ! CALL CINITW(DOW_PROD_HOURS(1,6),8,INT2(0))|
8418 |                  DO CALENDAR_DAY_OF_WEEK=1,8|
8419 |!                 ! prepare the hourly array of product applicability|
8420 |                     TEMP_R1 = GET_USER_DAY(CALENDAR_DAY_OF_WEEK,|
8421 |     +                  R_MONTH,|
8422 |     +                  USER_DAY_TYPES_ID(IND),|
8423 |     +                  PRODUCT_PATTERN(1,PRODUCT),|
8424 |     +                  MONTHLY_CF_TRANS(IND))|
8425 |                     DO HOUR_IN_DAY=1,24|
8426 |                        IF(NINT(PRODUCT_PATTERN(HOUR_IN_DAY,PRODUCT))>0)|
8427 |     +                     THEN|
8428 |                           DOW_PROD_APPLIES(HOUR_IN_DAY,|
8429 |     +                                CALENDAR_DAY_OF_WEEK,PRODUCT)= 1.0|
8430 |                          DOW_PROD_HOURS(CALENDAR_DAY_OF_WEEK,PRODUCT)=|
8431 |     +                    DOW_PROD_HOURS(CALENDAR_DAY_OF_WEEK,PRODUCT)+1|
8432 |                        ENDIF|
8433 |                     END DO|
8434 |                  END DO|
8435 |               END IF|
8436 |               MONTHLY_ENERGY_REVENUE(IND,R_MONTH) = 0.0|
8437 |               SELL_OR_BUY= 1.0|
8438 |               LONG_SHORT = 1.0|
8439 |!|
8440 |! 12/21/01. IF SELLING A DERIVATIVE PRODUCT, THEN THE BUYER IS PAYING FOR THE OPTIONALITY.|
8441 |! FOR INSTANCE, SELLING A CALL OPTION MEANS THAT WHEN IT IS CALLED, YOU MUST SERVE THE LOAD.|
8442 |!|
8443 |               IF(EXPENSE_ASSIGNMENT(IND) == LOCAL_ASSIGNMENT(1))|
8444 |     +            LONG_SHORT = -LONG_SHORT|
8445 |!|
8446 |               HOURS_STRUCK=0|
8447 |               STRIKE_VALUE=0.0|
8448 |               SUM_QUANTITY=0.0 ! sum of DAILY_MW across hours and days|
8449 |               IF(TEMP_L) IND_HRLY_CAPACITY = 0.|
8450 |!|
8451 |               LOCAL_BEGIN_DAY = BEGIN_DAY_IN_MONTH(IND)|
8452 |               LOCAL_END_DAY = MIN(R_DAYS_IN_MONTH,|
8453 |     +                                            END_DAY_IN_MONTH(IND))|
8454 |!|
