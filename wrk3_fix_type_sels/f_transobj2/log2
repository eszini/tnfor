13786 |!***********************************************************************|
13787 |      ENTRY MX_PRICE_CURVE(R_HIGHEST_INTERVAL,R_INTERVALS,|
13788 |     +                     R_CUM_REVENUES,R_PRICES,R_ISEAS)|
13789 |!***********************************************************************|
13790 |!|
13791 |! ASSUMES THAT THERE IS A ZEROTH INTERVAL.|
13792 |! R_POINTS DOES NOT INCLUDE THIS INTERVAL.|
13793 |!|
13794 |! DO I WANT PRICES OR REVENUES?|
13795 |!|
13796 |         IF(R_HIGHEST_INTERVAL < 1) THEN|
13797 |            RETURN|
13798 |         ELSEIF(R_HIGHEST_INTERVAL == PRICE_POINTS) THEN|
13799 |
|
13800 |            DO I = PRICE_POINTS, 1, -1|
13801 |               R_INTERVALS(I) = CUM_HOURS(I,R_ISEAS)|
13802 |               R_PRICES(I) = LODDUR(I,R_ISEAS)|
13803 |               R_CUM_REVENUES(I) = CUM_REVENUE(I,R_ISEAS)|
13804 |
|
13805 |            ENDDO|
13806 |            RETURN|
13807 |         ENDIF|
13808 |!|
13809 |         R_INTERVALS(R_HIGHEST_INTERVAL) =|
13810 |     +                                   CUM_HOURS(PRICE_POINTS,R_ISEAS)|
13811 |         R_CUM_REVENUES(R_HIGHEST_INTERVAL) =|
13812 |     +                                 CUM_REVENUE(PRICE_POINTS,R_ISEAS)|
13813 |         R_PRICES(R_HIGHEST_INTERVAL) = LODDUR(PRICE_POINTS,R_ISEAS)|
13814 |         R_INTERVALS(0) = CUM_HOURS(1,R_ISEAS)|
13815 |         R_CUM_REVENUES(0) = CUM_REVENUE(1,R_ISEAS)|
13816 |         R_PRICES(0) = LODDUR(1,R_ISEAS)|
13817 |!|
13818 |! FIND THE CUM_REVENUE/CUM_HOURS INTERVAL THAT CONTAINS MX_HOURS|
13819 |!|
13820 |         MX_INCREMENT = CUM_HOURS(1,R_ISEAS) / R_HIGHEST_INTERVAL|
13821 |         MX_INTERVAL = 1|
13822 |!|
13823 |         R_INTERVALS(MX_INTERVAL) = R_INTERVALS(MX_INTERVAL-1) -|
13824 |     +                                                      MX_INCREMENT|
13825 |!|
13826 |         DO I = 2, PRICE_POINTS|
13827 |!|
13828 |            IF(CUM_HOURS(I,R_ISEAS) >= R_INTERVALS(MX_INTERVAL)) CYCLE|
13829 |!|
13830 |! FIND THE PRICING.|
13831 |!|
13832 |!|
13833 |            DOWHILE (R_INTERVALS(MX_INTERVAL) > CUM_HOURS(I,R_ISEAS))|
13834 |!|
13835 |               IF(R_INTERVALS(MX_INTERVAL) -|
13836 |     +                           R_INTERVALS(MX_INTERVAL-1) /= 0.0) THEN|
13837 |                  TOP_CAP_PERCENT =|
13838 |     +               (R_INTERVALS(MX_INTERVAL) -|
13839 |     +                                         CUM_HOURS(I-1,R_ISEAS)) /|
13840 |     +                   (CUM_HOURS(I,R_ISEAS) - CUM_HOURS(I-1,R_ISEAS))|
13841 |               ELSE|
13842 |                  TOP_CAP_PERCENT = 0.0|
13843 |               ENDIF|
13844 |!|
13845 |               R_PRICES(MX_INTERVAL) =|
13846 |     +                  TOP_CAP_PERCENT * LODDUR(I,R_ISEAS) +|
13847 |     +                        (1.-TOP_CAP_PERCENT) * LODDUR(I-1,R_ISEAS)|
13848 |               R_CUM_REVENUES(MX_INTERVAL) =|
13849 |     +                  TOP_CAP_PERCENT * CUM_REVENUE(I,R_ISEAS) +|
13850 |     +                   (1.-TOP_CAP_PERCENT) * CUM_REVENUE(I-1,R_ISEAS)|
13851 |!|
13852 |               MX_INTERVAL = MX_INTERVAL + 1|
13853 |               R_INTERVALS(MX_INTERVAL) = R_INTERVALS(MX_INTERVAL-1) -|
13854 |     +                                                      MX_INCREMENT|
13855 |!|
13856 |            ENDDO ! MULTIPLE INTERVALS BETWEEN TWO PRICE POINTS|
13857 |!|
13858 |
|
13859 |!|
13860 |         ENDDO ! SEARCHING FOR PRICE_POINTS CROSSOVER|
13861 |!|
13862 |      RETURN|
13863 |!***********************************************************************|
13864 |      ENTRY CF_2_ANNUAL_REVENUE(R_CF,R_AVE_REVENUE,R_UNIT_NAME,R_ISEAS)|
13865 |!***********************************************************************|
13866 |!|
13867 |         MAX_POINTS = MAX(1,PRICE_POINTS - 1)|
13868 |!|
13869 |         TOTAL_PERIOD_HOURS = CUM_HOURS(1,R_ISEAS)|
13870 |!|
13871 |         IF(TOTAL_PERIOD_HOURS <= 0.0 .OR.|
13872 |     +                                 TOTAL_PERIOD_HOURS >= 8785.) THEN|
13873 |
|
13874 |            R_AVE_REVENUE = 0.0|
13875 |!|
13876 |            RETURN|
13877 |!|
13878 |         ENDIF|
13879 |!|
13880 |         IF(R_CF > 100.0 .OR. R_CF < 0.0) THEN|
13881 |            WRITE(4,*) "Hydro resource ",R_UNIT_NAME|
13882 |            WRITE(4,*) " has a capacity factor"|
13883 |            WRITE(4,*) "of ",R_CF," which is outside of valid range"|
13884 |            WRITE(4,*) "for asset revenue allocation purposes."|
13885 |            IF(R_CF > 100.0) THEN|
13886 |               WRITE(4,*) "Revenue assumes 100% Capacity Factor."|
13887 |               TOTAL_RESOURCE_HOURS = TOTAL_PERIOD_HOURS|
13888 |            ELSE|
13889 |               WRITE(4,*) "Revenue assumes 0% Capacity Factor."|
13890 |               TOTAL_RESOURCE_HOURS = 0.|
13891 |            ENDIF|
13892 |         ELSE|
13893 |            TOTAL_RESOURCE_HOURS = R_CF * TOTAL_PERIOD_HOURS / 100.|
13894 |         ENDIF|
13895 |         IF(R_CF == 0.0) THEN|
13896 |            R_AVE_REVENUE = CUM_REVENUE(MAX_POINTS,R_ISEAS) /|
13897 |     +                                     CUM_HOURS(MAX_POINTS,R_ISEAS)|
13898 |         ELSEIF(R_CF == 100.0) THEN|
13899 |            R_AVE_REVENUE =|
13900 |     +                     CUM_REVENUE(1,R_ISEAS) / CUM_HOURS(1,R_ISEAS)|
13901 |         ELSE ! SEARCH FOR THE CF INTERVAL|
13902 |!|
13903 |            START = 1|
13904 |            END = MAX_POINTS|
13905 |            POINT_NOT_FOUND = .TRUE.|
13906 |!|
13907 |            DOWHILE (POINT_NOT_FOUND)|
13908 |               HALF_POINT = START + (END-START)/2|
13909 |               IF(HALF_POINT == START) THEN|
13910 |                  POINT_NOT_FOUND = .FALSE.|
13911 |                  EXIT|
13912 |               ENDIF|
13913 |               IF(TOTAL_RESOURCE_HOURS <|
13914 |     +                               CUM_HOURS(HALF_POINT,R_ISEAS)) THEN|
13915 |                  START = HALF_POINT|
13916 |               ELSEIF(TOTAL_RESOURCE_HOURS >|
13917 |     +                               CUM_HOURS(HALF_POINT,R_ISEAS)) THEN|
13918 |                  END = HALF_POINT|
13919 |               ELSE|
13920 |                  POINT_NOT_FOUND = .FALSE.|
13921 |                  EXIT|
13922 |               ENDIF|
13923 |            ENDDO|
13924 |            IF(CUM_HOURS(HALF_POINT+1,R_ISEAS) -|
13925 |     +                        CUM_HOURS(HALF_POINT,R_ISEAS) /= 0.0) THEN|
13926 |               TOP_CAP_PERCENT =|
13927 |     +            (TOTAL_RESOURCE_HOURS -|
13928 |     +                                  CUM_HOURS(HALF_POINT,R_ISEAS)) /|
13929 |     +            (CUM_HOURS(HALF_POINT+1,R_ISEAS) -|
13930 |     +                                    CUM_HOURS(HALF_POINT,R_ISEAS))|
13931 |            ELSE|
13932 |               TOP_CAP_PERCENT = 1.0|
13933 |            ENDIF|
13934 |            BOTTOM_AVE_REVENUE = CUM_REVENUE(HALF_POINT,R_ISEAS)/|
13935 |     +                                     CUM_HOURS(HALF_POINT,R_ISEAS)|
13936 |!            TOP_AVE_REVENUE = CUM_REVENUE(HALF_POINT+1,R_ISEAS)/|
13937 |!     +                                   CUM_HOURS(HALF_POINT+1,R_ISEAS)|
13938 |            IF(CUM_HOURS(HALF_POINT+1,R_ISEAS) <= 0.01) THEN|
13939 |               WRITE(4,*) "Price curve has flat interval for pricing"|
13940 |               WRITE(4,*) "Hydro units"|
13941 |               TOP_AVE_REVENUE = BOTTOM_AVE_REVENUE|
13942 |            ELSE|
13943 |               TOP_AVE_REVENUE = CUM_REVENUE(HALF_POINT+1,R_ISEAS)/|
13944 |     +                                   CUM_HOURS(HALF_POINT+1,R_ISEAS)|
13945 |            ENDIF|
13946 |            R_AVE_REVENUE = (1.-TOP_CAP_PERCENT) * BOTTOM_AVE_REVENUE +|
13947 |     +                                 TOP_CAP_PERCENT * TOP_AVE_REVENUE|
13948 |         ENDIF|
13949 |      RETURN|
13950 |      END|
