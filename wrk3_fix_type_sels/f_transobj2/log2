793 |      ENTRY GET_DAY_TYPE(R_HOUR,R_DAY_OF_WEEK,R_MONTH)|
794 |!***********************************************************************|
795 |         IF(R_DAY_OF_WEEK > 7) THEN|
796 |            R_DAY_OF_WEEK = 7|
797 |         ELSEIF(R_DAY_OF_WEEK < 1) THEN|
798 |            R_DAY_OF_WEEK = 1|
799 |         ENDIF|
800 |         GET_DAY_TYPE = DAY_TYPE_DATA(R_HOUR,R_DAY_OF_WEEK,R_MONTH)|
801 |      RETURN|
