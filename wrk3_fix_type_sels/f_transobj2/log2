8485 |                              UNIT_AVAIL = UNIT_AVAIL +|
8486 |     +                        GET_BLOCK_AVAIL_4_HOUR(TEMP_UNIT_NUMBER,|
8487 |     +                                                   INT2(1),|
8488 |     +                                                HOUR_IN_MONTH) +|
8489 |     +                        GET_BLOCK_AVAIL_4_HOUR(TEMP_UNIT_NUMBER,|
8490 |     +                                                   INT2(2),|
8491 |     +                                                HOUR_IN_MONTH)|
8492 |                              CALL GET_MWBLOK_FOR_UNIT(|
8493 |     +                                 TEMP_UNIT_NUMBER,TEMP_R1,TEMP_R2)|
8494 |!|
8495 |                              RESOURCE_MW =|
8496 |     +                                   RESOURCE_MW + TEMP_R1 + TEMP_R2|
8497 |                              TEMP_I2 = TEMP_I2 + 1|
8498 |                              LOCAL_UNIT_ID =|
8499 |     +                           GET_VAR(|
8500 |     +                                 FLOAT(UNIT_CONTINGENT_LINK(IND)),|
8501 |     +                                   TEMP_I2,'MultiUnit Contingent')|
8502 |                           ENDDO|
8503 |                        ELSE|
8504 |                           TEMP_UNIT_NUMBER =|
8505 |     +                           GET_RESOURCE_ID_TO_UNIT(LOCAL_UNIT_ID,|
8506 |     +                                           NUMBER_OF_UNITS_FOR_ID) ! FIRST OCCURRENCE|
8507 |                           UNIT_AVAIL = UNIT_AVAIL +|
8508 |     +                       GET_BLOCK_AVAIL_4_HOUR(TEMP_UNIT_NUMBER,|
8509 |     +                                                   INT2(1),|
8510 |     +                                                HOUR_IN_MONTH) +|
8511 |     +                       GET_BLOCK_AVAIL_4_HOUR(TEMP_UNIT_NUMBER,|
8512 |     +                                                   INT2(2),|
8513 |     +                                                HOUR_IN_MONTH)|
8514 |                           CALL GET_MWBLOK_FOR_UNIT(|
8515 |     +                                 TEMP_UNIT_NUMBER,TEMP_R1,TEMP_R2)|
8516 |                           RESOURCE_MW = TEMP_R1 + TEMP_R2|
8517 |                        ENDIF|
8518 |!|
8519 |                        IF(RESOURCE_MW > 0.) THEN|
8520 |                           UNIT_AVAIL = UNIT_AVAIL/RESOURCE_MW|
8521 |                           IF(UNIT_AVAIL > 1.0) THEN|
8522 |                              WRITE(4,*) "PROBLEM IN UNIT CONTINGENT"|
8523 |                           ENDIF|
8524 |                        ELSE|
8525 |                           UNIT_AVAIL = 0.0|
8526 |                        ENDIF|
8527 |! 11/03/03. NEW CASES FOR REPLACEMENT LOGIC.|
8528 |                        OUTAGE_TYPE = NINT(GET_BLOCK_OUTAGE_4_HOUR(|
8529 |     +                          TEMP_UNIT_NUMBER,INT2(1),HOUR_IN_MONTH))|
8530 |!     +                          TEMP_UNIT_NUMBER,INT2(2),HOUR_IN_MONTH))|
8531 |                        IF(UNIT_CONTINGENCY(IND) == 'R' .OR.|
8532 |     +                          UNIT_CONTINGENCY(IND) == 'A' .OR.|
8533 |     +                                UNIT_CONTINGENCY(IND) == 'B') THEN|
8534 |                           IF( UNIT_CONTINGENCY(IND) == 'R' .OR.|
8535 |     +                         ( (OUTAGE_TYPE == 1 .AND.|
8536 |     +                                UNIT_CONTINGENCY(IND) == 'A') .OR.|
8537 |     +                           (OUTAGE_TYPE == 2 .AND.|
8538 |     +                             UNIT_CONTINGENCY(IND) == 'B') )) THEN|
8539 |                              DAILY_MW(HOUR) =|
8540 |     +                                 TEMP_QUANTITY * (1. - UNIT_AVAIL)|
8541 |                           ENDIF|
8542 |                        ELSE|
8543 |!                           OUTAGE_TYPE = NINT(GET_BLOCK_OUTAGE_4_HOUR(|
8544 |!     +                          TEMP_UNIT_NUMBER,INT2(2),HOUR_IN_MONTH))|
8545 |                           IF( UNIT_CONTINGENCY(IND) == 'U' .OR.|
8546 |     +                         ( (OUTAGE_TYPE == 1 .AND.|
8547 |     +                                UNIT_CONTINGENCY(IND) == 'M') .OR.|
8548 |     +                           (OUTAGE_TYPE == 2 .AND.|
8549 |     +                             UNIT_CONTINGENCY(IND) == 'F') )) THEN|
8550 |                              DAILY_MW(HOUR) =|
8551 |     +                                        TEMP_QUANTITY * UNIT_AVAIL|
8552 |                           ENDIF|
8553 |                        ENDIF|
8554 |                        R_MONTHLY_AVAIL(HOUR_IN_MONTH) =|
8555 |     +                  R_MONTHLY_AVAIL(HOUR_IN_MONTH) +|
8556 |     +                                       DAILY_MW(HOUR) * LONG_SHORT|
8557 |                     ENDDO ! HOUR|
8558 |                  ELSE|
8559 |                     DO HOUR = 1, 24|
8560 |                        HOUR_IN_MONTH = (DAY-1)*24+HOUR|
8561 |                        R_MONTHLY_AVAIL(HOUR_IN_MONTH) =|
8562 |     +                  R_MONTHLY_AVAIL(HOUR_IN_MONTH) +|
8563 |     +                                       DAILY_MW(HOUR) * LONG_SHORT|
8564 |                     ENDDO|
8565 |                  ENDIF ! CONTINGENT OPTION|
8566 |!|
8567 |                  HOUR_IN_MONTH=1+(DAY-1)*24|
8568 |!                  CALL GET_DAY_OF_WEEK_IN_MONTH(DAY,R_MONTH,|
8569 |!     +                                             CALENDAR_DAY_OF_WEEK)|
