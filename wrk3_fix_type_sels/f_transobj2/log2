11663 |               R_DAILY_STRIKES = R_DAILY_STRIKES + 1|
11664 |            ELSEIF(R_TYPE_OF_DERIV == HourlyOption) THEN|
11665 |               IF(TEMP_REVENUE > TEMP_COST) THEN|
11666 |                  GET_HOUR_DAY_OPTION_VALUE =|
11667 |     +                            GET_HOUR_DAY_OPTION_VALUE +|
11668 |     +                                          TEMP_REVENUE - TEMP_COST|
11669 |                  R_DAILY_ENERGY_REVENUE = R_DAILY_ENERGY_REVENUE +|
11670 |     +                                                      TEMP_REVENUE|
11671 |                  R_DAILY_VARIABLE_COST = R_DAILY_VARIABLE_COST +|
11672 |     +                                                      TEMP_COST|
11673 |                  R_DAILY_ENERGY = R_DAILY_ENERGY + TEMP_QUANT|
11674 |                  R_HOUR_USAGE(I) = TEMP_QUANT|
11675 |                  R_DAILY_STRIKES = R_DAILY_STRIKES + 1|
11676 |               ELSE|
11677 |                  R_STRIKE_QUANTITY(I) = 0.|
11678 |               ENDIF|
11679 |            ELSE ! ASSUMES Daily_Option FOR NOW|
11680 |               TEMP_VALUE = TEMP_VALUE + TEMP_REVENUE - TEMP_COST|
11681 |               R_DAILY_ENERGY_REVENUE = R_DAILY_ENERGY_REVENUE +|
11682 |     +                                                      TEMP_REVENUE|
11683 |               R_DAILY_VARIABLE_COST = R_DAILY_VARIABLE_COST +|
11684 |     +                                                      TEMP_COST|
11685 |               R_DAILY_ENERGY = R_DAILY_ENERGY + TEMP_QUANT|
11686 |               R_HOUR_USAGE(I) = TEMP_QUANT|
11687 |               R_DAILY_STRIKES = R_DAILY_STRIKES + 1|
11688 |               IF(I == 24 .AND. TEMP_VALUE < 0.000001) THEN ! DIDN'T STRIKE|
11689 |                  R_STRIKE_QUANTITY = 0.|
11690 |                  R_DAILY_STRIKES = 0|
11691 |                  R_DAILY_ENERGY_REVENUE = 0.|
11692 |                  R_DAILY_VARIABLE_COST = 0.|
11693 |                  R_DAILY_ENERGY = 0.|
11694 |                  R_HOUR_USAGE = 0.|
11695 |               ENDIF|
11696 |            ENDIF ! R_TYPE_OF_DERIV|
11697 |         ENDDO|
11698 |      RETURN|
11699 |      END|
