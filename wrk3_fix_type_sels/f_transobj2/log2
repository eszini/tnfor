11625 |     +       TEMP_QUANT,|
11626 |     +       R_24_HOUR_MARKET_PRICE(24),|
11627 |     +       R_HOUR_ACTIVE(24),|
11628 |     +       R_24_HOUR_STRIKE_PRICE(24),|
11629 |     +       R_CALL_OR_PUT,|
11630 |     +       R_STRIKE_QUANTITY(0:24), ! AVAILABLE MW RESET TO USED MW|
11631 |     +       R_DAILY_ENERGY,|
11632 |     +       R_DAILY_VARIABLE_COST,TEMP_COST,|
11633 |     +       R_DAILY_ENERGY_REVENUE,TEMP_REVENUE,|
