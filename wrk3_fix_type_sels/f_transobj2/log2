8364 |         DOW_PROD_APPLIES = 0.|
8365 |         DO CALENDAR_DAY_OF_WEEK=1,8|
8366 |!        ! prepare the hourly array of product applicability|
8367 |            DO HOUR_IN_DAY=1,24|
8368 |               DO PRODUCT=1,5 ! pattern for product==6 varies by IND|
8369 |                  IF(.TRUE..EQV.APPLY_ENERGY_PRODUCT(HOUR_IN_DAY,|
8370 |     +               CALENDAR_DAY_OF_WEEK,LOCAL_PRODUCT_TYPE(PRODUCT)))|
