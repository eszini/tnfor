486 |      ENTRY INIT_HOURLY_TIE|
487 |!***********************************************************************|
488 |!|
489 |         HOURLY_TIE_AVAILABLE = SAVE_TIE_LIMIT|
490 |         HOURLY_TIE_FLOW = SAVE_TIE_FLOW|
491 |
|
492 |         INIT_HOURLY_TIE = .TRUE.|
493 |      RETURN|
494 |!***********************************************************************|
495 |      ENTRY HOURLY_TIE_LIMIT(R_SELLER,R_BUYER)|
496 |!***********************************************************************|
497 |!|
498 |         IF(R_SELLER <= 0 .OR. R_SELLER > MAX_TIE_GROUPS .OR.|
499 |     +                 R_BUYER <= 0. .OR. R_BUYER > MAX_TIE_GROUPS) THEN|
500 |            HOURLY_TIE_LIMIT = 99999.|
501 |         ELSE|
502 |            HOURLY_TIE_LIMIT = HOURLY_TIE_AVAILABLE(R_SELLER,R_BUYER)|
503 |         ENDIF|
504 |      RETURN|
505 |!***********************************************************************|
506 |      ENTRY SEASONAL_TIE_LIMIT(R_SELLER,R_BUYER)|
507 |!***********************************************************************|
508 |         IF(R_SELLER <= 0 .OR. R_SELLER > MAX_TIE_GROUPS .OR.|
509 |     +                 R_BUYER <= 0. .OR. R_BUYER > MAX_TIE_GROUPS) THEN|
510 |            SEASONAL_TIE_LIMIT = 99999.|
511 |         ELSE|
512 |            SEASONAL_TIE_LIMIT = SAVE_TIE_LIMIT(R_SELLER,R_BUYER)|
513 |         ENDIF|
514 |      RETURN|
515 |!***********************************************************************|
516 |      ENTRY RECORD_TRANSACTION_TO_TIE(R_SELLER,R_BUYER,R_QUANTITY,|
517 |     +                                                    R_HOUR_IN_DAY)|
518 |!***********************************************************************|
519 |!|
520 |         IF(R_QUANTITY <= 0.) RETURN|
521 |!|
522 |         HOURLY_TIE_AVAILABLE(R_SELLER,R_BUYER) = MAX(0.,|
523 |     +              HOURLY_TIE_AVAILABLE(R_SELLER,R_BUYER) - R_QUANTITY)|
524 |         DO    TRANS_GROUP = 1, MAX_TIE_GROUPS|
525 |            QUANTITY_TO_TRANS_GROUP = R_QUANTITY *|
526 |     +                     SAVE_TIE_FLOW(R_SELLER,TRANS_GROUP,R_BUYER)|
527 |            TRANS_COST = SAVE_TIE_CHARGE(R_SELLER,TRANS_GROUP) *|
528 |     +                                           QUANTITY_TO_TRANS_GROUP|
529 |            MONTHLY_TRANS_REVENUE(R_SELLER,TRANS_GROUP) =|
530 |     +          MONTHLY_TRANS_REVENUE(R_SELLER,TRANS_GROUP) + TRANS_COST|
531 |            MONTHLY_TRANS_QUANTITY(R_SELLER,TRANS_GROUP) =|
532 |     +               MONTHLY_TRANS_QUANTITY(R_SELLER,TRANS_GROUP) +|
533 |     +                                           QUANTITY_TO_TRANS_GROUP|
534 |            MONTHLY_TRANS_COST(TRANS_GROUP,R_SELLER) =|
535 |     +             MONTHLY_TRANS_COST(TRANS_GROUP,R_SELLER) + TRANS_COST|
536 |!|
537 |            HOURLY_TRANS_REVENUE(TRANS_GROUP,R_HOUR_IN_DAY) =|
538 |     +                 HOURLY_TRANS_REVENUE(TRANS_GROUP,R_HOUR_IN_DAY) +|
539 |     +                                                        TRANS_COST|
540 |            HOURLY_TRANS_REVENUE(R_SELLER,R_HOUR_IN_DAY) =|
541 |     +                    HOURLY_TRANS_REVENUE(R_SELLER,R_HOUR_IN_DAY) -|
542 |     +                                                        TRANS_COST|
543 |!|
544 |         ENDDO|
545 |         RECORD_TRANSACTION_TO_TIE = .TRUE.|
546 |      RETURN|
547 |      END|
