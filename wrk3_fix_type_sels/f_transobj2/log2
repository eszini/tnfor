8353 |     +   R_DAYS_IN_MONTH,|
8354 |     +   R_MONTHLY_AVAIL)|
8355 |!|
8356 |!***********************************************************************|
8357 |!|
8358 |         MONTHLY_CALL_PUT_CAPACITY = .FALSE.|
8359 |         IF(.NOT. SAVE_MONTHLY_PRODUCTS_STATUS) RETURN|
8360 |         IF(NUM_MONTH_CALLS(R_TRANS_GROUP) +|
