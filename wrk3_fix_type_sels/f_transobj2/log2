8347 |!|
8348 |      ENTRY MONTHLY_CALL_PUT_CAPACITY(|
8349 |     +   R_TRANS_GROUP,|
8350 |     +   R_MONTHLY_PRICE,    ! 24x31 hourly detail|
8351 |     +   R_MONTHLY_CAPACITY, ! 24x31 hourly detail begins at (1); (0:800)|
