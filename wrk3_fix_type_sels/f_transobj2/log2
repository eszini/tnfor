473 |!***********************************************************************|
474 |!|
475 |         IF(R_SELLER <= MAX_TIE_GROUPS .AND.|
476 |     +                                   R_BUYER <= MAX_TIE_GROUPS) THEN|
477 |            DELIVERED_TIE_COST =|
478 |     +                MONTHLY_DELIVERED_TIE_COST(R_SELLER,R_BUYER)|
479 |         ELSE|
480 |            DELIVERED_TIE_COST = 0.|
481 |         ENDIF|
482 |!|
483 |      RETURN|
