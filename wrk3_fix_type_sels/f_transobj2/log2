741 |!***********************************************************************|
742 |!|
743 |      INCLUDE 'SpinLib.MON'|
744 |      SAVE|
745 |      INTEGER*4 VALUES_2_ZERO|
746 |      INTEGER*2 DELETE,HOURS_PER_DAY,DAY_TYPES_IN_MONTH,MONTHS_PER_YEAR,|
747 |     +            CURRENT_RECORD,MONTH,HOUR,DAY_TYPE,GET_DAY_TYPE,|
748 |     +            R_HOUR,R_DAY_OF_WEEK,R_MONTH,LAST_DAY_TYPE/1/,|
749 |     +            GET_LAST_DAY_TYPE|
750 |      PARAMETER ( HOURS_PER_DAY = 24,DAY_TYPES_IN_MONTH=7,|
751 |     +            MONTHS_PER_YEAR=12)|
752 |      INTEGER*2 DAY_TYPE_DATA(HOURS_PER_DAY,DAY_TYPES_IN_MONTH,|
753 |     +                                                  MONTHS_PER_YEAR)|
754 |      LOGICAL*1 READ_DAY_TYPE_DATA|
755 |      LOGICAL*4 DAY_TYPE_FILE_EXISTS|
756 |!      SAVE      DAY_TYPE_DATA|
757 |!|
758 |! END DATA DECLARATIONS|
759 |!|
760 |         READ_DAY_TYPE_DATA = .FALSE.|
761 |!|
762 |         VALUES_2_ZERO = INT(HOURS_PER_DAY*DAY_TYPES_IN_MONTH*|
763 |     +                                                  MONTHS_PER_YEAR)|
764 |!|
765 |         DAY_TYPE_DATA = 1|
766 |!|
767 |         CALL DOES_DAY_TYPE_FILE_EXIST(DAY_TYPE_FILE_EXISTS)|
768 |         IF(.NOT. DAY_TYPE_FILE_EXISTS) RETURN|
769 |         CALL OPEN_DAY_TYPE_FILE|
770 |         CURRENT_RECORD = 0|
771 |!|
772 |         DO MONTH = 1, MONTHS_PER_YEAR|
773 |            DO DAY_TYPE = 1, DAY_TYPES_IN_MONTH|
774 |               CURRENT_RECORD = CURRENT_RECORD + 1|
775 |               READ(10,REC=CURRENT_RECORD) DELETE,|
776 |     +                     (DAY_TYPE_DATA(HOUR,DAY_TYPE,MONTH),|
777 |     +                                          HOUR = 1, HOURS_PER_DAY)|
778 |               DO HOUR = 1, HOURS_PER_DAY|
779 |                  LAST_DAY_TYPE = MAX(LAST_DAY_TYPE,|
780 |     +                               DAY_TYPE_DATA(HOUR,DAY_TYPE,MONTH))|
781 |               ENDDO|
782 |            ENDDO|
783 |         ENDDO|
784 |         CALL CLOSE_DAY_TYPE_FILE|
785 |         READ_DAY_TYPE_DATA = .TRUE.|
786 |      RETURN|
