11640 |         R_DAILY_ENERGY = 0.0|
11641 |         R_HOUR_USAGE = 0.0|
11642 |         R_DAILY_VARIABLE_COST = 0.0|
11643 |         R_DAILY_ENERGY_REVENUE = 0.0|
11644 |         TEMP_VALUE = 0.0|
11645 |         DO I = 1, 24|
11646 |!|
11647 |            TEMP_QUANT =|
11648 |     +            R_STRIKE_QUANTITY(I) * R_CALL_OR_PUT *|
11649 |     +                                                  R_HOUR_ACTIVE(I)|
11650 |            TEMP_REVENUE = TEMP_QUANT * R_24_HOUR_MARKET_PRICE(I)|
11651 |            TEMP_COST = TEMP_QUANT * R_24_HOUR_STRIKE_PRICE(I)|
11652 |!|
