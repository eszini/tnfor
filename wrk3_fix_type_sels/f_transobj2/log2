8609 |               MONTHLY_STRIKES(IND,R_MONTH) =|
8610 |     +                                  MONTHLY_STRIKES(IND,R_MONTH) + 1|
8611 |               STRIKES_AVAILABLE(IND) = STRIKES_AVAILABLE(IND) - 1 ! AGT doubts this; perhaps count is of days?|
8612 |               STRIKES_REQUIRED(IND) = STRIKES_REQUIRED(IND) - 1|
8613 |!|
8614 |! 10/13/03. TO BE CONSISTENT WITH CHANGES MADE TO DAILY AND HOURLY ROUTINES.|
8615 |!|
8616 |               LONG_SHORT = LONG_SHORT * CALL_OR_PUT|
8617 |               MONTHLY_ENERGY(IND,R_MONTH) =|
8618 |     +                       MONTHLY_ENERGY(IND,R_MONTH) +|
8619 |     +                                      LONG_SHORT*ABS(SUM_QUANTITY)|
8620 |               MONTHLY_ENERGY_COST(IND,R_MONTH) =|
