8574 |     +            STRIKE_VALUE+GET_DAILY_OPTION_VALUE(|
8575 |     +               R_MONTHLY_PRICE(HOUR_IN_MONTH),|
8576 |     +               DAILY_MW,|
8577 |     +               DOW_PROD_APPLIES(1,CALENDAR_DAY_OF_WEEK,PRODUCT),|
8578 |!     +               SELL_OR_BUY,|
8579 |     +               CALL_OR_PUT, ! ALTERED 100206.|
8580 |     +               HOURLY_ENERGY_PRICE)|
8581 |!     +               MONTHLY_ENERGY_PRICE(IND))|
8582 |! ONLY WORKS FOR 7X24|
8583 |!                  CALL AccumVector(DAILY_MW(1),SUM_QUANTITY,24) ! use .ASM version for speed|
8584 |!|
8585 |                  DO J = 1, 24|
