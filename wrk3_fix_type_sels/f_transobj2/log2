8382 |         TEMP_PRICE_24 = 0. ! strike threshold, constant for the month|
8383 |! MONTHLY CALL LOGIC|
8384 |         DO I = 1, 2|
8385 |            N_BEST_VALUES=0|
8386 |            IF(I == 1) THEN ! CALLS|
8387 |               LOCAL_ACTIVE_TRANSACTIONS =|
8388 |     +                                    NUM_MONTH_CALLS(R_TRANS_GROUP)|
8389 |               CALL_OR_PUT = 1.|
8390 |            ELSE ! PUTS|
