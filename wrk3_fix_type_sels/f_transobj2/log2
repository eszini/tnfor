8623 |     +                                      LONG_SHORT*ABS(SUM_QUANTITY)|
8624 |!              IF(DERIVATIVE_TYPE(IND) < 4) THEN ! PHYSICAL|
8625 |               IF(TEMP_L) THEN ! PHYSICAL|
8626 |                  HOUR_IN_MONTH=0|
8627 |                  DO DAY=1, R_DAYS_IN_MONTH ! augment accums by IND_HRLY_CAPACITY|
8628 |                     DO HOUR_IN_DAY=1,24|
