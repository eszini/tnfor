8332 |     +                               R_HOUR_PRICE * TEMP_R1|
8333 |                     MONTHLY_ENERGY_COST(IND,R_MONTH) =|
8334 |     +                  MONTHLY_ENERGY_COST(IND,R_MONTH) +|
