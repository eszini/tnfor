2645 |C|
2646 |      SUBROUTINE FIND_ENRGY_CROSSOVER(A,LEFT,TARGET_ENERGY,|
2647 |     +                                 LODDUR,LPROB,B_ADJUSTED,RIGHT)|
2648 |C|
2649 |      use shared_vars_interg82|
2650 |      use interg82|
2651 ||
2652 |      LOGICAL*1 ENERGY_EXCEEDED_AT_FIRST_PASS|
2653 |C      INTEGER*2 ISTART,ISTOP,I|
2654 |      INTEGER*2 ISTART,I|
2655 |      REAL A,LEFT,TARGET_ENERGY,LODDUR(*),LPROB(*),B_ADJUSTED,RIGHT|
2656 |      REAL INTPL8,X1,Y1,X3,Y2,X2,ENERGY,INCREMENTAL_ENERGY,BASE|
2657 |C|
2658 |      INTPL8(X1,Y1,X3,Y2,X2) = Y1 + (Y2-Y1) * (X3-X1)/(X2-X1)|
2659 |C|
2660 |      CALL RETURN_ISTART_ISTOP(ISTART,ISTOP)|
2661 |      BASE = LODDUR(1)|
2662 |      ENERGY = MAX(BASE-A,0.0)|
2663 |      INCREMENTAL_ENERGY = 0.|
2664 |      ENERGY_EXCEEDED_AT_FIRST_PASS = .FALSE.|
2665 |      IF(A > BASE) THEN|
2666 |         INCREMENTAL_ENERGY = (LODDUR(ISTART)-A)*(LPROB(ISTART)+LEFT)/2.|
2667 |         ENERGY = ENERGY + INCREMENTAL_ENERGY|
2668 |         IF(ENERGY > TARGET_ENERGY) ENERGY_EXCEEDED_AT_FIRST_PASS =|
2669 |     +                                                            .TRUE.|
2670 |      ENDIF|
2671 |      I = ISTART|
2672 |      DOWHILE (ENERGY < TARGET_ENERGY)|
2673 |         INCREMENTAL_ENERGY =(LPROB(I) + LPROB(I+1)) *|
2674 |     +                                      (LODDUR(I+1) - LODDUR(I))/2.|
2675 |         ENERGY = ENERGY + INCREMENTAL_ENERGY|
2676 |         I = I + 1|
2677 |      ENDDO|
2678 |      ENERGY = ENERGY - INCREMENTAL_ENERGY|
2679 |      I = MAX(ISTART,I - 1)|
2680 |      IF(ENERGY_EXCEEDED_AT_FIRST_PASS) THEN|
2681 |         CALL FIND_MAXIMUM_ENERGY(A,LODDUR(I),|
2682 |     +                         LEFT,LPROB(I),ENERGY,|
2683 |     +                         TARGET_ENERGY,B_ADJUSTED,RIGHT)|
2684 |      ELSE|
2685 |         CALL FIND_MAXIMUM_ENERGY(LODDUR(I),LODDUR(I+1),|
2686 |     +                         LPROB(I),LPROB(I+1),ENERGY,|
2687 |     +                         TARGET_ENERGY,B_ADJUSTED,RIGHT)|
2688 |      ENDIF|
2689 |      RETURN|
2690 |      END|
