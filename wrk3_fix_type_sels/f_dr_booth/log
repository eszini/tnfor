3007 |      SUBROUTINE GET_GIBSON5_ENERGY(GIBSON_BLOCK1_ENERGY,|
3008 |     +                              GIBSON_BLOCK2_ENERGY,SEAS_HOURS,|
3009 |     +                              ISEAS,UNITNO,BLK_MW,ARRAY_POINTR)|
3010 |C**********************************************************************|
3011 |      INCLUDE 'SpinLib.MON'|
3012 |      use kepcocom|
3013 |      INCLUDE 'SIZECOM.MON'|
3014 |      INCLUDE 'LAMCOM.MON'|
3015 |      INCLUDE 'PRODCOM.MON'|
3016 |      |
3017 |      LOGICAL*1 FOUND_THIS_MONTH_FORECAST,GET_THIS_MONTH_CLASS_FORECAST|
3018 |      INTEGER*2 GIB,ISEAS,UNITNO,ARRAY_POINTR,PSI_CLASS_NUMBER|
3019 |      REAL  PSI_LDC,PSI_ENERGY_DEMAND,PSI_PEAK_DEMAND,|
3020 |     +      PSI_BASE_DEMAND,GIB5_CAP,GIB5_ENERGY,GIBSON_BLOCK1_ENERGY,|
3021 |     +      GIBSON_BLOCK2_ENERGY,GIBSON_TOTAL_ENERGY,BLK_MW,SEAS_HOURS,|
3022 |     +      FORECAST_DSM_ENERGY(MAX_LOAD_CLASSES),THIS_MONTH_ENERGY,|
3023 |     +      THIS_MONTH_PEAK|
3024 |! ADDED 9/1/94. GAT.|
3025 |C|
3026 |         CALL GET_CLASS_DSM_ENERGY_ALLOC(ISEAS,FORECAST_DSM_ENERGY)|
3027 |C|
3028 |         PSI_CLASS_NUMBER = 3|
3029 |         FOUND_THIS_MONTH_FORECAST = GET_THIS_MONTH_CLASS_FORECAST(|
3030 |     +                                    ISEAS,|
3031 |     +                                    PSI_CLASS_NUMBER,|
3032 |     +                                    THIS_MONTH_ENERGY,|
3033 |     +                                    THIS_MONTH_PEAK)|
3034 |C|
3035 |         PSI_ENERGY_DEMAND =(THIS_MONTH_ENERGY +|
3036 |     +                       FORECAST_DSM_ENERGY(PSI_CLASS_NUMBER))/|
3037 |     +                                                        SEAS_HOURS|
3038 |         PSI_PEAK_DEMAND = THIS_MONTH_PEAK ! ASSUMES MONTHLY PRODUCTION|
3039 |         PSI_BASE_DEMAND = MAX(0.,|
3040 |     +                           2.*PSI_ENERGY_DEMAND - PSI_PEAK_DEMAND)|
3041 |         DO GIB = 1 , 2|
3042 |            IF(GIB == 1) THEN ! CALCULATE TOTAL GIBSON ENERGY|
3043 |               GIB5_CAP = MW(2,UNITNO) *|
3044 |     +                   (1.-AREA_CAPACITY_LOSSES(3,ISEAS,ARRAY_POINTR))|
3045 |            ELSE|
3046 |               GIB5_CAP = BLK_MW|
3047 |            ENDIF|
3048 |            IF(GIB5_CAP <= PSI_BASE_DEMAND) THEN|
3049 |               GIB5_ENERGY = GIB5_CAP|
3050 |            ELSE|
3051 |               IF(GIB5_CAP > PSI_PEAK_DEMAND) GIB5_CAP = PSI_PEAK_DEMAND|
3052 |               PSI_LDC = (PSI_PEAK_DEMAND - GIB5_CAP)/|
3053 |     +                               (PSI_PEAK_DEMAND - PSI_BASE_DEMAND)|
3054 |               GIB5_ENERGY = PSI_BASE_DEMAND + (1. + PSI_LDC) *|
3055 |     +                                   (GIB5_CAP - PSI_BASE_DEMAND)/2.|
3056 |            ENDIF|
3057 |            IF(GIB == 1) THEN|
3058 |               GIBSON_TOTAL_ENERGY = GIB5_ENERGY|
3059 |            ELSE|
3060 |               GIBSON_BLOCK1_ENERGY = GIB5_ENERGY|
3061 |            ENDIF|
3062 |         ENDDO|
3063 |         GIBSON_BLOCK2_ENERGY = GIBSON_TOTAL_ENERGY-GIBSON_BLOCK1_ENERGY|
3064 |      RETURN|
3065 |      END|
