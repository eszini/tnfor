2591 |      SUBROUTINE SHADOW_FUEL_INVENTORY(ENERGY,MMBTU_FUEL_BALANCE,|
2592 |     +                                 EA,COEFF,HEAT_RATE_FACTOR,|
2593 |     +                                 SEAS_HOURS,B,A,|
2594 |     +                                 LEFT,RIGHT,|
2595 |     +                                 AVAILABLE_SHADOW_CAPACITY,|
2596 |     +                                 MWBLOK,LODDUR,LPROB,|
2597 |     +                                 BLENDING_RATE,|
2598 |     +                                 SEC_BTU_COST)|
2599 |C|
2600 |      REAL EA,COEFF,HEAT_RATE_FACTOR,SEAS_HOURS,GET_HEAT_CONVERSION,|
2601 |     +     ENERGY,B,A,LEFT,RIGHT,AVAILABLE_SHADOW_CAPACITY|
2602 |      REAL ADJUSTED_ENERGY,B_ADJUSTED,MWBLOK,SEC_BTU_COST|
2603 |      REAL LODDUR(*),LPROB(*),BLENDING_RATE|
2604 |      REAL*8 DBLE_TEMP,HEAT,MMBTU_FUEL_BALANCE|
2605 |C|
2606 |      DBLE_TEMP = DBLE((EA * COEFF * HEAT_RATE_FACTOR * SEAS_HOURS)/|
2607 |     +                         GET_HEAT_CONVERSION())|
2608 |      HEAT = DBLE_TEMP * DBLE(ENERGY * (1. - BLENDING_RATE))|
2609 |      IF(HEAT <= MMBTU_FUEL_BALANCE) THEN|
2610 |         MMBTU_FUEL_BALANCE = MMBTU_FUEL_BALANCE - HEAT|
2611 |         AVAILABLE_SHADOW_CAPACITY = 0.|
2612 |      ELSE|
2613 |         HEAT = MMBTU_FUEL_BALANCE/(DBLE_TEMP*DBLE(1. - BLENDING_RATE))|
2614 |         ADJUSTED_ENERGY = SNGL(HEAT)|
2615 |         IF(A + ADJUSTED_ENERGY <= LODDUR(1)) THEN|
2616 |            B_ADJUSTED = A + ADJUSTED_ENERGY|
2617 |            RIGHT = 1.|
2618 |         ELSEIF(ABS(LEFT - RIGHT) < .0001) THEN|
2619 |            B_ADJUSTED = A + ADJUSTED_ENERGY/LEFT|
2620 |         ELSE|
2621 |C|
2622 |! FIND THE INCREMENT THAT HAS THE ENERGY CROSS-OVER|
2623 |C|
2624 |            CALL FIND_ENRGY_CROSSOVER(A,LEFT,ADJUSTED_ENERGY,LODDUR,|
2625 |     +                                LPROB,B_ADJUSTED,RIGHT)|
2626 |         ENDIF|
2627 |         AVAILABLE_SHADOW_CAPACITY = (B - B_ADJUSTED)*MWBLOK/(B-A)|
2628 |         MWBLOK = MWBLOK - AVAILABLE_SHADOW_CAPACITY|
2629 |         MMBTU_FUEL_BALANCE = 0.|
2630 |         ENERGY = ADJUSTED_ENERGY|
2631 |         B = B_ADJUSTED|
2632 |         IF(SEC_BTU_COST == 0.) AVAILABLE_SHADOW_CAPACITY = 0.|
2633 |      ENDIF|
2634 |      RETURN|
2635 |      END|
