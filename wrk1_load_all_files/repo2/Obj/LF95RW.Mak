TRANSOBJ2.OBJ: $(FOR10DIR)\$*.$(FOR95) $(SPINLIB) $(SIZE) $(GLOBE) $(KEPCO) $(MC) $(RPTMod)
               $(F95EXE)  $(FOR10DIR)\$*.$(FOR95)

############################
##That wraps up the objects
############################

MSGOLDRW.exe: OBJS
   lf95 -nc  -stack 1000000  -EXE MSGOLDRW  @LF95RW.lnk

COPYEXE:
   echo Done!

