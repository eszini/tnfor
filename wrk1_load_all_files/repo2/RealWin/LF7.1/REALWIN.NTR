  INTEGER FUNCTION save_dialog(dialog, stat)
    TYPE (dialog_t), DIMENSION(:), TARGET :: dialog
    INTEGER, OPTIONAL, INTENT(OUT) :: stat

    TYPE (save_dialog_pointer_t), DIMENSION(:), POINTER :: temp_list
    INTEGER :: i, slots

    CALL init_stat (stat)
    slots = SIZE(save_dialog_list, 1)
    DO i = 1, slots
      IF (.NOT. associated(save_dialog_list(i)%dialog)) THEN
        save_dialog_list(i)%dialog => dialog
        save_dialog = i
        RETURN
      END IF
    END DO

    ! All slots are full ... not likely!
    temp_list => save_dialog_list
    ALLOCATE (save_dialog_list(1:slots+10), stat=stat)
    DO i = 1, slots
      save_dialog_list(i)%dialog => temp_list(i)%dialog
    END DO

    DEALLOCATE (temp_list, stat=stat)
    save_dialog_list(slots+1)%dialog => dialog
    save_dialog = slots+1
    RETURN

  END FUNCTION save_dialog

  SUBROUTINE delete_save_dialog(slot)
    INTEGER, OPTIONAL, INTENT(IN) :: slot

    NULLIFY (save_dialog_list(slot)%dialog)
    RETURN

  END SUBROUTINE delete_save_dialog


