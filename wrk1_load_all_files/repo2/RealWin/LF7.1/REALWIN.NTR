MODULE realwin
  USE windows_h
  USE realwin_types

  IMPLICIT none

  ! Values for the dialog item state element
  INTEGER, PARAMETER :: DLGS_UPDOWN     = 512       ! low 9 bits is signed updown value
  INTEGER, PARAMETER :: DLGS_UPDOWN_MASK = 511
  INTEGER, PARAMETER :: DLGS_UPDOWN_SIGN = 256
  INTEGER, PARAMETER :: DLGS_UPDOWN_SIGN_EXTENSION = -512
  INTEGER, PARAMETER :: DLGS_UPDOWN_MAX = 1023
  INTEGER, PARAMETER :: DLGS_INITIAL   = 1024
  INTEGER, PARAMETER :: DLGS_MODIFIED  = 2048
  INTEGER, PARAMETER :: DLGS_ENTERED   = 4096
  INTEGER, PARAMETER :: DLGS_FINISHED  = 8192
  INTEGER, PARAMETER :: DLGS_PROCESSING = 16384
  INTEGER, PARAMETER :: DLGS_DOUBLECLICK = 32768
  INTEGER, PARAMETER :: DLGS_COMMAND    = 65536
  INTEGER, PARAMETER :: DLGS_NEED_UPDATE  = 65536 * 2  ! Application asking RealWin to update spreadsheet
  INTEGER, PARAMETER :: DLGS_DELETE       = 65536 * 4  ! Delete key in a spreadsheet
  INTEGER, PARAMETER :: DLGS_SHIFT_DELETE = 65536 * 8  ! Delete key, with shift, in a spreadsheet
  INTEGER, PARAMETER :: DLGS_INSERT       = 65536 * 16 ! Insert key in a spreadsheet
  INTEGER, PARAMETER :: DLGS_SHIFT_INSERT = 65536 * 32 ! Insert key, with shift, in a spreadsheet

  ! Defines for dialog box proc
  INTEGER, PARAMETER :: DLGB_INITIAL   = 1024 + 8
  INTEGER, PARAMETER :: DLGB_FINISHED  = 1024 + 9
  INTEGER, PARAMETER :: DLGB_CLOSED    = 1024 + 10


  ! Defines for window change_procedure callback routined
  INTEGER, PARAMETER :: CH_SIZE_MAXHIDE   = 4 ! Some other window has been maximized.
  INTEGER, PARAMETER :: CH_SIZE_MAXIMIZED = 2 ! Window has been maximized.
  INTEGER, PARAMETER :: CH_SIZE_MAXSHOW   = 3 ! Some other window that was maximized has been restored to its former size.
  INTEGER, PARAMETER :: CH_SIZE_MINIMIZED = 1 ! Window has been minimized.
  INTEGER, PARAMETER :: CH_SIZE_RESTORED  = 0 ! Window has been resized, but not maximized or minimized.
  INTEGER, PARAMETER :: CH_MOVED          = 1024 + 5 ! Window was moved.
  INTEGER, PARAMETER :: CH_SETFOCUS       = 1024 + 6 ! Window has just gotten the "focus".
  INTEGER, PARAMETER :: CH_KILLFOCUS      = 1024 + 7 ! Window has just lost the "focus".

  ! Set_palette_mode defines
  INTEGER, PARAMETER :: PALETTE_SINGLE = 1
  INTEGER, PARAMETER :: PALETTE_EACH_BITMAP = 2
  INTEGER, PARAMETER :: PALETTE_FAVOR_ANIMATE = 3
  INTEGER, PARAMETER :: PALETTE_HALFTONE = 4

  ! Miscellaneous defines
  INTEGER, PUBLIC, PARAMETER :: DT_NORMAL = DT_LEFT + DT_TABSTOP + DT_WORDBREAK

  INTEGER, PUBLIC, PARAMETER :: STDOUT_UNIT = -32762
  INTEGER, PUBLIC, PARAMETER :: FIVE_AND_SIX = -(5 + (65536 * 6))


  CHARACTER, PUBLIC, PARAMETER :: tab_text = char(9)
  CHARACTER, PUBLIC, PARAMETER :: newline_text = CHAR(13)
  CHARACTER (len=20), PUBLIC, PARAMETER :: main_class_name = "realwin_MAIN_CLASS"
  CHARACTER (len=20), PUBLIC, PARAMETER :: rw_class_name = "realwin_CLASS"


  REAL, PRIVATE :: x_scale = 1.0
  REAL, PRIVATE :: y_scale = 1.0
  INTEGER, PRIVATE :: discard         ! Assign unneeded function results here
  LOGICAL, PRIVATE :: logical_discard ! Assign unneeded function results here
  LOGICAL, PRIVATE :: first_time = .true.
  LOGICAL :: dialog_tool_requested = .FALSE.
  LOGICAL :: dialog_tool_active = .FALSE.
  TYPE (dialog_t), POINTER, DIMENSION (:) :: realtool_dialog_copy
!  INTEGER, PUBLIC:: ES_NUMBER

  ! RealWin version number
  CHARACTER (LEN=*), PARAMETER :: realwin_version = "3.00a"

  CHARACTER (LEN=10), PUBLIC:: status = "3RDPARTY"  ! used in OPEN stmts


  INTEGER, PUBLIC :: accelerator_entries = 0
  INTEGER, PUBLIC :: accelerator_handle = 0
  TYPE (accel_t), PUBLIC, POINTER, DIMENSION(:) :: accelerator_table
  TYPE (menu_t), PUBLIC, POINTER, DIMENSION(:) :: main_menu
  INTEGER, PARAMETER :: SELF_DIAGNOSE_FILE = 16384
  INTEGER, PARAMETER :: SELF_DIAGNOSE_MEMORY = 32768
  INTEGER, PARAMETER :: SELF_DIAGNOSE_DEBUG = 65536
  INTEGER, PARAMETER :: SELF_DIAGNOSE_DIALOG = 8192
  INTEGER, PUBLIC :: self_diagnose = 1
  LOGICAL, PUBLIC :: PLATFORM_WIN32S = .FALSE.
  LOGICAL, PUBLIC :: PLATFORM_WIN95 = .FALSE.
  LOGICAL, PUBLIC :: PLATFORM_WIN98 = .FALSE.
  LOGICAL, PUBLIC :: PLATFORM_NT = .FALSE.
  LOGICAL, PUBLIC :: PLATFORM_NT40 = .FALSE.
  LOGICAL, PUBLIC :: PLATFORM_NT351 = .FALSE.
  LOGICAL, PUBLIC :: PROGRAM_ALREADY_RUNNING = .FALSE.
  INTEGER, PUBLIC, DIMENSION(6) :: PLATFORM_OK                  !
  INTEGER, PUBLIC :: dlg_default_control_height = 12            ! Default height of buttons, etc.
  INTEGER, PUBLIC :: dlg_default_text_height = 8                ! Default height of static text
  INTEGER, PUBLIC :: dlg_default_listbox_increment = 10         ! Height for each element, up to 4 in list box
  INTEGER, PUBLIC :: dlg_default_border = 7                     ! Spacing between controls and edges of dialog box
  INTEGER, PUBLIC :: dlg_default_spacing = 4                    ! Spacing between controls
  INTEGER, PUBLIC :: dlg_default_pushbutton_width = 40          ! Default width of pushbuttons
  INTEGER, PUBLIC :: dlg_default_editbox_width = 80             ! Default width of editbox, listbox, and combobox
  INTEGER, PUBLIC :: dlg_default_trackbar_height = 18           ! Default height of a trackbar control
  INTEGER, PUBLIC :: dlg_default_trackbar_width = 80            ! Default width of a trackbar control
  INTEGER, PUBLIC :: dlg_default_updown_height = 12             ! Default height of a updown control
  INTEGER, PUBLIC :: dlg_default_updown_width = 12              ! Default width of a updown control
  INTEGER, PUBLIC :: dlg_default_scrollbar_height = 10          ! Default height of a scrollbar control
  INTEGER, PUBLIC :: dlg_default_scrollbar_width = 80           ! Default width of a scrollbar control
  INTEGER, PUBLIC :: dlg_default_progressbar_height = 10        ! Default height of a progressbar control
  INTEGER, PUBLIC :: dlg_default_progressbar_width = 80         ! Default width of a progressbar control
  INTEGER, PUBLIC :: dlg_default_spreadsheet_height = 120       ! Default height of a spreadsheet control
  INTEGER, PUBLIC :: dlg_default_spreadsheet_width = 200        ! Default width of a spreadsheet control
  INTEGER, PUBLIC :: dlg_default_ss_cell_width = 42             ! Default width of spreadsheet cell
  INTEGER, PUBLIC :: dlg_default_ss_real_width = 51             ! Default width of real spreadsheet cell
  INTEGER, PUBLIC :: dlg_default_ss_double_width = 72           ! Default width of double spreadsheet cell
  INTEGER, PUBLIC :: dlg_default_ss_row_head_width = 21         ! Default width of spreadsheet row heading
  INTEGER, PUBLIC :: dlg_default_ss_row_node_width = 8          ! Default width of spreadsheet row button with no heading text
  INTEGER, PUBLIC :: dlg_default_ss_cell_height = 12            ! Default height of spreadsheet cell

  ! The following values can be specified for the x argument to set_dialog_item
  ! to perform special default spacing.
  INTEGER, PUBLIC, PARAMETER :: dlg_pos_right = -1       ! put this control to the right of the previous one
  INTEGER, PUBLIC, PARAMETER :: dlg_pos_back_1 = -2      ! put this control under the one BEFORE last
  INTEGER, PUBLIC, PARAMETER :: dlg_pos_next_column = -3 ! put this control at the top of the next column to the right
  INTEGER, PUBLIC, PARAMETER :: dlg_pos_default = -4

  ! Default brush for window background; it will get a non-zero value later.
  INTEGER, PUBLIC :: default_back_brush = 0

  ! Constants for get_key_state
  INTEGER, PUBLIC, PARAMETER ::  KEY_DOWN_FLAG = high_bit
  INTEGER, PUBLIC, PARAMETER ::  KEY_TOGGLED_FLAG = 1


  INTERFACE
    SUBROUTINE update_window(window, erase, rectangle, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (in) :: window
      LOGICAL, INTENT (IN), OPTIONAL :: erase ! True if the window needs to be erased
      TYPE (rect_t), OPTIONAL, INTENT (IN) :: rectangle
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE update_window

    SUBROUTINE set_foreground (window, stat)
      IMPLICIT NONE
      INTEGER, INTENT (in) :: window
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE set_foreground

    SUBROUTINE set_window_order (window, relative_window, stat)
      IMPLICIT NONE
      INTEGER, INTENT (in) :: window
      INTEGER, INTENT (in) :: relative_window
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE set_window_order

    FUNCTION window_exists(window)
      IMPLICIT NONE
      LOGICAL :: window_exists
      INTEGER, INTENT (in) :: window
    END FUNCTION window_exists

    FUNCTION box_exists(box)
      IMPLICIT NONE
      LOGICAL :: box_exists
      INTEGER, INTENT (in) :: box
    END FUNCTION box_exists

    FUNCTION menu_exists(menu)
      IMPLICIT NONE
      LOGICAL :: menu_exists
      INTEGER, INTENT (in) :: menu
    END FUNCTION menu_exists

    SUBROUTINE set_window_callback (callback)
      IMPLICIT NONE
      INTERFACE
        LOGICAL FUNCTION callback (window, message, wparam, lparam, result)
          INTEGER, INTENT (IN) :: window, message, wparam, lparam
          INTEGER, INTENT (INOUT) :: result
        END FUNCTION callback
      END INTERFACE
    END SUBROUTINE set_window_callback

    SUBROUTINE remove_window_callback
    END SUBROUTINE remove_window_callback

    SUBROUTINE set_dialog_callback (callback)
      IMPLICIT NONE
      INTERFACE
        LOGICAL FUNCTION callback (window, message, wparam, lparam, result)
          INTEGER, INTENT (IN) :: window, message, wparam, lparam
          INTEGER, INTENT (INOUT) :: result
        END FUNCTION callback
      END INTERFACE
    END SUBROUTINE set_dialog_callback

    SUBROUTINE remove_dialog_callback
    END SUBROUTINE remove_dialog_callback

    FUNCTION get_dialog_item_window (dialog_handle, dialog_item, stat) RESULT (control_handle)
      USE realwin_types
      IMPLICIT NONE

      INTEGER :: control_handle
      INTEGER, INTENT (IN) :: dialog_handle
      TYPE (dialog_t), INTENT (IN) :: dialog_item
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION get_dialog_item_window



    SUBROUTINE update_status_bar(window, stat)
      IMPLICIT NONE
      INTEGER, OPTIONAL, INTENT (in) :: window
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE update_status_bar

    SUBROUTINE update_box(box, stat)
      IMPLICIT NONE
      INTEGER, INTENT (in) :: box
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE update_box

    SUBROUTINE destroy_window (window, stat)
      IMPLICIT NONE
      INTEGER, INTENT (IN) :: window               ! Handle of the window
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE destroy_window

    SUBROUTINE write_scroll_line (window, box, text, update, stat)
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window    ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box       ! Scroll box
      CHARACTER (LEN=*), INTENT (IN) :: text      ! Line of text to write
      LOGICAL, OPTIONAL, INTENT (IN) :: update    ! Update the window immediately
                                                  ! Default is .TRUE. if not specified
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE write_scroll_line

    SUBROUTINE read_scroll_line (window, box, text, stat)
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window    ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box       ! Scroll box
      CHARACTER (LEN=*), INTENT (OUT) :: text      ! Line of text to read
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE read_scroll_line

    SUBROUTINE set_scroll_position (window, box, line, column, stat)
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window    ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box       ! Scroll box
      INTEGER, OPTIONAL, INTENT (IN) :: line      ! New Line
      INTEGER, OPTIONAL, INTENT (IN) :: column    ! New column
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE set_scroll_position

    SUBROUTINE get_scroll_position  (window, box, first_line, last_line, first_column, last_column, stat)
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window          ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box             ! Scroll box
      INTEGER, OPTIONAL, INTENT (OUT) :: first_line     ! First Line displayed
      INTEGER, OPTIONAL, INTENT (OUT) :: last_line      ! Last Line displayed
      INTEGER, OPTIONAL, INTENT (OUT) :: first_column   ! First column displayed
      INTEGER, OPTIONAL, INTENT (OUT) :: last_column    ! Last column displayed
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE get_scroll_position

    SUBROUTINE set_scroll_range (window, box, rows_to_scroll, columns_to_scroll, rows_per_screen, columns_per_screen, stat)
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window    ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box       ! Scroll box
      INTEGER, OPTIONAL, INTENT (IN) :: rows_to_scroll      ! New row
      INTEGER, OPTIONAL, INTENT (IN) :: columns_to_scroll    ! New column
      INTEGER, OPTIONAL, INTENT (IN) :: rows_per_screen      ! New row
      INTEGER, OPTIONAL, INTENT (IN) :: columns_per_screen    ! New column
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE set_scroll_range

    SUBROUTINE get_scroll_range (window, box, rows_to_scroll, columns_to_scroll, rows_per_screen, columns_per_screen, stat)
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window          ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box             ! Scroll box
      INTEGER, OPTIONAL, INTENT (OUT) :: rows_to_scroll     ! First row displayed
      INTEGER, OPTIONAL, INTENT (OUT) :: rows_per_screen      ! Last row displayed
      INTEGER, OPTIONAL, INTENT (OUT) :: columns_to_scroll   ! First column displayed
      INTEGER, OPTIONAL, INTENT (OUT) :: columns_per_screen    ! Last column displayed
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE get_scroll_range

    FUNCTION get_parent (window, stat) RESULT (parent)
      USE realwin_types
      IMPLICIT NONE

      INTEGER :: parent
      INTEGER, INTENT (IN) :: window
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION get_parent

    SUBROUTINE rw_spreadsheet_move (ss_window, mode, count, dialog, item, stat)
      USE realwin_types
      IMPLICIT NONE

      INTEGER, INTENT (IN) :: ss_window
      INTEGER, INTENT (IN) :: mode             ! MOVE operation for selection
      INTEGER, INTENT (IN) :: count            ! Number of positions to move
      TYPE (dialog_t), INTENT (IN) :: dialog   ! Pass first element of dialog array (Fortran / C compatibility)
      INTEGER, INTENT (IN) :: item             ! Element number in the dialog array
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE rw_spreadsheet_move


    SUBROUTINE rw_finish_spreadsheet_cell (ss_window, save)
      USE realwin_types
      IMPLICIT NONE

      INTEGER, INTENT (IN) :: ss_window
      LOGICAL, INTENT (IN) :: save             ! Save the edited value if true
    END SUBROUTINE rw_finish_spreadsheet_cell


    SUBROUTINE delete_scroll_lines (window, box, start_line, end_line, start_column, end_column, stat)
      IMPLICIT NONE
      ! Supply one of the following: window or box
      INTEGER, OPTIONAL, INTENT (IN) :: window    ! Scroll window
      INTEGER, OPTIONAL, INTENT (IN) :: box       ! Scroll box
      INTEGER, OPTIONAL, INTENT (IN) :: start_line      ! First line to delete
      INTEGER, OPTIONAL, INTENT (IN) :: end_line        ! Last line to delete
      INTEGER, OPTIONAL, INTENT (IN) :: start_column      ! First Column in first line
      INTEGER, OPTIONAL, INTENT (IN) :: end_column        ! Last column in last line
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE delete_scroll_lines


    INTEGER function get_windows_instance()
    END FUNCTION

    INTEGER function get_main_hwnd()
    END FUNCTION get_main_hwnd

    INTEGER FUNCTION get_key_state (key)
      IMPLICIT NONE
      INTEGER, INTENT (IN) :: key
    END FUNCTION get_key_state

    INTEGER FUNCTION send_message (window, msg, wparam, lparam)
      IMPLICIT NONE
      INTEGER, INTENT (IN) :: window, msg, wparam, lparam
    END FUNCTION send_message

    SUBROUTINE post_message (window, msg, wparam, lparam)
      IMPLICIT NONE
      INTEGER, INTENT (IN) :: window, msg, wparam, lparam
    END SUBROUTINE post_message

    SUBROUTINE get_current_directory (directory, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (OUT)           :: directory
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE get_current_directory

    SUBROUTINE set_current_directory (directory, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (IN)            :: directory
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE set_current_directory

    SUBROUTINE get_windows_directory (directory, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (OUT)           :: directory
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE get_windows_directory

    SUBROUTINE get_environment_variable (name, value, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (IN)  :: name
      CHARACTER (LEN=*), INTENT (OUT) :: value
      INTEGER, INTENT (OUT), OPTIONAL :: stat
    END SUBROUTINE get_environment_variable

    SUBROUTINE set_environment_variable (name, value, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (IN)  :: name
      CHARACTER (LEN=*), INTENT (IN)  :: value
      INTEGER, INTENT (OUT), OPTIONAL :: stat
    END SUBROUTINE set_environment_variable

    SUBROUTINE get_temp_file_name (file_name, prefix, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (OUT) :: file_name
      CHARACTER (LEN=*), OPTIONAL, INTENT (IN) :: prefix
      INTEGER, INTENT (OUT), OPTIONAL :: stat
    END SUBROUTINE get_temp_file_name

    SUBROUTINE get_exe_name (file_name, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (OUT) :: file_name
      INTEGER, INTENT (OUT), OPTIONAL :: stat
    END SUBROUTINE get_exe_name

    SUBROUTINE set_file_time (file_name, creation_time, access_time, write_time, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (IN) :: file_name
      INTEGER, OPTIONAL, INTENT (IN), DIMENSION (*) :: creation_time
      INTEGER, OPTIONAL, INTENT (IN), DIMENSION (*) :: access_time
      INTEGER, OPTIONAL, INTENT (IN), DIMENSION (*) :: write_time
      INTEGER, INTENT (OUT), OPTIONAL :: stat
    END SUBROUTINE set_file_time

    SUBROUTINE get_file_time (file_name, creation_time, access_time, write_time, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (IN) :: file_name
      INTEGER, OPTIONAL, INTENT (OUT), DIMENSION (*) :: creation_time
      INTEGER, OPTIONAL, INTENT (OUT), DIMENSION (*) :: access_time
      INTEGER, OPTIONAL, INTENT (OUT), DIMENSION (*) :: write_time
      INTEGER, INTENT (OUT), OPTIONAL :: stat
    END SUBROUTINE get_file_time

    SUBROUTINE get_registry_value (key, value_name, sub_keys, form, text, number, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: key
      CHARACTER (LEN=*), INTENT (IN)            :: value_name
      CHARACTER (LEN=*), INTENT (IN), OPTIONAL  :: sub_keys
      INTEGER, INTENT (OUT), OPTIONAL           :: form
      CHARACTER (LEN=*), INTENT (OUT), OPTIONAL :: text
      INTEGER, INTENT (OUT), OPTIONAL           :: number
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE get_registry_value

    SUBROUTINE open_registry_key (old_key, sub_keys, new_key, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: old_key
      CHARACTER (LEN=*), INTENT (IN)            :: sub_keys
      INTEGER, INTENT (OUT)                     :: new_key
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE open_registry_key

    SUBROUTINE close_registry_key (key, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: key
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE close_registry_key

    SUBROUTINE spawn (file_name, wait, stat)
      USE realwin_types
      IMPLICIT NONE
      CHARACTER (LEN=*), INTENT (IN)            :: file_name
      LOGICAL, INTENT (IN), OPTIONAL            :: wait
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE spawn

    FUNCTION rw_open_file (file_name, access, share, creation, attributes, stat) RESULT (handle)
      USE realwin_types
      IMPLICIT NONE
      INTEGER                                   :: handle            ! File handle is returned
      CHARACTER (LEN=*), INTENT (IN)            :: file_name         ! Name of file, port, etc.
      INTEGER, INTENT (IN), OPTIONAL            :: access            ! Access requested
      INTEGER, INTENT (IN), OPTIONAL            :: share             ! How the object can be shared
      INTEGER, INTENT (IN), OPTIONAL            :: creation          ! Conditional action based on whether file exists
      INTEGER, INTENT (IN), OPTIONAL            :: attributes        ! Attributes for a file being created
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END FUNCTION rw_open_file

    SUBROUTINE rw_read_file (handle, buffer, bytes_read, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: handle            ! File handle from rw_open_file
      CHARACTER(LEN=*), INTENT (OUT)            :: buffer            ! Buffer to fill
      INTEGER, INTENT (OUT), OPTIONAL           :: bytes_read        ! Number of bytes actually read
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE rw_read_file


    SUBROUTINE rw_write_file (handle, buffer, bytes_written, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: handle            ! File handle from rw_open_file
      CHARACTER(LEN=*), INTENT (IN)             :: buffer            ! Buffer to write
      INTEGER, INTENT (OUT), OPTIONAL           :: bytes_written     ! Number of bytes actually written
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE rw_write_file


    SUBROUTINE rw_close_file (handle, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: handle            ! File handle from rw_open_file
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE rw_close_file

    SUBROUTINE set_comm_timeout (handle, timeout, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: handle            ! File handle from rw_open_file
      TYPE (comm_timeout_t), INTENT (IN)        :: timeout           ! Communication port timeout parameters
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE set_comm_timeout

    SUBROUTINE get_comm_timeout (handle, timeout, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: handle            ! File handle from rw_open_file
      TYPE (comm_timeout_t), INTENT (OUT)       :: timeout           ! Communication port timeout parameters
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE get_comm_timeout

    SUBROUTINE set_comm_mode (handle, baudrate, parity, databits, stopbits, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN)                      :: handle            ! File handle from rw_open_file
      INTEGER, INTENT (IN), OPTIONAL            :: baudrate          ! Communication port mode parameters
      INTEGER, INTENT (IN), OPTIONAL            :: parity            ! Communication port mode parameters
      INTEGER, INTENT (IN), OPTIONAL            :: databits          ! Communication port mode parameters
      INTEGER, INTENT (IN), OPTIONAL            :: stopbits          ! Communication port mode parameters
      INTEGER, INTENT (OUT), OPTIONAL           :: stat
    END SUBROUTINE set_comm_mode

