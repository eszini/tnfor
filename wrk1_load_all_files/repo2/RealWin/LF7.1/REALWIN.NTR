    ! This subroutine can print a bitmap loaded by load_bitmapimage of a window or
    SUBROUTINE draw_bitmap (ups, bitmap, rectangle, fit_code, left, top, right, bottom, &
                            pixel_left, pixel_top, pixel_right, pixel_bottom, stat)
      USE realwin_types
      IMPLICIT NONE
      ! argument passed to the paint routine
      type (userpaint), INTENT (IN) :: ups        ! Destination userpaint structure
      INTEGER, INTENT (IN) :: bitmap    ! Source bitmap
      INTEGER, OPTIONAL, INTENT (IN) :: fit_code     ! fit_code to control shape and size
      TYPE (rect_t), OPTIONAL, INTENT (IN) :: rectangle ! Rectangle within the bitmap
      ! Locations within the destination
      REAL, OPTIONAL, INTENT (IN) :: left
      REAL, OPTIONAL, INTENT (IN) :: top
      REAL, OPTIONAL, INTENT (IN) :: right
      REAL, OPTIONAL, INTENT (IN) :: bottom
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_left
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_top
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_right
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_bottom
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE draw_bitmap

    ! This function loads a bitmap from a resource or directly from
    ! a device independent bitmap file
    FUNCTION load_bitmap (resource, id, file_name, window, box, source_bitmap, options, rectangle, ups, stat) RESULT (bitmap)
      USE realwin_types
      INTEGER :: bitmap
      CHARACTER (LEN=*), OPTIONAL, INTENT (IN) :: resource
      INTEGER, OPTIONAL, INTENT (IN)           :: id
      CHARACTER (LEN=*), OPTIONAL, INTENT (IN) :: file_name
      INTEGER, OPTIONAL, INTENT (IN)           :: window    ! Get bitmap from a window
      INTEGER, OPTIONAL, INTENT (IN)           :: box       ! Source box
      INTEGER, OPTIONAL, INTENT (IN)           :: source_bitmap    ! Source bitmap
      INTEGER, OPTIONAL, INTENT (IN)           :: options   ! Can be a combination of the following:
                                                            ! RW_WHOLE_WINDOW - Window argument means whole
                                                            !                   window, not just client area.
                                                            ! RW_SCREEN      - Take a snapshot of the whole screen
      TYPE (rect_t), OPTIONAL, INTENT (IN)     :: rectangle ! Rectangle within box or window
      type (userpaint), OPTIONAL, INTENT (IN)  :: ups       ! Model of Destination
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION load_bitmap




    ! This function creates an empty bitmap compatible with the screen
    FUNCTION create_bitmap (width, height, ups, stat) RESULT (bitmap)
      USE realwin_types
      INTEGER :: bitmap
      INTEGER, INTENT (IN)           :: width, height       ! Size in pixels
      type (userpaint), OPTIONAL, INTENT (IN)  :: ups       ! Model of Destination
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION create_bitmap


