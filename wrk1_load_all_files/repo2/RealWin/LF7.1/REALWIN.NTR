! set_dialog_item sets up all of the values for given dialog item
! Defaults will be supplied for any optional argument that is not supplied
!$IF DEFINED(FREE)
!  SUBROUTINE set_dialog_item (dialog_item, type, flags, title, text, value, x, y, width, height, list_box, stat)
  SUBROUTINE set_dialog_item (dialog_item, type, flags, title, text, id, value, x, y, &
             width, height, list_box, proc, font, custom, &
             integer_max, integer_min, integer_increment, &
             real_value, real_max, real_min, real_increment, &
             double_value, double_max, double_min, double_increment, format, &
             back_brush, text_color, icon, bitmap, style, buffer, edit, stat)

    USE realwin_types
    TYPE (dialog_t) :: dialog_item          ! Item to set up
    INTEGER, OPTIONAL, INTENT (IN) :: type
    INTEGER, OPTIONAL, INTENT (IN) :: flags
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: title
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: text
    INTEGER, OPTIONAL, INTENT (IN) :: value
    INTEGER, OPTIONAL, INTENT (IN) :: x, y    ! Location (in dialog box units) of the upper left corner
    INTEGER, OPTIONAL, INTENT (IN) :: width, height  ! Dimensions (in dialog box units) of the control
    CHARACTER (len=*), INTENT (IN), DIMENSION(:), OPTIONAL :: list_box
    LOGICAL proc
    EXTERNAL proc
    OPTIONAL proc
    INTEGER, OPTIONAL, INTENT (IN) :: id      ! ID number assigned to this control
    INTEGER, OPTIONAL, INTENT (IN) :: font    ! Font for any text in this control
    INTEGER, OPTIONAL, INTENT (IN) :: custom  ! Conversion filter number
    INTEGER, OPTIONAL, INTENT (IN) :: integer_max
