    ! Pass the specified mouse events to a Fortran procedure
    SUBROUTINE capture_mouse_events (window, mouse_proc, flags, cursor, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN) :: window            ! Window that wants mouse events
      INTEGER, INTENT (IN) :: flags             ! Mouse events to capture
      INTERFACE
        SUBROUTINE mouse_proc (event, begin_point, end_point, window, drag_rect, keys)
          USE realwin_types
          ! The argument below will have exactly one of the above event flags set. It is suitable for use in a SELECT CASE statement.
          INTEGER, INTENT (IN) :: event
          TYPE (point_t), INTENT (IN) :: begin_point ! Begin or only point for the event
          TYPE (point_t), INTENT (IN) :: end_point   ! End point for drag operations
          INTEGER, INTENT (IN) :: window             ! Window in which the mouse event occurred
          TYPE (rect_t), INTENT (IN) :: drag_rect    ! Rectangle derived from begin_point and end_point
          INTEGER, INTENT (IN) :: keys
          ! The above argument will contain bits to indicate the following statuses when the mouse event occurred.
          !   MK_CONTROL  Set if the CTRL key is down.
          !   MK_LBUTTON  Set if the left mouse button is down.
          !   MK_MBUTTON  Set if the middle mouse button is down.
          !   MK_RBUTTON  Set if the right mouse button is down.
          !   MK_SHIFT    Set if the SHIFT key is down.

        END SUBROUTINE mouse_proc
      END INTERFACE
      OPTIONAL mouse_proc
      INTEGER, OPTIONAL, INTENT (IN) :: cursor
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE capture_mouse_events

    SUBROUTINE cancel_drag_mark (window, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN), OPTIONAL  :: window           ! Window to cancel the marking in
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE cancel_drag_mark

    SUBROUTINE release_mouse_events (window, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, INTENT (IN) :: window           ! Window that is releasing mouse events
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE release_mouse_events


    ! Convert a pixel point to proportional coordinates of a window or box
    SUBROUTINE point_to_portion (ups, window, box, bitmap, point, x, y, stat)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: window
      INTEGER, OPTIONAL, INTENT (IN) :: box
      INTEGER, OPTIONAL, INTENT (IN) :: bitmap
      TYPE (point_t), INTENT (IN) :: point   ! Point in pixels
      REAL, INTENT (OUT) :: x, y             ! Proportional x & y coordinates
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE point_to_portion

