  FUNCTION create_main_window (window_name, menu, status_bar, toolbar, style, x, y, &
                          width, height, pixel_width, pixel_height, &
                          paint_code, file_name,                    &
                          text_color, text_font,                    &
                          icon, cursor, back_brush, show, paint_procedure, exit_procedure, &
                          scroll_procedure, change_procedure, bitmap, stat ) &
                          RESULT (window_handle)
    USE realwin_types
    INTEGER :: window_handle
    CHARACTER (len=*), INTENT (IN) :: window_name
    TYPE (menu_t), DIMENSION (:), OPTIONAL, TARGET :: menu
    TYPE (status_t), DIMENSION (:), OPTIONAL, INTENT (IN) :: status_bar
    TYPE (toolbar_t), DIMENSION (:), OPTIONAL, INTENT (IN) :: toolbar
!    INTEGER, OPTIONAL :: instance
    INTEGER, OPTIONAL, INTENT (IN) :: style
    REAL, OPTIONAL, INTENT (IN) :: x
    REAL, OPTIONAL, INTENT (IN) :: y
    REAL, OPTIONAL, INTENT (IN) :: width
    REAL, OPTIONAL, INTENT (IN) :: height
    INTEGER, OPTIONAL, INTENT (IN) :: pixel_width, pixel_height
    INTEGER, OPTIONAL, INTENT (IN) :: paint_code ! Method of painting the box
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: file_name  ! Name of a file to scroll
    INTEGER, OPTIONAL, INTENT (IN) :: text_color, text_font    ! text
    INTEGER, OPTIONAL, INTENT (IN) :: icon
    INTEGER, OPTIONAL, INTENT (IN) :: cursor
    INTEGER, OPTIONAL, INTENT (IN) :: back_brush
    INTEGER, OPTIONAL, INTENT (IN) :: show
    ! Fortran procedure for painting the Window
    EXTERNAL paint_procedure
    OPTIONAL :: paint_procedure
    ! Fortran procedure that is called before the Window is closed
    EXTERNAL exit_procedure
    LOGICAL exit_procedure
    OPTIONAL exit_procedure
    EXTERNAL scroll_procedure
    INTEGER scroll_procedure
    OPTIONAL scroll_procedure
    EXTERNAL change_procedure
    OPTIONAL change_procedure
    INTEGER, OPTIONAL, INTENT (IN) :: bitmap    ! Bitmap to associate with the window
    INTEGER, INTENT (OUT), OPTIONAL           :: stat

  END FUNCTION create_main_window

  FUNCTION create_window (window_name, menu, toolbar, class_name, style, x, y, width, height, &
                          pixel_width, pixel_height, &
                          paint_code, file_name, text_color, text_font, &
                          owner, icon, cursor, back_brush, show, paint_procedure, &
                          exit_procedure, scroll_procedure, change_procedure, bitmap, stat) RESULT (window_handle)
    USE realwin_types
    IMPLICIT NONE
    INTEGER :: window_handle
    CHARACTER (len=*), INTENT (IN) :: window_name
    TYPE (menu_t), DIMENSION (:), OPTIONAL, TARGET :: menu
    TYPE (toolbar_t), DIMENSION (:), OPTIONAL, INTENT (IN) :: toolbar
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: class_name
!    INTEGER, OPTIONAL :: instance
    INTEGER, OPTIONAL, INTENT (IN) :: style
    REAL, OPTIONAL, INTENT (IN) :: x
    REAL, OPTIONAL, INTENT (IN) :: y
    REAL, OPTIONAL, INTENT (IN) :: width
    REAL, OPTIONAL, INTENT (IN) :: height
    INTEGER, OPTIONAL, INTENT (IN) :: pixel_width, pixel_height
    INTEGER, OPTIONAL, INTENT (IN) :: paint_code ! Method of painting the box
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: file_name  ! Name of a file to scroll
    INTEGER, OPTIONAL, INTENT (IN) :: text_color, text_font    ! text
    INTEGER, OPTIONAL, INTENT (IN) :: owner
    INTEGER, OPTIONAL, INTENT (IN) :: icon
    INTEGER, OPTIONAL, INTENT (IN) :: cursor
    INTEGER, OPTIONAL, INTENT (IN) :: back_brush
    INTEGER, OPTIONAL, INTENT (IN) :: show
    ! Fortran procedure for painting the Window
    EXTERNAL paint_procedure
    OPTIONAL :: paint_procedure
    ! Fortran procedure that is called before the Window is closed
    EXTERNAL exit_procedure
    LOGICAL exit_procedure
    OPTIONAL exit_procedure
    EXTERNAL scroll_procedure
    INTEGER scroll_procedure
    OPTIONAL scroll_procedure
    EXTERNAL change_procedure
    OPTIONAL change_procedure
    INTEGER, OPTIONAL, INTENT (IN) :: bitmap    ! Bitmap to associate with the window
    INTEGER, INTENT (OUT), OPTIONAL           :: stat

  END FUNCTION create_window

  SUBROUTINE redefine_window (window, window_name, paint_code, &
             x, y, width, height, pixel_x, pixel_y, pixel_width, pixel_height, &
             text_color, text_font, cursor, back_brush, paint_procedure, &
             scroll_procedure, change_procedure, bitmap, menu, show, update, &
             remove_paint_procedure, remove_scroll_procedure, remove_change_procedure, stat)
    IMPLICIT NONE
    INTEGER, INTENT (IN) :: window
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: window_name
    INTEGER, OPTIONAL, INTENT (IN) :: paint_code            ! Method of painting the box
    REAL, OPTIONAL, INTENT (IN) :: x
    REAL, OPTIONAL, INTENT (IN) :: y
    REAL, OPTIONAL, INTENT (IN) :: width
    REAL, OPTIONAL, INTENT (IN) :: height
    INTEGER, OPTIONAL, INTENT (IN) :: pixel_x, pixel_y
    INTEGER, OPTIONAL, INTENT (IN) :: pixel_width, pixel_height
    INTEGER, OPTIONAL, INTENT (IN) :: text_color, text_font ! text
    INTEGER, OPTIONAL, INTENT (IN) :: cursor
    INTEGER, OPTIONAL, INTENT (IN) :: back_brush
    ! Fortran procedure for painting the Window
    EXTERNAL paint_procedure
    OPTIONAL :: paint_procedure
    EXTERNAL scroll_procedure
    INTEGER scroll_procedure
    OPTIONAL scroll_procedure
    EXTERNAL change_procedure
    OPTIONAL change_procedure
    INTEGER, OPTIONAL, INTENT (IN) :: bitmap    ! Bitmap to associate with the window
    TYPE (menu_t), DIMENSION (:), OPTIONAL, TARGET :: menu  ! Menu to associate with the window
    INTEGER, OPTIONAL, INTENT (IN) :: show
    LOGICAL, OPTIONAL, INTENT (IN) :: update    ! Update the window immediately
                                                ! Default is .TRUE. if not specified
    LOGICAL, OPTIONAL, INTENT (IN) :: remove_paint_procedure, remove_scroll_procedure, remove_change_procedure
    INTEGER, INTENT (OUT), OPTIONAL           :: stat
  END SUBROUTINE redefine_window




  FUNCTION pop_up_menu(menu, owner, x, y, pixel_x, pixel_y, flags, rect, stat) RESULT (command)
    USE realwin_types
    INTEGER :: command
    TYPE (menu_t), dimension(:), INTENT (INOUT) :: menu
    INTEGER, OPTIONAL, INTENT(IN)               :: owner
    REAL, INTENT (IN), OPTIONAL                 :: x, y   ! Proportional Screen coordinates
    INTEGER, INTENT (IN), OPTIONAL              :: pixel_x, pixel_y   ! Proportional Screen coordinates
    INTEGER, INTENT (IN), OPTIONAL              :: flags
    TYPE (rect_t), INTENT (IN), OPTIONAL        :: rect    ! Rectangle to avoid covering
    INTEGER, INTENT (OUT), OPTIONAL             :: stat
  END FUNCTION pop_up_menu

  FUNCTION create_menu(menu, pop_up, stat) RESULT (menu_handle)
    USE realwin_types
    INTEGER :: menu_handle
