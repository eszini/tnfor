  ! Extract the increment value from the state field
  FUNCTION updown_increment (state) RESULT (increment)
    INTEGER :: increment
    INTEGER, INTENT (IN) :: state

    increment = IAND(state, DLGS_UPDOWN_MASK)
    IF (IAND(increment, DLGS_UPDOWN_SIGN) /= 0) THEN
      increment = IOR(increment, DLGS_UPDOWN_SIGN_EXTENSION)
    END IF
  END FUNCTION updown_increment

