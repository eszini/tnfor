    ! This subroutine sets the size and 'fitting' mode of a userpaint
    ! variable, typically for the printer.
    SUBROUTINE set_output_fit (ups, window, box, fit_code, &
                            left, top, right, bottom, &
                            pixel_left, pixel_top, pixel_right, pixel_bottom, stat)
      USE realwin_types
      IMPLICIT NONE
      ! argument passed to the paint routine
      type (userpaint), INTENT (IN) :: ups        ! output userpaint structure
      INTEGER, OPTIONAL, INTENT (IN) :: window    ! model window
      INTEGER, OPTIONAL, INTENT (IN) :: box       ! model box
      INTEGER, OPTIONAL, INTENT (IN) :: fit_code  ! fit_code to control shape and size
      ! Locations within the output
      REAL, OPTIONAL, INTENT (IN) :: left
      REAL, OPTIONAL, INTENT (IN) :: top
      REAL, OPTIONAL, INTENT (IN) :: right
      REAL, OPTIONAL, INTENT (IN) :: bottom
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_left
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_top
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_right
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_bottom
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE set_output_fit

    SUBROUTINE get_page_data (ups, font, lines_on_page, minimum_chars, average_chars, &
                              copies, start_page, end_page, paper_size, margin, minimum_margin, &
                              landscape, stat)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: font           ! Set a font on which to base the data
      INTEGER, OPTIONAL, INTENT (OUT) :: lines_on_page ! Number of lines remaining
      INTEGER, OPTIONAL, INTENT (OUT) :: minimum_chars ! A line will hold this number of the widest chars
      INTEGER, OPTIONAL, INTENT (OUT) :: average_chars ! A line will, on average, hold this number of chars
      INTEGER, OPTIONAL, INTENT (OUT) :: copies        ! # of copies specified by user
      INTEGER, OPTIONAL, INTENT (OUT) :: start_page    ! Starting page number specified by user
      INTEGER, OPTIONAL, INTENT (OUT) :: end_page      ! Ending page number specified by user
      TYPE (size_t), OPTIONAL, INTENT (OUT) :: paper_size ! Size of page in mm/100 or inches/1000
      TYPE (rect_t), OPTIONAL, INTENT (OUT) :: margin     ! Margin in mm/100 or inches/1000
      TYPE (rect_t), OPTIONAL, INTENT (OUT) :: minimum_margin ! Minimum margin in mm/100 or inches/1000
      LOGICAL, OPTIONAL, INTENT (OUT) :: landscape     ! True if landscape orientation
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE get_page_data

    SUBROUTINE set_page_data (ups, copies, start_page, end_page, metric, &
               paper_size, margin, minimum_margin, landscape, stat)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: copies        ! # of copies specified by user
      INTEGER, OPTIONAL, INTENT (IN) :: start_page    ! Starting page number specified by user
      INTEGER, OPTIONAL, INTENT (IN) :: end_page      ! Ending page number specified by user
      LOGICAL, OPTIONAL, INTENT (IN) :: metric        ! If .TRUE., use metric measurements
      TYPE (size_t), OPTIONAL, INTENT (IN) :: paper_size ! Size of page in mm/100 or inches/1000
      TYPE (rect_t), OPTIONAL, INTENT (IN) :: margin     ! Margin in mm/100 or inches/1000
      TYPE (rect_t), OPTIONAL, INTENT (IN) :: minimum_margin ! Minimum margin in mm/100 or inches/1000
      LOGICAL, OPTIONAL, INTENT (IN) :: landscape     ! Set orientation to landscape
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE set_page_data

    ! Get the coordinates of the window or box, in pixels
    SUBROUTINE get_rect (ups, window, box, bitmap, options, rectangle, stat)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: window
      INTEGER, OPTIONAL, INTENT (IN) :: box
      INTEGER, OPTIONAL, INTENT (IN) :: bitmap
      INTEGER, OPTIONAL, INTENT (IN) :: options   ! Can be a combination of the following:
                                                  ! RW_WHOLE_WINDOW - Window argument means whole
                                                  !                   window, not just client area.
                                                  ! RW_SCREEN       - Rectangle values relative to the
                                                  !                   whole screen. If none of ups, window, box
                                                  !                   or bitmap are specified, then rectangle
                                                  !                   receives the coordinates of the whole screen.
      TYPE (rect_t), INTENT (OUT) :: rectangle
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE


