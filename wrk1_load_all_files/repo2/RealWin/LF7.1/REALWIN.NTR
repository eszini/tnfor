    SUBROUTINE flash_window (window, invert, nofocus, stat)
      INTEGER, OPTIONAL, INTENT (IN) :: window          ! Window to flash; default is main window
      LOGICAL, OPTIONAL, INTENT (IN) :: invert          ! If true, just invert the window state; default is .FALSE.
      LOGICAL, OPTIONAL, INTENT (IN) :: nofocus         ! If true, only flash if the window does
                                                        ! NOT have the current focus; default is .FALSE.
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE flash_window

