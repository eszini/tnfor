    SUBROUTINE new_pen (ups, color, style, width, pixel_width, inches, millimeters, stat)
      USE realwin_types
      IMPLICIT NONE

      ! argument passed to the paint routine
      type (userpaint), INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: color     ! RGB color for the new pen
      INTEGER, OPTIONAL, INTENT (IN) :: style     ! Style for the new pen
                                                  ! Can be any of the following:
                                                  !   PS_SOLID      solid lines.
                                                  !   PS_DASH       dashed lines.
                                                  !   PS_DOT        dotted lines.
                                                  !   PS_DASHDOT    alternating dashes and dots.
                                                  !   PS_DASHDOTDOT alternating dashes and double dots.
                                                  !   PS_NULL       invisible lines.
      REAL, OPTIONAL, INTENT (IN) :: width        ! Width of the pen as a proportion
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_width  ! Width of the pen in pixels
      REAL, OPTIONAL, INTENT (IN) :: inches       ! Width of the pen in inches
      REAL, OPTIONAL, INTENT (IN) :: millimeters  ! Width of the pen in millimeters
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE new_pen

