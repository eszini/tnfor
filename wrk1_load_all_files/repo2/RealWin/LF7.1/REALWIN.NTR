    INTEGER, OPTIONAL, INTENT (IN) :: integer_min
    INTEGER, OPTIONAL, INTENT (IN) :: integer_increment
    REAL,    OPTIONAL, INTENT (IN) :: real_value
    REAL,    OPTIONAL, INTENT (IN) :: real_max
    REAL,    OPTIONAL, INTENT (IN) :: real_min
    REAL,    OPTIONAL, INTENT (IN) :: real_increment
    DOUBLE PRECISION, OPTIONAL, INTENT (IN) :: double_value
    DOUBLE PRECISION, OPTIONAL, INTENT (IN) :: double_max
    DOUBLE PRECISION, OPTIONAL, INTENT (IN) :: double_min
    DOUBLE PRECISION, OPTIONAL, INTENT (IN) :: double_increment
