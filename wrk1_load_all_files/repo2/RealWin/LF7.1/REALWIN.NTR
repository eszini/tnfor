  FUNCTION define_box (window_handle, paint_code, file_name, unit, &
                       left, top, right, bottom, &
                       pixel_left, pixel_top, pixel_right, pixel_bottom, &
                       back_brush, text_color, text_font, frame_brush, &
                       paint_procedure, scroll_procedure, bitmap, stat) &
                       RESULT (box_handle)
    USE realwin_types
    INTEGER :: box_handle                        ! Handle to the new box
    INTEGER, OPTIONAL, INTENT (IN) :: window_handle     ! Handle of the containing window
    INTEGER, OPTIONAL, INTENT (IN) :: paint_code ! Method of painting the box
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: file_name  ! Name of a file to scroll
    INTEGER, OPTIONAL, INTENT (IN) :: UNIT       ! Unit number to scroll
    ! Positions of the 4 corners relative to the containing window
    REAL, OPTIONAL, INTENT (IN) :: left, top, right, bottom
    ! Positions of the 4 corners in pixels relative to the upper left of the
    ! containing window
    INTEGER, OPTIONAL, INTENT (IN) :: pixel_left, pixel_top, pixel_right, pixel_bottom
    ! Background, text, and frame brushs in RGB
    INTEGER, OPTIONAL, INTENT (IN) :: back_brush, text_color, text_font, frame_brush
    ! Fortran procedure for painting the Box
    EXTERNAL paint_procedure
    OPTIONAL :: paint_procedure
    EXTERNAL scroll_procedure
    INTEGER scroll_procedure
    OPTIONAL scroll_procedure
    INTEGER, OPTIONAL, INTENT (IN) :: bitmap    ! Bitmap to associate with the box
    INTEGER, INTENT (OUT), OPTIONAL           :: stat

  END FUNCTION define_box


  SUBROUTINE redefine_box (handle, paint_code, file_name, unit, left, top, right, bottom, &
                       pixel_left, pixel_top, pixel_right, pixel_bottom, &
                       back_brush, text_color, text_font, frame_brush, &
                       paint_procedure, scroll_procedure, bitmap, &
                       remove_paint_procedure, remove_scroll_procedure, stat)
    USE realwin_types
    INTEGER, INTENT (IN) :: handle               ! Handle of the box
    INTEGER, OPTIONAL, INTENT (IN) :: paint_code ! Method of painting the box
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: file_name  ! Name of a file to scroll
    INTEGER, OPTIONAL, INTENT (IN) :: UNIT       ! Unit number to scroll
    ! Positions of the 4 corners relative to the containing window
    REAL, OPTIONAL, INTENT (IN) :: left, top, right, bottom
    ! Positions of the 4 corners in pixels relative to the upper left of the
    ! containing window
    INTEGER, OPTIONAL, INTENT (IN) :: pixel_left, pixel_top, pixel_right, pixel_bottom
    ! Background, text, and frame brushs in RGB
    INTEGER, OPTIONAL, INTENT (IN) :: back_brush, text_color, text_font, frame_brush
    ! Fortran procedure for painting the Box
    EXTERNAL paint_procedure
    OPTIONAL :: paint_procedure
    EXTERNAL scroll_procedure
    INTEGER scroll_procedure
    OPTIONAL scroll_procedure
    INTEGER, OPTIONAL, INTENT (IN) :: bitmap    ! Bitmap to associate with the box
    LOGICAL, OPTIONAL, INTENT (IN) :: remove_paint_procedure, remove_scroll_procedure
    INTEGER, INTENT (OUT), OPTIONAL           :: stat

  END SUBROUTINE redefine_box


  SUBROUTINE destroy_box (handle, stat)
    USE realwin_types
    INTEGER, INTENT (IN) :: handle               ! Handle of the box
    INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure

  END SUBROUTINE destroy_box

  ! This function starts a print job, including calling the print dialog
  FUNCTION start_print (ups, dialog_flags, owner, job_name, landscape, stat)
    USE realwin_types
    LOGICAL :: start_print
    type (userpaint), INTENT (OUT) :: ups             ! userpaint structure for printing
    INTEGER, OPTIONAL, INTENT (INOUT) :: dialog_flags ! Flags to control printing
    INTEGER, OPTIONAL, INTENT (IN) :: owner          ! Owner window for print dialog
    CHARACTER (LEN=*), OPTIONAL, INTENT (IN) :: job_name ! Name for the print job
    LOGICAL, OPTIONAL, INTENT (IN) :: landscape       ! Set orientation to landscape
    INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
  END FUNCTION start_print

  SUBROUTINE end_print (ups, stat)
    USE realwin_types
    type (userpaint), INTENT (INOUT) :: ups           ! userpaint structure for printing
    INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
  END SUBROUTINE end_print

