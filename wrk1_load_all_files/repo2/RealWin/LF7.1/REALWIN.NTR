    INTEGER, OPTIONAL, INTENT (IN) :: text_color
    INTEGER, OPTIONAL, INTENT (IN) :: icon
    INTEGER, OPTIONAL, INTENT (IN) :: bitmap
    INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure

  END SUBROUTINE update_dialog_item_a

