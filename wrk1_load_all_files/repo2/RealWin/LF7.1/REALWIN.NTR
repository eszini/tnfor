! set_menu_item sets up all of the values for given menu item
! Defaults will be supplied for any optional argument that is not supplied
  SUBROUTINE set_menu_item(menu_item, text, help, accelerator, drop_down, command, options)
    USE realwin_types
    TYPE (menu_t) :: menu_item          ! Item to set up
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: text
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: help
    CHARACTER (len=*), OPTIONAL, INTENT (IN) :: accelerator
    TYPE (menu_t), OPTIONAL, INTENT (IN), TARGET, DIMENSION(:) :: drop_down
    INTEGER, OPTIONAL, INTENT (IN) :: command
    INTEGER, OPTIONAL, INTENT (IN) :: options


  END SUBROUTINE set_menu_item

! change_menu_item_enable sets up all of the values for given menu item
! Defaults will be supplied for any optional argument that is not supplied
  SUBROUTINE change_menu_item_enable (menu_item, options)
    USE realwin_types
    TYPE (menu_t) :: menu_item          ! Item to change
    INTEGER, INTENT (IN) :: options


  END SUBROUTINE change_menu_item_enable

! update_menu_item sets up all of the values for given menu item
! Defaults will be supplied for any optional argument that is not supplied
  SUBROUTINE update_menu_item (menu_item, options, stat)
    USE realwin_types
    TYPE (menu_t) :: menu_item          ! Item to change
    INTEGER, INTENT (IN) :: options
    INTEGER, INTENT (OUT), OPTIONAL :: stat ! Returns non-zero if error

  END SUBROUTINE update_menu_item

