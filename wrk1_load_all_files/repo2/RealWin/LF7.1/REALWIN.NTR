      TYPE (point_t), INTENT (INOUT) :: point   ! Point in pixels
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE screen_to_client_point

    ! Convert a horizontal pixel to a proportional coordinate of a window or box
    FUNCTION x_pixel_to_portion (pixel_x, ups, window, box, bitmap, distance, stat) RESULT (x)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: window
      INTEGER, OPTIONAL, INTENT (IN) :: box
      INTEGER, OPTIONAL, INTENT (IN) :: bitmap
      INTEGER, INTENT (IN) :: pixel_x        ! Pixel location
      REAL :: x                              ! Proportional x coordinate
      LOGICAL, OPTIONAL, INTENT (IN) :: distance      ! .TRUE. iff a distance result is desired
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION x_pixel_to_portion

    ! Convert a vertical pixel to a proportional coordinate of a window or box
    FUNCTION y_pixel_to_portion (pixel_y, ups, window, box, bitmap, distance, stat) RESULT (y)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      INTEGER, OPTIONAL, INTENT (IN) :: window
      INTEGER, OPTIONAL, INTENT (IN) :: box
      INTEGER, OPTIONAL, INTENT (IN) :: bitmap
      INTEGER, INTENT (IN) :: pixel_y        ! Pixel location
      REAL :: y                              ! Proportional y coordinate
      LOGICAL, OPTIONAL, INTENT (IN) :: distance      ! .TRUE. iff a distance result is desired
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION y_pixel_to_portion

