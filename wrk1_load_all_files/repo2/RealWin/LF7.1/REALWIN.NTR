      INTEGER, OPTIONAL, INTENT (IN) :: owner
      CHARACTER (len=*), OPTIONAL, INTENT (IN) :: title
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION choose_color

    INTEGER FUNCTION choose_font (owner, color, rotate, ups, title, flags, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, OPTIONAL, INTENT (IN) :: owner
      REAL, OPTIONAL, INTENT (IN) :: rotate     ! Degrees up from the X axis to rotate the Font
      ! color to be set by the user; strikeout & underline can also be set in the
      ! dialog box if this argument is present.
      INTEGER, OPTIONAL, INTENT (OUT) :: color
      type (userpaint), OPTIONAL, INTENT (IN) :: ups ! For printer fonts
      CHARACTER (len=*), OPTIONAL, INTENT (IN) :: title
      INTEGER, OPTIONAL, INTENT (IN) :: flags     ! Flags to control font choice
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION


    SUBROUTINE get_font_data (font, ups, typeface, point, italic, underline, strikeout, bold, rotate, stat)
      USE realwin_types
      INTEGER, OPTIONAL, INTENT (IN) :: font
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      CHARACTER (len=*), OPTIONAL, INTENT (OUT) :: typeface
      INTEGER, OPTIONAL, INTENT (OUT) :: point
      LOGICAL, OPTIONAL, INTENT (OUT) :: italic, underline, bold, strikeout
      REAL, OPTIONAL, INTENT (OUT) :: rotate     ! Degrees up from the X axis to rotate the Font
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE get_font_data


    ! Get information about a volume in the file system.
    ! Returns .true. if successful
    !
    LOGICAL function get_volume_info (root, volume_name, volume_serial, &
                     max_file_name, file_system_name, case_preserved, case_sensitive, &
                     unicode, acl, file_compression, volume_compressed, stat)
      IMPLICIT NONE
      ! Name of the root directory, current drive if not specified
      CHARACTER (len=*), OPTIONAL, INTENT (IN) :: root
      ! Returns the name of the volume
      CHARACTER (len=*), OPTIONAL, INTENT (OUT) :: volume_name
      ! Returns the volume serial number
      INTEGER, OPTIONAL, INTENT (OUT) :: volume_serial
      ! Returns the maximum length of a component in a pathname, i.e.,
      ! something that can appear between two backslashes
      INTEGER, OPTIONAL, INTENT (OUT) :: max_file_name
      ! Returns the Name of the file system, e.g., FAT, NTFS
      CHARACTER (len=*), OPTIONAL, INTENT (OUT) :: file_system_name
      ! Returns .true. IFF the system preserves the case of filenames
      LOGICAL, OPTIONAL, INTENT (OUT) :: case_preserved
      ! Returns .true. IFF the system is case sensitive with filenames
      LOGICAL, OPTIONAL, INTENT (OUT) :: case_sensitive
      ! Returns .true. IFF the system supports UNICODE in filenames
      LOGICAL, OPTIONAL, INTENT (OUT) :: unicode
      ! Returns .true. IFF the system supports Access Control Lists
      LOGICAL, OPTIONAL, INTENT (OUT) :: acl
      ! Returns .true. IFF the system supports file based compression
      LOGICAL, OPTIONAL, INTENT (OUT) :: file_compression
      ! Returns .true. IFF the volume is compressed, e.g., doublespaced
      LOGICAL, OPTIONAL, INTENT (OUT) :: volume_compressed
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    end FUNCTION get_volume_info


    SUBROUTINE write_text (ups, text, x, y, pixel_x, pixel_y, color, back, font, append, &
                           format, tab_stop, left_margin, right_margin, rotate, &
!                           width, height, pixel_width, pixel_height, &
                           begin_point, end_point, lines, characters, stat)
      USE realwin_types
      IMPLICIT NONE
      ! argument passed to the paint routine
      type (userpaint), INTENT (IN) :: ups
      ! character string to write
      CHARACTER (len=*), INTENT (IN) :: text
      ! proportional coordinates for top left corner of area to write in
      REAL, OPTIONAL, INTENT (IN) :: x, y
      ! color for the text
      INTEGER, OPTIONAL, INTENT (IN) :: color
      ! color for the text background
      INTEGER, OPTIONAL, INTENT (IN) :: back
      ! font and point size for text
      INTEGER, OPTIONAL, INTENT (IN) :: font
      ! If True, append to last line, default false; not recommended with 'format'
      LOGICAL, OPTIONAL, INTENT (IN) :: append
      ! Automatic formatting for the text within a rectangle whose upper left
      ! corner is specified by x & y, and whose lower right corner is that of
      ! the window or box. Unless DT_NOPREFIX is specified, the character
      ! following an ampersand (&) will be underscored. To write an ampersand,
      ! you must specify two consecutive ampersands.
      ! Note: not to be used with 'rotate'.
      ! Value can one of the following:
      !  DT_NORMAL     - Aligns left, expands tabs, and breaks line at word boundaries.
      !                  Equivalent of DT_LEFT, DT_TABSTOP, & DT_WORDBREAK.
      !  DT_TOP        - Justifies a line of text at the top of the rectangle.
      !  DT_BOTTOM     - Justifies a line of text at the bottom of the rectangle.
      !  DT_LEFT       - Aligns text at the left.
      !  DT_RIGHT      - Aligns text to the right.
      !  DT_CENTER     - Centers text horizontally in the rectangle.
      !  DT_VCENTER    - Centers a line of text vertically.
      !  DT_NOPREFIX   - Turns off treating an ampersand (&) as a prefix character.
      !  DT_EXPANDTABS - Expands tab characters. The default number of characters
      !                  per tab is 8.
      !  DT_EXTERNALLEADING - Increases spacing between lines according to
      !                  the font 'external leading'.
      !  DT_SINGLELINE - Displays text on a single line only. Carriage returns
      !                  and linefeeds do not break the line.
      !  DT_WORDBREAK  - Breaks words. Lines are automatically broken between
      !                  words if a word extends past the edge of the rectangle
      !                  A carriage return-linefeed sequence also breaks the line.
      INTEGER, OPTIONAL, INTENT (IN) :: format
      ! pixel cooordinates for top left corner of are to write in
      INTEGER, OPTIONAL, INTENT (IN) :: pixel_x, pixel_y
      ! Number of average char widths for tab stop, used with 'format'
      INTEGER, OPTIONAL, INTENT (IN) :: tab_stop
      ! Number of average char widths for left margin, used with 'format'
      INTEGER, OPTIONAL, INTENT (IN) :: left_margin
      ! Number of average char widths for right margin, used with 'format'
      INTEGER, OPTIONAL, INTENT (IN) :: right_margin
      ! Degrees up from the X axis to rotate the text; not to be used with 'format'
      REAL, OPTIONAL, INTENT (IN) :: rotate
!      REAL, OPTIONAL, INTENT (IN) :: width
!      REAL, OPTIONAL, INTENT (IN) :: height
!      INTEGER, OPTIONAL, INTENT (IN) :: pixel_width, pixel_height
      TYPE (point_t), OPTIONAL, INTENT (OUT) :: begin_point, end_point
      INTEGER, OPTIONAL, INTENT (OUT) :: lines    ! Number of lines written
      INTEGER, OPTIONAL, INTENT (OUT) :: characters    ! Number of characters written
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE write_text

