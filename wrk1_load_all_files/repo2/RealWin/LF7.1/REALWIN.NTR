    ! Convert millimeters on the screen or printer to vertical pixels
    FUNCTION y_millimeters_to_pixel (y, ups, stat) RESULT (pixel_y)
      USE realwin_types
      IMPLICIT NONE
      type (userpaint), OPTIONAL, INTENT (IN) :: ups
      REAL, INTENT (IN) :: y                  ! millimeters on y axis
      INTEGER :: pixel_y                      ! Pixel location
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION y_millimeters_to_pixel

    ! Convert dialog units to pixel coordinates
    SUBROUTINE dialog_units_to_pixel (dialog_handle, font, x, y, width, height, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, OPTIONAL, INTENT (IN) :: dialog_handle ! Window handle of an active dialog box
      INTEGER, OPTIONAL, INTENT (IN) :: font   ! Handle to a font for a dialog box
      INTEGER, OPTIONAL, INTENT (INOUT) :: x, y, width, height
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE dialog_units_to_pixel

    ! Convert pixel cooridinates to dialog units
    SUBROUTINE pixel_to_dialog_units (dialog_handle, font, x, y, width, height, stat)
      USE realwin_types
      IMPLICIT NONE
      INTEGER, OPTIONAL, INTENT (IN) :: dialog_handle ! Window handle of an active dialog box
      INTEGER, OPTIONAL, INTENT (IN) :: font   ! Handle to a font for a dialog box
      INTEGER, OPTIONAL, INTENT (INOUT) :: x, y, width, height
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END SUBROUTINE pixel_to_dialog_units

! FREE! Note that this routine gets no args when called from the FREEBEE RealWin.
! For now we will allow all args to be not-present. Later on we may change this
! two separate interfaces and two C routines.
    ! This function invokes the page setup dialog
    FUNCTION page_setup_dialog (dialog_flags, owner, landscape, stat)
      USE realwin_types
      IMPLICIT none
      LOGICAL :: page_setup_dialog
      INTEGER, OPTIONAL, INTENT (INOUT) :: dialog_flags ! Flags to control page_setup
      INTEGER, OPTIONAL, INTENT (IN) :: owner           ! Owner window for page_setup dialog
      LOGICAL, OPTIONAL, INTENT (IN) :: landscape       ! Set orientation to landscape
      INTEGER, INTENT (OUT), OPTIONAL :: stat  ! Non-zero return if failure
    END FUNCTION page_setup_dialog


