    INTEGER, OPTIONAL, INTENT (IN) :: dialog_x, dialog_y ! Location (in dialog box units) of the upper left corner
    INTEGER, OPTIONAL, INTENT (IN) :: width, height  ! Dimensions (in dialog box units) of the box
    LOGICAL, OPTIONAL, INTENT (IN) :: modeless       ! True if modeless; default is modal
    INTEGER, OPTIONAL, INTENT (IN) :: font           ! Font for any text in the dialog box
    INTEGER, OPTIONAL, INTENT (IN) :: style          ! Special style for the dialog box
